		or (http and http.request)
		or http_request
		or request
	
	--// State
	Controller.Connections = {}
	Controller.Destroyed = false
	
	function Controller:Track(conn)
		table.insert(self.Connections, conn)
		return conn
	end
	
	function Controller:Destroy()
		if self.Destroyed then return end
		self.Destroyed = true
	
		for _, c in ipairs(self.Connections) do
			pcall(function()
				c:Disconnect()
			end)
		end
	
		self.Connections = {}
	
		if self.Gui then
			pcall(function()
				self.Gui:Destroy()
			end)
		end
	
		if script then
			pcall(function()
				script:Destroy()
			end)
		end
	end
	
	--// Allowed PlaceIds
	local allowedPlaceIds = {
		17698425045,
		86098085533596,
		18248633989,
		118758941554698
	}
	
	local wrongPlace = true
	for _, id in ipairs(allowedPlaceIds) do
		if game.PlaceId == id then
			wrongPlace = false
			break
		end
	end
	
	--// WRONG PLACE HANDLER (NOTIFICATION + TELEPORT)
	if wrongPlace then
		StarterGui:SetCore("SendNotification", {
			Title = "Wrong Game",
			Text = "Redirecting you to the correct game...",
			Duration = 5
		})
	
		task.delay(5, function()
			if Controller.Destroyed then return end
	
			local function getRandomPlace()
				return allowedPlaceIds[math.random(1, #allowedPlaceIds)]
			end
	
			pcall(function()
				TeleportService:Teleport(getRandomPlace(), LocalPlayer)
			end)
