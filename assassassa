local function OTHUUX_fake_script() -- OutlastHubNormalPremium_2.TextLabel_14.LocalScript 
	local script = Instance.new('LocalScript', OutlastHubNormalPremium_2.TextLabel_14)

	local Players = game:GetService("Players")
	
	local RunService = game:GetService("RunService")
	
	
	
	local player = Players.LocalPlayer
	
	local button = script.Parent:WaitForChild("WipButton")
	
	
	
	local onColor = Color3.fromRGB(51, 255, 47)
	
	local offColor = Color3.fromRGB(255, 0, 0)
	
	button.BackgroundColor3 = offColor
	
	
	
	local attackInterval = 0.16
	
	local hitPartsList = { "Head" }
	
	local attackHealthThreshold = 100
	
	local currentHand = "RightHand"
	
	local TargetR = 10
	
	
	
	local humanoid = nil
	
	local character = nil
	
	
	
	-- Class checker
	
	local leaderstats = player:WaitForChild("leaderstats", 5)
	
	local classValue = leaderstats and leaderstats:WaitForChild("Class", 5)
	
	local lastClass = nil
	
	
	
	local function updateClass()
	
		if classValue then
	
			lastClass = classValue.Value
	
		end
	
	end
	
	
	
	-- Remote finder
	
	local function getRemote()
	
		if not character then return nil end
	
		local core = character:FindFirstChild("Core")
	
		if not core then return nil end
	
		local comm = core:FindFirstChild("Communicate")
	
		if not comm then return nil end
	
	
	
		for _, v in pairs(comm:GetChildren()) do
	
			if v:IsA("RemoteEvent") then
	
				return v
	
			end
	
		end
	
		return nil
	
	end
	
	
	
	-- Target selection
	
	local function getRandomTarget()
	
		if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
	
		local hrp = character.HumanoidRootPart
	
	
	
		local candidates = {}
	
	
	
		for _, plr in pairs(Players:GetPlayers()) do
	
			if plr ~= player and plr.Character then
	
				local tHRP = plr.Character:FindFirstChild("HumanoidRootPart")
	
				local hum = plr.Character:FindFirstChildOfClass("Humanoid")
	
	
	
				if tHRP and hum and hum.Health > 0 and hum.Health <= attackHealthThreshold then
	
					local distance = (tHRP.Position - hrp.Position).Magnitude
	
					if distance <= TargetR then
	
						table.insert(candidates, plr)
	
					end
	
				end
	
			end
	
		end
	
	
	
		if #candidates > 0 then
	
			return candidates[math.random(1, #candidates)]
	
		end
	
	
	
		return nil
	
	end
	
	
	
	-- Attack
	
	local function performAttack(target)
	
		if not target or not target.Character or not character then return end
	
		updateClass()
	
		if not lastClass then return end
	
	
	
		local tChar = target.Character
	
		local hrp = tChar:FindFirstChild("HumanoidRootPart")
	
		if not hrp then return end
	
	
	
		local remote = getRemote()
	
		if not remote then return end
	
	
	
		local offHand = (currentHand == "RightHand") and "LeftHand" or "RightHand"
	
		local hitPart = tChar:FindFirstChild(hitPartsList[1]) or hrp
	
	
	
		local args = {
	
			"Heavy",
	
			{
	
				Point = hrp.Position, -- Exact HRP position, no prediction
	
				Combo = math.random(1, 5),
	
				Class = lastClass,
	
				IsKnockdown = false,
	
				Character = tChar,
	
				Hit = hitPart,
	
				Limb = currentHand,
	
				Result = nil
	
			},
	
			false
	
		}
	
	
	
		remote:FireServer(unpack(args))
	
		remote:FireServer("Swing", { Limb = currentHand })
	
		currentHand = offHand
	
	end
	
	
	
	-- Loop toggle
	
	local Toggle = false
	
	local loopRunning = false
	
	
	
	button.MouseButton1Click:Connect(function()
	
		Toggle = not Toggle
	
		button.BackgroundColor3 = Toggle and onColor or offColor
	
	
	
		if Toggle and not loopRunning then
	
			loopRunning = true
	
	
	
			task.spawn(function()
	
				local currentTarget = nil
	
				local lastAttackTime = 0
	
	
	
				while Toggle do
	
					local myHRP = character and character:FindFirstChild("HumanoidRootPart")
	
	
	
					if not currentTarget
	
						or not currentTarget.Character
	
						or not currentTarget.Character:FindFirstChildOfClass("Humanoid")
	
						or currentTarget.Character:FindFirstChildOfClass("Humanoid").Health <= 0
	
						or not myHRP
	
						or not currentTarget.Character:FindFirstChild("HumanoidRootPart")
	
						or (currentTarget.Character.HumanoidRootPart.Position - myHRP.Position).Magnitude > TargetR
	
					then
	
						currentTarget = getRandomTarget()
	
					end
	
	
	
					if currentTarget and currentTarget.Character then
	
						local hum = currentTarget.Character:FindFirstChildOfClass("Humanoid")
	
						if hum and hum.Health > 0 then
	
							local now = tick()
	
							if now - lastAttackTime >= attackInterval then
	
								performAttack(currentTarget)
	
								lastAttackTime = now
	
							end
	
						end
	
					end
	
	
	
					task.wait()
	
				end
	
	
	
				loopRunning = false
	
			end)
	
		end
	
	end)
	
	
	
	-- Character handling
	
	local function onCharacterAdded(char)
	
		character = char
	
		humanoid = char:WaitForChild("Humanoid")
	
	end
	
	
	
	if player.Character then
	
		onCharacterAdded(player.Character)
	
	end
	
	player.CharacterAdded:Connect(onCharacterAdded) 
end
