local function ANTQE_fake_script() -- TextLabel_35.mainScript 
	local script = Instance.new('LocalScript', TextLabel_35)

	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	
	local player = Players.LocalPlayer
	local button = script.Parent:WaitForChild("WipButton")
	
	local onColor = Color3.fromRGB(51, 255, 47)
	local offColor = Color3.fromRGB(255, 0, 0)
	button.BackgroundColor3 = offColor
	
	local attackInterval = 0.33
	local PREDICTION_FACTOR = 1
	local hitPartsList = { "Head" }
	local attackHealthThreshold = 100
	local currentHand = "RightHand"
	
	local humanoid
	local character
	local stylesFolder
	local animationClassMap = {}
	local lastClass = nil
	local classUpdateConnection
	
	-- =========================
	-- Animation / Class Functions
	-- =========================
	local function getIdNumber(animation)
		if not animation or not animation.AnimationId then return nil end
		local id = animation.AnimationId:match("%d+")
		return id and tonumber(id)
	end
	
	local function scanStyles(folder, className)
		for _, child in pairs(folder:GetChildren()) do
			if child:IsA("Animation") then
				local id = getIdNumber(child)
				if id then
					animationClassMap[id] = className
				end
			elseif child:IsA("Folder") then
				scanStyles(child, className)
			end
		end
	end
	
	local function updateClassFromAnimation()
		if not humanoid then return end
		local animator = humanoid:FindFirstChildOfClass("Animator")
		if not animator then return end
	
		for _, track in pairs(animator:GetPlayingAnimationTracks()) do
			local id = getIdNumber(track.Animation)
			local className = id and animationClassMap[id]
			if className then
				lastClass = className
				break
			end
		end
	end
	
	local function onCharacterAdded(char)
		character = char
		humanoid = character:WaitForChild("Humanoid")
		stylesFolder = character:WaitForChild("Core"):WaitForChild("Animations"):WaitForChild("Styles")
		animationClassMap = {}
		lastClass = nil
	
		for _, classFolder in pairs(stylesFolder:GetChildren()) do
			if classFolder:IsA("Folder") then
				scanStyles(classFolder, classFolder.Name)
			end
		end
	
		if classUpdateConnection then
			classUpdateConnection:Disconnect()
		end
	
		classUpdateConnection = RunService.Heartbeat:Connect(updateClassFromAnimation)
		task.defer(updateClassFromAnimation)
	end
	
	-- Initial bind and respawn bind
	onCharacterAdded(player.Character or player.CharacterAdded:Wait())
	player.CharacterAdded:Connect(onCharacterAdded)
	
	-- =========================
	-- Utility Functions
	-- =========================
	local function getRemote()
		if not character then return end
		local core = character:WaitForChild("Core")
		local comm = core:WaitForChild("Communicate")
		for _, v in pairs(comm:GetChildren()) do
			if v:IsA("RemoteEvent") then
				return v
			end
		end
	end
	
	local function predictPosition(hrp)
		return hrp.Position + (hrp.Velocity * attackInterval * PREDICTION_FACTOR)
	end
	
	-- =========================
	-- Fixed Highlight Check
	-- =========================
	local function hasHighlight(plr)
		if not plr.Character then return false end
	
		local function findHighlight(parent)
			for _, child in pairs(parent:GetChildren()) do
				if child:IsA("Highlight") then
					return true
				elseif child:IsA("Model") or child:IsA("Folder") then
					if findHighlight(child) then
						return true
					end
				end
			end
			return false
		end
	
		return findHighlight(plr.Character)
	end
	
	local function getRandomTarget()
		local candidates = {}
		for _, plr in pairs(Players:GetPlayers()) do
			if plr ~= player and plr.Character then
				local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
				local humanoid = plr.Character:FindFirstChildOfClass("Humanoid")
				if hrp and humanoid and humanoid.Health > 0 and humanoid.Health <= attackHealthThreshold then
					if not hasHighlight(plr) then
						table.insert(candidates, plr)
					end
				end
			end
		end
		if #candidates > 0 then
			return candidates[math.random(1, #candidates)]
		end
		return nil
	end
	
	local function performAttack(target)
		if not target or not target.Character or not character then return end
		local tChar = target.Character
		local hrp = tChar:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
	
		local remote = getRemote()
		if not remote then return end
	
		local myClass = lastClass or ""
		local offHand = (currentHand == "RightHand") and "LeftHand" or "RightHand"
	
		-- Only attack once per call
		local hitPart = tChar:FindFirstChild(hitPartsList[1]) or hrp
		local args = {
			"Heavy",
			{
				Point = predictPosition(hrp),
				Combo = math.random(1, 5),
				Class = myClass,
				IsKnockdown = false,
				Character = tChar,
				Hit = hitPart,
				Limb = currentHand,
				Result = nil
			},
			false
		}
	
		remote:FireServer(unpack(args))
		remote:FireServer("Swing", { Limb = currentHand })
		remote:FireServer("Swing", { Limb = offHand })
		currentHand = offHand
	end
	
	-- =========================
	-- Teleport / RunService
	-- =========================
	local teleportConnection
	
	local function startTeleportLoop(target)
		if teleportConnection then
			teleportConnection:Disconnect()
		end
	
		teleportConnection = RunService.Heartbeat:Connect(function()
			if not target or not target.Character or not character then return end
			local myHRP = character:FindFirstChild("HumanoidRootPart")
			local tHRP = target.Character:FindFirstChild("HumanoidRootPart")
			if not myHRP or not tHRP then return end
	
			-- Disable collisions
			for _, part in ipairs(character:GetDescendants()) do
				if part:IsA("BasePart") then
					part.CanCollide = false
				end
			end
	
			-- Teleport and rotate
			local underPos = tHRP.Position + Vector3.new(0, -6.5, 0)
			myHRP.CFrame = CFrame.new(underPos, underPos + Vector3.new(0, 1, 0)) * CFrame.Angles(math.rad(180), 0, 0)
		end)
	end
	
	local function stopTeleportLoop()
		if teleportConnection then
			teleportConnection:Disconnect()
			teleportConnection = nil
		end
	end
	
	-- =========================
	-- Toggle Loop
	-- =========================
	local Toggle = false
	local loopRunning = false
	
	button.MouseButton1Click:Connect(function()
		Toggle = not Toggle
		button.BackgroundColor3 = Toggle and onColor or offColor
	
		if Toggle and not loopRunning then
			loopRunning = true
	
			task.spawn(function()
				local currentTarget = nil
				local lastAttackTime = 0
	
				while Toggle do
					if not currentTarget or not currentTarget.Character then
						currentTarget = getRandomTarget()
					else
						local hum = currentTarget.Character:FindFirstChildOfClass("Humanoid")
						if not hum or hum.Health <= 0 then
							currentTarget = getRandomTarget()
						end
					end
	
					if currentTarget and currentTarget.Character then
						local hum = currentTarget.Character:FindFirstChildOfClass("Humanoid")
						if hum and hum.Health > 0 then
							startTeleportLoop(currentTarget)
	
							local now = tick()
							if now - lastAttackTime >= attackInterval then
								performAttack(currentTarget)
								lastAttackTime = now
							end
						end
					end
	
					task.wait()
				end
	
				stopTeleportLoop()
				loopRunning = false
			end)
		else
			stopTeleportLoop()
		end
	end)
end
