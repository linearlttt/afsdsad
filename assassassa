						commRemote:FireServer("Pickup", {Object = sourceChar, Type = item}, false)
						commRemote:FireServer("Throw", {Type = item, Object = sourceChar, HoldDuration = 0, Held = true, Aim = IMPACT_SPEED}, false)
						throwableRemote:FireServer("Impact", {Object = sourceChar, Type = item, Speed = IMPACT_SPEED, Part = sourceChar, HitPosition = sourceRoot.Position, GUID = HttpService:GenerateGUID(false)})
	
						performedAttack = true
					end
				end
			end
	
			if performedAttack then
				lastThrowTime = currentTime 
				CurrentIndex = (CurrentIndex % #ItemCycle) + 1
			end
		end)
	end
	
