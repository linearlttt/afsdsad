	local function getActiveSourcePlayers()
		local activePlayers = {}
		for _, userId in ipairs(savedTargetUserIds) do
			local foundPlayer = Players:GetPlayerByUserId(userId)
			if foundPlayer then
				table.insert(activePlayers, foundPlayer)
			end
		end
		return activePlayers
	end
	
