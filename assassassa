					if hitPlayer and hitPlayer ~= player and not ignoreIDs[hitPlayer.UserId] then
						local hum = hitModel:FindFirstChildOfClass("Humanoid")
						if hum and hum.Health > 0 then
							-- Clean old lock if exists, then establish new lock
							shutDownEverything()
							task.wait(0.05)
							currentTarget = hitPlayer
							startLoop()
						end
					end
				end
			end
		end
	end
	
	UIS.InputBegan:Connect(onInputBegan)
	
