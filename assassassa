				local sourceRoot = sourceChar and sourceChar:FindFirstChild("HumanoidRootPart")
				local humanoid = sourceChar and sourceChar:FindFirstChildWhichIsA("Humanoid")
	
				-- TARGET SELF: Set the target directly to the source player's own character components
				if sourceChar and sourceRoot and humanoid and humanoid.Health > 0 and isPlayerLoaded(sourcePlr) then
					local commRemote = getCommunicate(sourceChar)
					local throwableRemote = remotesFolder and remotesFolder:FindFirstChild("ThrowableRemote")
	
					if commRemote and throwableRemote then
						local item = ItemCycle[CurrentIndex]
	
						local clickDetector = sourceChar:FindFirstChildWhichIsA("ClickDetector", true)
						if clickDetector then safeFireClick(clickDetector) end
	
						-- Remote execution firing at themselves
						commRemote:FireServer("Pickup", {Object = sourceChar, Type = item}, false)
