			local result = Workspace:Raycast(ray.Origin, ray.Direction * 1000, raycastParams)
	
			if result and result.Instance then
				local hitModel = result.Instance:FindFirstAncestorOfClass("Model")
				if hitModel then
					local hitPlayer = Players:GetPlayerFromCharacter(hitModel)
					if hitPlayer and hitPlayer ~= player and not ignoreIDs[hitPlayer.UserId] then
						local hum = hitModel:FindFirstChildOfClass("Humanoid")
						if hum and hum.Health > 0 then
							-- Clean old lock if exists, then establish new lock
							shutDownEverything()
							task.wait(0.05)
							currentTarget = hitPlayer
							startLoop()
						end
					end
				end
			end
		end
	end
	
	UIS.InputBegan:Connect(onInputBegan)
	
	-- CLEANUP EVENTS
	Players.PlayerRemoving:Connect(function(leavingPlayer)
		if currentTarget and leavingPlayer == currentTarget then
			shutDownEverything()
		end
	end)
	
	player.CharacterAdded:Connect(function(char)
		wipEnabled = false
		shutDownEverything()
		updateButtonVisuals()
		character = char
