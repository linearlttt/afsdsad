			button.BackgroundColor3 = Color3.fromRGB(255, 0, 0) 
			DisableThrowables(false)
		end
	end
	
	button.MouseButton1Click:Connect(h)--]]
	
	
	
	local Players = game:GetService("Players")
	local LocalPlayer = Players.LocalPlayer
	
	local Toggle = false
	local button = script.Parent:FindFirstChild("WipButton")
	
	-- State tracking and connection storage
	local States = { DisableTouch = false }
	local Connections = {}
	
	-- Applies or removes the touch restriction on a player's character parts
	local function SetPlayerTouch(character, shouldDisable)
		if not character then return end
		for _, part in ipairs(character:GetChildren()) do
			if part:IsA("BasePart") then
				-- If true, sets CanTouch to false (blocking them)
				-- If false, returns CanTouch back to true
				part.CanTouch = not shouldDisable
			end
		end
	end
	
	-- Handles monitoring and disabling other players' touch capabilities
	local function DisableOtherPlayersTouch(args1)
		States.DisableTouch = args1
	
		-- Clean up old event listeners (stops checking old character updates)
		for _, connection in ipairs(Connections) do
			connection:Disconnect()
		end
		table.clear(Connections)
	
		-- If the toggle is turned OFF, restore everyone's touch instantly
		if not args1 then
			for _, player in ipairs(Players:GetPlayers()) do
				if player ~= LocalPlayer and player.Character then
					SetPlayerTouch(player.Character, false)
				end
			end
			return
		end
	
		-- If toggled ON, apply restriction to current players and listen for updates
		for _, player in ipairs(Players:GetPlayers()) do
			if player ~= LocalPlayer then
				-- Apply to their current character
				if player.Character then
					SetPlayerTouch(player.Character, true)
				end
	
				-- Listen if they respawn or get a new character model
				table.insert(Connections, player.CharacterAdded:Connect(function(char)
					task.wait(0.1) -- Small delay to ensure body parts load in
					if States.DisableTouch then
						SetPlayerTouch(char, true)
					end
				end))
			end
		end
	
		-- Also listen for entirely new players joining the server
		table.insert(Connections, Players.PlayerAdded:Connect(function(player)
			table.insert(Connections, player.CharacterAdded:Connect(function(char)
				task.wait(0.1)
				if States.DisableTouch then
					SetPlayerTouch(char, true)
				end
			end))
		end))
	end
	
	-- The button toggle click event
	local function h()
		Toggle = not Toggle
	
		if Toggle then
			-- Turn green (ON) -> Disables other players from touching you
			button.BackgroundColor3 = Color3.fromRGB(51, 255, 47) 
			DisableOtherPlayersTouch(true)
		else
			-- Turn red (OFF) -> Allows other players to touch you normally again
			button.BackgroundColor3 = Color3.fromRGB(255, 0, 0) 
			DisableOtherPlayersTouch(false)
		end
	end
	
	button.MouseButton1Click:Connect(h)
end
