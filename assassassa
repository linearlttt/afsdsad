	local function untrackPlayer(enemyPlayer: Player)
		local pJanitor = Janitor.TrackingPlayers[enemyPlayer]
		if pJanitor then
			if pJanitor.AnimationHook then pJanitor.AnimationHook:Disconnect() end
			if pJanitor.CharAddedHook then pJanitor.CharAddedHook:Disconnect() end
			Janitor.TrackingPlayers[enemyPlayer] = nil
