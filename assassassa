				if id then
					animationClassMap[id] = className
				end
			elseif child:IsA("Folder") then
				scanStyles(child, className)
			end
		end
	end
	
	for _, classFolder in pairs(stylesFolder:GetChildren()) do
		if classFolder:IsA("Folder") then
			scanStyles(classFolder, classFolder.Name)
		end
	end
	
	local lastClass = nil
	
	local function updateClassFromAnimation()
		local animator = humanoid:FindFirstChildOfClass("Animator")
		if not animator then return end
	
		for _, track in pairs(animator:GetPlayingAnimationTracks()) do
			local id = getIdNumber(track.Animation)
			local className = id and animationClassMap[id]
			if className then
				lastClass = className
				break
			end
		end
	end
	
	RunService.Heartbeat:Connect(updateClassFromAnimation)
	
	local function isFightEquipped()
		local char = player.Character
		if not char then return false end
		local tool = char:FindFirstChildOfClass("Tool")
		return tool and tool.Name == "Fight"
	end
	
	local function getRemote()
		local char = player.Character or player.CharacterAdded:Wait()
		local core = char:WaitForChild("Core")
		local comm = core:WaitForChild("Communicate")
	
		for _, v in pairs(comm:GetChildren()) do
			if v:IsA("RemoteEvent") then
				return v
			end
		end
	end
	
	local function predictPosition(hrp)
		if not hrp then return end
		return hrp.Position + (hrp.Velocity * ATTACK_DELAY * 0.5)
	end
	
	local function stabilizeCharacter(hrp)
		if not hrp then return end
		hrp.Velocity = Vector3.new(0,0,0)
		hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
		hrp.AssemblyAngularVelocity = Vector3.new(0,0,0)
	end
	
	local function attack()
		local remote = getRemote()
		if not remote then return end
	
		local target = nil
		local myHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if not myHRP then return end
	
		-- Only target friends at 0 health
		for _, plr in pairs(Players:GetPlayers()) do
			if plr ~= player and plr.Character then
				local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
				local humanoid = plr.Character:FindFirstChildOfClass("Humanoid")
				if hrp and humanoid and humanoid.Health <= 0 and player:IsFriendsWith(plr.UserId) then
					local distance = (myHRP.Position - hrp.Position).Magnitude
					if distance <= MAX_DISTANCE then
						target = plr
						break
					end
				end
			end
		end
	
		if not target or not target.Character then return end
	
		local tChar = target.Character
		local hrp = tChar:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
	
		local myClass = lastClass
		local offHand = (currentHand == "RightHand") and "LeftHand" or "RightHand"
	
		for _, partName in pairs(hitPartsList) do
			local hitPart = tChar:FindFirstChild(partName) or hrp
			local args = {
				"Swing",
				{
					Point = predictPosition(hrp),
					Combo = 5,
					Class = myClass,
					IsKnockdown = false,
					Character = tChar,
					Hit = hitPart,
					Limb = currentHand,
					Classs = "",
					Result = nil
				},
				false
			}
	
			remote:FireServer(unpack(args))
			remote:FireServer("Swing", {Limb = currentHand})
			remote:FireServer("Swing", {Limb = offHand})
			currentHand = offHand
		end
	end
	
	-- =========================
	-- LOOP
	-- =========================
	local moveConnection
	local function startMovementLoop()
		if moveConnection then return end
		moveConnection = RunService.Heartbeat:Connect(function()
			if not attacking then return end
			local char = player.Character
			local myHRP = char and char:FindFirstChild("HumanoidRootPart")
			if not myHRP or not isFightEquipped() then return end
	
			for _, plr in pairs(Players:GetPlayers()) do
				if plr ~= player and plr.Character then
					local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
					local humanoid = plr.Character:FindFirstChildOfClass("Humanoid")
					if hrp and humanoid and humanoid.Health <= 0 and player:IsFriendsWith(plr.UserId) then
						local distance = (myHRP.Position - hrp.Position).Magnitude
						if distance <= MAX_DISTANCE then
							-- Wait 0.5 seconds before teleporting
							task.delay(0, function()
								if myHRP and attacking then
									stabilizeCharacter(myHRP)
									myHRP.CFrame = CFrame.new(predictPosition(hrp) + Vector3.new(0,0,2))
								end
							end)
							break
						end
					end
				end
			end
		end)
	end
	
	local function stopMovementLoop()
		if moveConnection then
			moveConnection:Disconnect()
			moveConnection = nil
		end
	end
	
	local function startLoop()
		if attacking then return end
		attacking = true
		startMovementLoop()
	
		task.spawn(function()
			while attacking do
				attack()
				task.wait(ATTACK_DELAY)
			end
		end)
	end
	
	local function stopLoop()
		attacking = false
		stopMovementLoop()
	end
	
	-- =========================
	-- WIP BUTTON
	-- =========================
	if wipButton then
		wipButton.MouseButton1Click:Connect(function()
			wipEnabled = not wipEnabled
			if wipEnabled then
				wipButton.BackgroundColor3 = Color3.fromRGB(51, 255, 47)
				startLoop()
			else
				wipButton.BackgroundColor3 = Color3.fromRGB(255, 11, 0)
				stopLoop()
			end
		end)
	end
end
coroutine.wrap(YZOMW_fake_script)()
local function UTSLDP_fake_script() -- TextLabel_29.LocalScript 
	local script = Instance.new('LocalScript', TextLabel_29)

	
	local Players = game:GetService("Players")
	local player = Players.LocalPlayer
	local button = script.Parent:FindFirstChild("WipButton")
	local textbox = script.Parent:WaitForChild("AnimSpeed")
	
	local TARGET_NAMES = {
		["1"] = true,
		["2"] = true,
		["3"] = true,
		["4"] = true,
	}
	
	local Toggle = false
	local loopRunning = false
	local c = 0.1
	local lastClick = 0
	
	local on = Color3.fromRGB(51, 255, 47)
	local off = Color3.fromRGB(255, 0, 0)
	
	button.BackgroundColor3 = off
	
	-- =======================
	-- Functions
	-- =======================
	local function getSpeed()
		local num = tonumber(textbox.Text)
		if num and num > 0 then
			return math.clamp(num, 0, 20) -- ensures speed is between 0 and 20
		end
		return nil
	end
	
	local function animationLoop()
		if loopRunning then return end
		loopRunning = true
	
		while Toggle do
			local character = player.Character
			if character then
				local humanoid = character:FindFirstChildOfClass("Humanoid")
				local animator = humanoid and humanoid:FindFirstChildOfClass("Animator")
	
				if animator then
					local speed = getSpeed()
					if speed then
						for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
							if track.Name and TARGET_NAMES[track.Name] then
								if track.IsPlaying then
									track:AdjustSpeed(speed)
								end
							end
						end
					end
				end
			end
	
			task.wait(0.1)
		end
	
		loopRunning = false
	end
	
	local function toggleButton()
		if tick() - lastClick < c then return end
		lastClick = tick()
	
		Toggle = not Toggle
	
		if Toggle then
			button.BackgroundColor3 = on
			task.spawn(animationLoop) -- run asynchronously
		else
			button.BackgroundColor3 = off
		end
	end
	
	button.MouseButton1Click:Connect(toggleButton)
	button.TouchTap:Connect(toggleButton)
end
