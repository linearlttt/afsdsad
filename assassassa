local function ONWR_fake_script() -- OutlastHubNormalPremium_2.TargetHit.LocalScript 
	local script = Instance.new('LocalScript', OutlastHubNormalPremium_2.TargetHit)

	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	local UIS = game:GetService("UserInputService")
	local Workspace = game:GetService("Workspace")
	
	local player = Players.LocalPlayer
	local character = player.Character or player.CharacterAdded:Wait()
	local humanoid = character:WaitForChild("Humanoid")
	local camera = Workspace.CurrentCamera 
	
	-- UI Elements
	local parentRoot = script.Parent
	local textBox = parentRoot:FindFirstChild("TargetBox")
	local wipButton = parentRoot:FindFirstChild("WipButton") 
	local blatantButton = parentRoot:FindFirstChild("Blantant") 
	local hiddenButton = parentRoot:FindFirstChild("Hidden")   
	
	-- Core UI Labels
	local originalBlatantText = blatantButton and blatantButton.Text or "Blatant"
	local originalHiddenText = hiddenButton and hiddenButton.Text or "Hidden"
	
	-- Tuning Config
	local attackDelay = 0.17
	local SPEED_THRESHOLD = 5 
	local FORWARD_OFFSET = 5    
	local UNDERGROUND_DEPTH = 7 
	local BLATANT_PREDICTION_FACTOR = 1.5
	
	-- System States
	local attacking = false
	local wipEnabled = false 
	local currentMode = nil  -- Persistent mode state: "Blatant", "Hidden", or nil
	local currentTarget = nil
	local currentClass = nil
	local moveConnection = nil
	local animConnection = nil 
	local originalCFrame = nil 
	
	-- Combat Stats
	local leaderstats = player:WaitForChild("leaderstats", 5)
	local classValue = leaderstats and leaderstats:WaitForChild("Class", 5)
	
	local function updateCurrentClass()
		if classValue then
			currentClass = classValue.Value
		end
	end
	
	local ignoreIDs = { [10712947750] = true }
	
	-- HIGHLIGHT FILTER CHECKER
	local function hasHighlight(plr)
		if not plr or not plr.Character then
			return false
		end
		-- Using GetChildren is faster and lightweight for performance
		for _, obj in ipairs(plr.Character:GetChildren()) do
			if obj:IsA("Highlight") then
				return true
			end
		end
		return false
	end
	
	-- CAMERA HANDLERS
	local function resetCamera()
		camera.CameraSubject = player.Character:FindFirstChildOfClass("Humanoid") or player.Character
		camera.CameraType = Enum.CameraType.Custom
	end
	
	local function viewTarget(target)
		if target and target.Character then
			local tHum = target.Character:FindFirstChildOfClass("Humanoid")
			if tHum then camera.CameraSubject = tHum end
		else
			resetCamera()
		end
	end
	
	-- CHARACTER WORKSPACE ENFORCER
	local function handleCharacterParenting(char)
		if not char then return end
		task.wait()
		local liveFolder = Workspace:FindFirstChild("Live")
		if liveFolder and char:IsDescendantOf(liveFolder) then char.Parent = Workspace end
		if char.Parent ~= Workspace then char.Parent = Workspace end
	end
	
	Workspace.DescendantAdded:Connect(function(desc)
		if desc == character then handleCharacterParenting(character) end
	end)
	handleCharacterParenting(character)
	
	-- TARGETING ENGINE
	local function getTargetsFromText(text)
		if not text or text == "" then return {} end
		local targets = {}
		local used = {}
		for name in string.gmatch(text, "([^,]+)") do
			name = name:lower():gsub("^%s+", ""):gsub("%s+$", "")
			for _, plr in ipairs(Players:GetPlayers()) do
				if plr ~= player and not ignoreIDs[plr.UserId] and not used[plr.UserId] then
					if string.find(plr.Name:lower(), name, 1, true) or string.find(plr.DisplayName:lower(), name, 1, true) then
						targets[#targets + 1] = plr
						used[plr.UserId] = true
					end
				end
			end
		end
		return targets
	end
	
	local function getClosest()
		-- If our current target leaves, dies, or receives a highlight, drop them immediately
		if currentTarget and (not currentTarget.Parent or not currentTarget.Character or hasHighlight(currentTarget)) then
			currentTarget = nil
		end
		if currentTarget and currentTarget.Character then
			local hum = currentTarget.Character:FindFirstChildOfClass("Humanoid")
			if hum and hum.Health > 0 then return currentTarget end
		end
	
		local targets = getTargetsFromText(textBox and textBox.Text or "")
		currentTarget = nil
	
		-- Loop through multiple players provided in textbox; bypasses highlighted players
		for _, plr in ipairs(targets) do
			if plr.Character and not hasHighlight(plr) then
				local hum = plr.Character:FindFirstChildOfClass("Humanoid")
				if hum and hum.Health > 0 then
					currentTarget = plr
					break -- Locks onto the first matching target without a highlight
				end
			end
		end
		return currentTarget
	end
	
	local function getRemote()
		local core = character and character:FindFirstChild("Core")
		local comm = core and core:FindFirstChild("Communicate")
		if not comm then return nil end
		for _, v in pairs(comm:GetChildren()) do
			if v:IsA("RemoteEvent") then return v end
		end
	end
	
	-- ATTACK LOGIC (Targets Torso exclusively)
	local function attack(target)
		updateCurrentClass()
		local remote = getRemote()
		if not remote or not target or not target.Character then return end
	
		local tChar = target.Character
		local torsoPart = tChar:FindFirstChild("UpperTorso") or tChar:FindFirstChild("Torso")
		if not torsoPart then return end
	
		local hitPart = tChar:FindFirstChild("Head") or torsoPart
		local args = {
			"Heavy",
			{
				Point = torsoPart.Position,
				Combo = math.random(1, 5),
				Class = currentClass,
				IsKnockdown = false,
				Character = tChar,
				Hit = hitPart,
				Limb = "LeftHand",
				Result = nil
			},
			false
		}
		remote:FireServer(unpack(args))
		remote:FireServer("Swing", { Limb = "LeftHand" })
	end
	
	-- SLAM ATTACK LOGIC
	local function slamTarget(target)
		updateCurrentClass()
		local remote = getRemote()
		-- STRICT MODE ENFORCEMENT: Added explicit check for "Blatant" mode
		if not remote or not target or not target.Character or currentMode ~= "Blatant" then return end
	
		local tChar = target.Character
		local torsoPart = tChar:FindFirstChild("UpperTorso") or tChar:FindFirstChild("Torso")
		if not torsoPart then return end
	
		local hitPart = tChar:FindFirstChild("LeftUpperArm") or torsoPart
	
		remote:FireServer("Grab")
		task.wait(0.02)
		if not attacking or currentMode ~= "Blatant" then return end
	
		local args = {
			"Slam",
			{
				Character = tChar,
				Point = torsoPart.Position,
				Hit = hitPart,
				Limb = "",
				Class = currentClass, -- Fixed minor typo ('Classs' -> 'Class')
				Result = nil
			}
		}
		remote:FireServer(unpack(args))
	end
	
	-- TELEPORT RESET MECHANIC
	local function returnToOriginalPosition()
		resetCamera() 
		local myHRP = character and character:FindFirstChild("HumanoidRootPart")
		if myHRP and originalCFrame then
			myHRP.CFrame = originalCFrame
			myHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
			myHRP.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
			if humanoid then humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end
		end
		originalCFrame = nil 
	end
	
	local function startMovementLoop()
		if moveConnection then return end
	
		moveConnection = RunService.Heartbeat:Connect(function()
			if not wipEnabled or not attacking or not currentMode then return end
	
			local myHRP = character and character:FindFirstChild("HumanoidRootPart")
			local target = getClosest() 
	
			if myHRP and target and target.Character then
				local tChar = target.Character
				local tTorso = tChar and (tChar:FindFirstChild("UpperTorso") or tChar:FindFirstChild("Torso"))
	
				if tTorso then
					if not originalCFrame then
						originalCFrame = myHRP.CFrame
					end
	
					local rawVelocity = tTorso.AssemblyLinearVelocity
					local targetSpeed = rawVelocity.Magnitude
					local targetVelocity = rawVelocity
	
					if targetSpeed > 120 then
						targetVelocity = Vector3.new(0, 0, 0)
						targetSpeed = 0
					end
	
					local calculatedCFrame = myHRP.CFrame
	
					if currentMode == "Blatant" then
						local prediction = tTorso.Position + (targetVelocity * attackDelay * BLATANT_PREDICTION_FACTOR)
						calculatedCFrame = CFrame.new(prediction + Vector3.new(0, 0, -2))
	
					elseif currentMode == "Hidden" then
						local basePosition = tTorso.Position
						if targetSpeed > SPEED_THRESHOLD then
							basePosition = basePosition + (targetVelocity.Unit * FORWARD_OFFSET)
						end
	
						local enforcedUndergroundY = tTorso.Position.Y - UNDERGROUND_DEPTH
						local finalUnderPos = Vector3.new(basePosition.X, enforcedUndergroundY, basePosition.Z)
						calculatedCFrame = CFrame.new(finalUnderPos) * CFrame.Angles(math.rad(90), 0, 0)
					end
	
					myHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
					myHRP.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
					myHRP.CFrame = calculatedCFrame
					viewTarget(target)
				else
					if originalCFrame then returnToOriginalPosition() end
				end
			else
				if originalCFrame then 
					returnToOriginalPosition() 
				end
			end
		end)
	end
	
	local function stopMovementLoop()
		if moveConnection then
			moveConnection:Disconnect()
			moveConnection = nil
		end
	end
	
	-- ANIMATION OVERRIDES
	local function stopAllAnimations()
		local animator = humanoid and humanoid:FindFirstChildOfClass("Animator")
		if animator then
			for _, track in ipairs(animator:GetPlayingAnimationTracks()) do track:Stop(0) end
		end
	end
	
	local function startAnimationSuppressor()
