	local wipButton = parentRoot:FindFirstChild("WipButton")
	
	local ignoreKnockedLabel = parentRoot:FindFirstChild("Ignoreknocked") 
	local ignoreKnockedButton = ignoreKnockedLabel and ignoreKnockedLabel:FindFirstChild("Ignoreknocked")
	
	-- Track connections per player to clean them up properly and prevent leaks
	local playerConnections = {}
	
	local MIN_SIZE = 2
	local MAX_SIZE = 7
	local currentSize = MIN_SIZE
	local dragging = false
	local hitboxActive = false 
	local ignoreKnockedActive = false 
	
	-- Purely updates a character's properties based on current states
	local function applyHitboxToCharacter(character)
		if not character then return end
		local rootPart = character:FindFirstChild("HumanoidRootPart")
		local humanoid = character:FindFirstChild("Humanoid")
		if not rootPart or not humanoid or humanoid.Health <= 0 then return end
	
		-- CRITICAL FIX: If the main hitbox toggle is off, force default states and exit immediately
		if not hitboxActive then
			rootPart.Size = Vector3.new(2, 2, 1)
			rootPart.CanCollide = true -- Ensure the HRP retains collision defaults
			return
		end
	
		-- If active, evaluate the knocked exception state
		if ignoreKnockedActive and character:FindFirstChild("Knocked") then
			rootPart.Size = Vector3.new(2, 2, 1)
			rootPart.CanCollide = true
		else
			rootPart.Size = Vector3.new(currentSize, currentSize, currentSize)
			rootPart.CanCollide = false -- Turn off collision ONLY on the HumanoidRootPart so it doesn't block you
		end
	end
	
	local function updateAllHitboxes()
		for _, player in pairs(Players:GetPlayers()) do
			if player ~= LocalPlayer and player.Character then
				applyHitboxToCharacter(player.Character)
			end
		end
	end
	
	-- Replaces the heavy RenderStepped loop by listening directly to character state changes
	local function watchCharacterState(character)
		applyHitboxToCharacter(character)
	
		-- Listen for the "Knocked" instance being added or removed dynamically
		local childAdded = character.ChildAdded:Connect(function(child)
			if child.Name == "Knocked" then
				applyHitboxToCharacter(character)
			end
		end)
	
		local childRemoved = character.ChildRemoved:Connect(function(child)
			if child.Name == "Knocked" then
				applyHitboxToCharacter(character)
			end
		end)
	
		local humanoid = character:WaitForChild("Humanoid", 5)
		local died
		if humanoid then
			died = humanoid.Died:Connect(function()
				local rootPart = character:FindFirstChild("HumanoidRootPart")
				if rootPart then
					rootPart.Size = Vector3.new(2, 2, 1) 
					rootPart.CanCollide = true
				end
			end)
		end
	
		return {childAdded, childRemoved, died}
	end
	
	-- Handle Slider UI Physics
	local function updateSlider(pos, blockHitboxUpdate)
		currentSize = MIN_SIZE + pos * (MAX_SIZE - MIN_SIZE)
		amountValue.Text = string.format("%.2f", currentSize)
		slideFrame:TweenSize(UDim2.new(pos, 0, 1, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.1, true)
	
		-- Explicitly check if updates are blocked during initialization
		if hitboxActive and not blockHitboxUpdate then 
			updateAllHitboxes() 
		end
	end
	
	local function updateSliderFromInput(input)
		if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end
		local pos = math.clamp((input.Position.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
		updateSlider(pos, false)
	end
	
	slider.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			updateSliderFromInput(input)
		end
	end)
	
	slider.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if dragging then updateSliderFromInput(input) end
	end)
	
	-- Main Activation Button Toggle
	if wipButton then
		wipButton.MouseButton1Down:Connect(function()
			hitboxActive = not hitboxActive
			wipButton.BackgroundColor3 = hitboxActive and Color3.fromRGB(51, 255, 47) or Color3.fromRGB(255, 11, 0)
			updateAllHitboxes()
		end)
	end
	
	-- Ignore Knocked Button Toggle
	if ignoreKnockedButton then
		ignoreKnockedButton.MouseButton1Down:Connect(function()
			ignoreKnockedActive = not ignoreKnockedActive
			ignoreKnockedButton.BackgroundColor3 = ignoreKnockedActive and Color3.fromRGB(51, 255, 47) or Color3.fromRGB(255, 11, 0)
			updateAllHitboxes()
		end)
	end
	
	-- Player Setup Events
	local function setupPlayer(player)
		playerConnections[player] = {}
	
		local function onCharAdded(char)
			-- Disconnect old character listeners if they exist to prevent memory leaks
			for _, conn in pairs(playerConnections[player]) do conn:Disconnect() end
			playerConnections[player] = watchCharacterState(char)
		end
	
		player.CharacterAdded:Connect(onCharAdded)
		if player.Character then onCharAdded(player.Character) end
	end
	
	Players.PlayerAdded:Connect(setupPlayer)
	Players.PlayerRemoving:Connect(function(player)
		if playerConnections[player] then
			for _, conn in pairs(playerConnections[player]) do conn:Disconnect() end
			playerConnections[player] = nil
		end
	end)
	
	for _, player in pairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then setupPlayer(player) end
	end
	
	-- Initialize slider visually to default size WITHOUT changing player hitboxes
	-- Passing 'true' completely prevents execution from touching players during loading
	updateSlider((currentSize - MIN_SIZE) / (MAX_SIZE - MIN_SIZE), true)
end
