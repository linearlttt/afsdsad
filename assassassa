	-- UI ELEMENTS
	-- ==========================================
	local slider = script.Parent
	local slideFrame = slider:WaitForChild("slideFrame") :: Frame
	local amountValue = slider:WaitForChild("amountValue") :: TextLabel
	local parentRoot = slider.Parent.Parent
	local wipButton = parentRoot:FindFirstChild("WipButton") :: TextButton
	
