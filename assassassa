	local UIS = game:GetService("UserInputService")
	local TweenService = game:GetService("TweenService")
	
	-- ==========================================
	-- CONFIGURATION & STATE
	-- ==========================================
	type Settings = {
		WeaveEnabled: boolean,
		MaxDistance: number,
		DelayDuration: number
	}
	
	local Config: Settings = {
		WeaveEnabled = false,
		MaxDistance = 30,
		DelayDuration = 0.2 -- Default delay
	}
	
	local MIN_VALUE, MAX_VALUE = 0, 1 -- Slider min/max range in seconds
	local dragging = false
	local wipEnabled = false 
