							subPart.CanCollide = false 
							subPart.Velocity = Vector3.zero
							subPart.RotVelocity = Vector3.zero
						end
					end
				end
			end
	
			local predictedPos = predictPosition(tTorso)
			local underPos = predictedPos + Vector3.new(0, -6.6, 0)
	
			myHRP.CFrame = CFrame.new(underPos, predictedPos) * CFrame.Angles(math.rad(180), 0, 0)
	
			myHRP.Velocity = Vector3.zero
			myHRP.RotVelocity = Vector3.zero
		end)
	end
	
	-- INSTANT TELEPORT BACK
	local function resetPosition()
