			local isIdle = animName:lower():match("Idle")
			local isM1 = animName:match("M1's")
	
			-- Safety: Don't override if it's already an OMNI folder animation asset playing
			local omniFolder = getOmniFolder()
			if omniFolder and animationTrack.Animation:IsDescendantOf(omniFolder) then return end
	
			if isM1 or isIdle then
				local omniAnimObject = getOmniReplacement(animName, isIdle)
	
				if omniAnimObject then
					-- Stop your current style's animation instantly
					animationTrack:Stop()
	
					-- Load and play the OMNI version instead
					local overrideTrack = animator:LoadAnimation(omniAnimObject)
					overrideTrack.Priority = Enum.AnimationPriority.Action4
	
					if isIdle then
						overrideTrack.Looped = true
					end
	
					overrideTrack:Play()
				end
			end
		end)
	end
	
	-- --- Main Toggle Button Logic ---
	
	click.MouseButton1Click:Connect(function()
		Toggle = not Toggle
	
		if Toggle then
			click.BackgroundColor3 = Color3.fromRGB(51, 255, 47)
			startOverride()
	
			LocalPlayer.CharacterAdded:Connect(function()
				if Toggle then
					task.wait(1)
					startOverride()
				end
			end)
		else
			click.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
			if animationTrackConnection then
				animationTrackConnection:Disconnect()
				animationTrackConnection = nil
			end
		end
	end)
end
