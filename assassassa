	-- =========================
	-- SLIDER (HEALTH THRESHOLD 1-50)
	-- =========================
	local function updateSlider(pos)
		slideFrame:TweenSize(
			UDim2.new(pos, 0, 1, 0),
			Enum.EasingDirection.Out,
			Enum.EasingStyle.Quad,
			0.1,
			true
		)
	
		local healthThreshold = math.floor(MIN_HEALTH + pos * (MAX_HEALTH - MIN_HEALTH))
		amountValue.Text = tostring(healthThreshold)
		attackHealthThreshold = healthThreshold
	end
	
	slider.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			local pos = math.clamp((mouse.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
			updateSlider(pos)
		end
	end)
	
	slider.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local pos = math.clamp((mouse.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
			updateSlider(pos)
		end
	end)
	
	-- =========================
	-- WIP BUTTON
	-- =========================
	if wipButton then
		wipButton.MouseButton1Down:Connect(function()
			wipEnabled = not wipEnabled
			if wipEnabled then
				wipButton.BackgroundColor3 = Color3.fromRGB(51, 255, 47)
				startLoop()
			else
				wipButton.BackgroundColor3 = Color3.fromRGB(255, 11, 0)
				stopLoop()
			end
		end)
	end
end
coroutine.wrap(WSEVG_fake_script)()
