local function ITWA_fake_script() -- OutlastHubNormalPremium_2.OMNI.LocalScript 
	local script = Instance.new('LocalScript', OutlastHubNormalPremium_2.OMNI)

	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	local LocalPlayer = Players.LocalPlayer
	local click = script.Parent:FindFirstChild("WipButton")
	
	local Toggle = false
	local animationTrackConnection = nil
	
	-- --- Helper Functions ---
	
	-- Gets the main OMNI folder directly from Core.Animations.Styles
	local function getOmniFolder()
		local char = LocalPlayer.Character
		local core = char and char:FindFirstChild("Core")
		local animations = core and core:FindFirstChild("Animations")
		local styles = animations and animations:FindFirstChild("Styles")
	
		return styles and styles:FindFirstChild("OMNI")
	end
	
	-- Checks if you are holding a tool called "Fight"
	local function isFightToolEquipped()
		local char = LocalPlayer.Character
		if char then
			local tool = char:FindFirstChild("Fight")
			if tool and tool:IsA("Tool") then
				return true
			end
		end
		return false
	end
	
	-- Finds the matching replacement animation object inside the OMNI folder
	local function getOmniReplacement(animName, isIdle)
		local omniFolder = getOmniFolder()
		if not omniFolder then return nil end
	
		if isIdle then
			-- Grabs "Idle" directly inside the OMNI folder
			return omniFolder:FindFirstChild(animName) or omniFolder:FindFirstChild("Idle")
		else
			-- Looks inside the M1s folder for the matching attack name
			local m1sFolder = omniFolder:FindFirstChild("M1s")
			if m1sFolder then
				return m1sFolder:FindFirstChild(animName)
			else
				return omniFolder:FindFirstChild(animName, true)
			end
		end
	end
	
	-- --- The Override Core Logic ---
	
	local function startOverride()
		local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
		local humanoid = char:WaitForChild("Humanoid")
		local animator = humanoid:WaitForChild("Animator")
	
		if animationTrackConnection then animationTrackConnection:Disconnect() end
	
		-- Listen for any animation playing on your character
		animationTrackConnection = animator.AnimationPlayed:Connect(function(animationTrack)
			-- Only override if toggle is ON and the Fight tool is physically out
			if not Toggle or not isFightToolEquipped() then return end
	
			local animName = animationTrack.Animation.Name
			local isIdle = animName:lower():match("Idle")
			local isM1 = animName:match("M1's")
	
			-- Safety: Don't override if it's already an OMNI folder animation asset playing
			local omniFolder = getOmniFolder()
			if omniFolder and animationTrack.Animation:IsDescendantOf(omniFolder) then return end
	
			if isM1 or isIdle then
				local omniAnimObject = getOmniReplacement(animName, isIdle)
	
				if omniAnimObject then
					-- Stop your current style's animation instantly
					animationTrack:Stop()
	
					-- Load and play the OMNI version instead
					local overrideTrack = animator:LoadAnimation(omniAnimObject)
					overrideTrack.Priority = Enum.AnimationPriority.Action4
	
					if isIdle then
						overrideTrack.Looped = true
					end
	
					overrideTrack:Play()
				end
			end
		end)
	end
	
	-- --- Main Toggle Button Logic ---
	
	click.MouseButton1Click:Connect(function()
		Toggle = not Toggle
	
		if Toggle then
			click.BackgroundColor3 = Color3.fromRGB(51, 255, 47)
			startOverride()
	
			LocalPlayer.CharacterAdded:Connect(function()
				if Toggle then
					task.wait(1)
					startOverride()
				end
			end)
		else
			click.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
			if animationTrackConnection then
				animationTrackConnection:Disconnect()
				animationTrackConnection = nil
			end
		end
	end)
end
