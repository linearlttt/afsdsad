	local function startThrowingLoop()
		if throwConnection then throwConnection:Disconnect() end
	
		throwConnection = RunService.Heartbeat:Connect(function()
			if not wipEnabled then 
				stopThrowing() 
				return 
			end
	
			local currentTime = os.clock()
			if currentTime - lastThrowTime < THROW_RATE then return end 
	
			local sourcePlayersList = getActiveSourcePlayers()
			if #sourcePlayersList == 0 then return end
	
			local performedAttack = false
	
			-- Process every target entered in the list sequentially
			for _, sourcePlr in ipairs(sourcePlayersList) do
