		blatantButton.MouseButton1Down:Connect(function() handleToggle("Blatant") end)
	end
	
	if hiddenButton and hiddenButton:IsA("GuiButton") then
		hiddenButton.MouseButton1Down:Connect(function() handleToggle("Hidden") end)
	end
	
