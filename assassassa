		while true do
			task.wait()
	
			if not _G.WeaveEnabled then
				last = os.clock()
				_G._t = 0
				continue
			end
	
			local now = os.clock()
			local dt = now - last
			last = now
	
			_G._t += dt
	
			local interval = math.max(0, _G.WeaveInterval + _G.MicroInterval)
	
			if _G._t >= interval then
				_G._t -= interval
	
				local remote = getRemote()
				if remote then
					pcall(function()
