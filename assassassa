		local targetChar = targetPart.Parent
		local velocity = targetPart.Velocity
	
		local horizontalVelocity = Vector3.new(velocity.X, 0, velocity.Z)
		local finalPosition = targetPart.Position
	
		if horizontalVelocity.Magnitude > 0.5 then
			local moveDirection = horizontalVelocity.Unit
			finalPosition = targetPart.Position + (moveDirection * 5)
		elseif targetChar:FindFirstChild("SkateBoard") then
			local board = targetChar:FindFirstChild("SkateBoard")
			if board:IsA("BasePart") and board.Velocity.Magnitude > 0.5 then
				finalPosition = targetPart.Position + (board.Velocity.Unit * 7)
			else
