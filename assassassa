local function ZWTML_fake_script() -- TextLabel_27.mainScript 
	local script = Instance.new('LocalScript', TextLabel_27)

	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	local TweenService = game:GetService("TweenService")
	
	local player = Players.LocalPlayer
	local button = script.Parent:WaitForChild("WipButton")
	
	local onColor = Color3.fromRGB(51, 255, 47)
	local offColor = Color3.fromRGB(255, 0, 0)
	button.BackgroundColor3 = offColor
	
	local attackInterval = 0.176
	local PREDICTION_FACTOR = 0.2
	local hitPartsList = { "Head" }
	local attackHealthThreshold = 100
	local currentHand = "RightHand"
	
	local character = player.Character or player.CharacterAdded:Wait()
	local classValue = player:WaitForChild("leaderstats"):WaitForChild("Class")
	
	local function getCurrentClass()
		return classValue.Value
	end
	
	local originalPosition
	
	player.CharacterAdded:Connect(function(char)
		character = char
	end)
	
	-- STOP ALL ANIMATIONS (NEW)
	local function stopAllAnimations(char)
		if not char then return end
	
		local hum = char:FindFirstChildOfClass("Humanoid")
		if not hum then return end
	
		local animator = hum:FindFirstChildOfClass("Animator") or hum:WaitForChild("Animator", 0.1)
		if not animator then return end
	
		for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
			track:Stop(0)
		end
	end
	
	local function getRemote()
		if not character then return end
		local core = character:WaitForChild("Core")
		local comm = core:WaitForChild("Communicate")
	
		for _, v in pairs(comm:GetChildren()) do
			if v:IsA("RemoteEvent") then
				return v
			end
		end
	end
	
	local function predictPosition(hrp)
		local character = hrp.Parent
		local humanoid = character:FindFirstChildOfClass("Humanoid")
	
		local horizontalVelocity = Vector3.new(hrp.Velocity.X, 0, hrp.Velocity.Z)
	
		local moveDir = Vector3.zero
	
		if horizontalVelocity.Magnitude > 2 then
			local speedMultiplier = 4
			if humanoid then
				speedMultiplier = humanoid.WalkSpeed * 0.25
			end
			moveDir = horizontalVelocity.Unit * speedMultiplier
		end
	
		local yPrediction = math.clamp(
			hrp.Velocity.Y * attackInterval * PREDICTION_FACTOR,
			-6,
			6
		)
	
		local predicted = Vector3.new(
			hrp.Position.X + moveDir.X,
			hrp.Position.Y + yPrediction,
			hrp.Position.Z + moveDir.Z
		)
	
		local hasSkateboard = character:FindFirstChild("SkateBoard")
		if hasSkateboard then
			predicted += hrp.CFrame.LookVector * 4
		end
	
		return predicted
	end
	
	local hc = Color3.fromRGB(143, 255, 137)
	
	-- VELOCITY THRESHOLDS
	local minVelocity = -1000
	local maxVelocity = 1000
	
	local function colorsAreClose(c1, c2, tolerance)
		tolerance = tolerance or 0.01
		return math.abs(c1.R - c2.R) <= tolerance
			and math.abs(c1.G - c2.G) <= tolerance
			and math.abs(c1.B - c2.B) <= tolerance
	end
	
	local function hasHighlight(plr)
		if not plr.Character then return false end
	
		local function findHighlight(parent)
			for _, child in pairs(parent:GetChildren()) do
				if child:IsA("Highlight") then
					if colorsAreClose(child.OutlineColor, hc) then
						return true
					end
				elseif child:IsA("Model") or child:IsA("Folder") then
					if findHighlight(child) then
						return true
					end
				end
			end
			return false
		end
	
		return findHighlight(plr.Character)
	end
	
	local friendIds = {}
	task.spawn(function()
		local success, friends = pcall(function()
			return player:GetFriendsAsync()
		end)
		if success then
			for _, info in pairs(friends:GetCurrentPage()) do
				friendIds[info.Id] = true
			end
		end
	end)
	
	local function isFriend(plr)
		return friendIds[plr.UserId] == true
	end
	
	local eligiblePlayers = {}
	
	local function updateEligiblePlayer(plr)
		if plr == player or isFriend(plr) then
			eligiblePlayers[plr] = nil
			return
		end
	
		if plr.Character then
			local humanoid = plr.Character:FindFirstChildOfClass("Humanoid")
			local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
	
			if humanoid and humanoid.Health > 0 and humanoid.Health <= attackHealthThreshold and hrp then
				if hasHighlight(plr) then
					eligiblePlayers[plr] = nil
					return
				end
	
				-- UPDATED VELOCITY CHECKER
				local v = hrp.Velocity
				if (v.X > maxVelocity or v.X < minVelocity) or
					(v.Y > maxVelocity or v.Y < minVelocity) or
					(v.Z > maxVelocity or v.Z < minVelocity) then
					eligiblePlayers[plr] = nil
					return
				end
	
				eligiblePlayers[plr] = true
			else
				eligiblePlayers[plr] = nil
			end
		end
	end
	
	Players.PlayerAdded:Connect(function(plr)
		plr.CharacterAdded:Connect(function()
			task.wait()
			updateEligiblePlayer(plr)
		end)
	end)
	
	for _, plr in pairs(Players:GetPlayers()) do
		if plr ~= player then
			if plr.Character then
				updateEligiblePlayer(plr)
			end
			plr.CharacterAdded:Connect(function()
				task.wait()
				updateEligiblePlayer(plr)
			end)
		end
	end
	
	local function getRandomTarget()
		local candidates = {}
		for plr in pairs(eligiblePlayers) do
			if plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
				and plr.Character:FindFirstChild("HumanoidRootPart")
				and not isFriend(plr) then
				table.insert(candidates, plr)
			end
		end
	
		if #candidates > 0 then
			return candidates[math.random(1, #candidates)]
		end
		return nil
	end
	
	local function performAttack(target)
		if not target or not target.Character or not character then return end
	
		local tChar = target.Character
		local hrp = tChar:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
	
		local remote = getRemote()
		if not remote then return end
	
		local myClass = getCurrentClass()
		local offHand = (currentHand == "RightHand") and "LeftHand" or "RightHand"
		local hitPart = tChar:FindFirstChild(hitPartsList[1]) or hrp
	
		local args = {
			"Heavy",
			{
				Point = predictPosition(hrp),
				Combo = math.random(1, 5),
				Class = myClass,
				IsKnockdown = false,
				Character = tChar,
				Hit = hitPart,
				Limb = currentHand,
				Result = nil
			},
			false
		}
	
		remote:FireServer(unpack(args))
		remote:FireServer("Swing", { Limb = offHand })
	
		currentHand = offHand
	end
	
	local teleportConnection
	
	local function startTeleportLoop(target)
		if teleportConnection then
			teleportConnection:Disconnect()
		end
	
		teleportConnection = RunService.Heartbeat:Connect(function()
			if character then
				stopAllAnimations(character)
			end
	
			if not target or not target.Character or not character then return end
	
			local myHRP = character:FindFirstChild("HumanoidRootPart")
			local tHRP = target.Character:FindFirstChild("HumanoidRootPart")
			if not myHRP or not tHRP then return end
	
			for _, part in ipairs(character:GetDescendants()) do
				if part:IsA("BasePart") then
					part.CanCollide = false
				end
			end
	
			local predictedPos = predictPosition(tHRP)
			local underPos = predictedPos + Vector3.new(0, -6.4, 0)
	
			myHRP.CFrame = CFrame.new(underPos, predictedPos) * CFrame.Angles(math.rad(180), 0, 0)
		end)
	end
	
	local function stopTeleportLoop()
		if teleportConnection then
			teleportConnection:Disconnect()
			teleportConnection = nil
		end
	end
	
	local function resetPosition()
		if character and character:FindFirstChild("HumanoidRootPart") and originalPosition then
			local hrp = character.HumanoidRootPart
			hrp.Velocity = Vector3.zero
			hrp.RotVelocity = Vector3.zero
	
			local tween = TweenService:Create(
				hrp,
				TweenInfo.new(5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
				{ CFrame = CFrame.new(originalPosition) }
			)
	
			tween:Play()
		end
	end
	
	local Toggle = false
	local loopRunning = false
	
	button.MouseButton1Click:Connect(function()
		Toggle = not Toggle
		button.BackgroundColor3 = Toggle and onColor or offColor
	
		if Toggle and not loopRunning then
			loopRunning = true
	
			if character and character:FindFirstChild("HumanoidRootPart") then
				originalPosition = character.HumanoidRootPart.Position
				stopAllAnimations(character) -- stop immediately on start
			end
	
			task.spawn(function()
				local currentTarget = nil
				local lastAttackTime = 0
	
				while Toggle do
					for _, plr in pairs(Players:GetPlayers()) do
						updateEligiblePlayer(plr)
					end
	
					if not currentTarget
						or not currentTarget.Character
						or not currentTarget.Character:FindFirstChildOfClass("Humanoid")
						or currentTarget.Character:FindFirstChildOfClass("Humanoid").Health <= 0
						or hasHighlight(currentTarget)
						or isFriend(currentTarget)
					then
						currentTarget = getRandomTarget()
					end
	
					if currentTarget and currentTarget.Character then
						local hum = currentTarget.Character:FindFirstChildOfClass("Humanoid")
						if hum and hum.Health > 0 then
							startTeleportLoop(currentTarget)
	
							local now = tick()
							if now - lastAttackTime >= attackInterval then
								performAttack(currentTarget)
								lastAttackTime = now
							end
						end
					end
	
					task.wait()
				end
	
				stopTeleportLoop()
				resetPosition()
				loopRunning = false
			end)
		else
			Toggle = false
			stopTeleportLoop()
			resetPosition()
		end
	end)
end
