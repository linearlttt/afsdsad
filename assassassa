	local offColor = Color3.fromRGB(255, 0, 0)
	button.BackgroundColor3 = offColor
	
	-- CONFIGURATION
	local MAX_DISTANCE = 8
	local PREDICTION_TIME = 0.054
	local VERTICAL_OFFSET = Vector3.new(0, 1.5, 0) -- Studs above the target's head
	
	local buttonEnabled = false 
	local toolConnection = nil  
	
	local function getClosestPlayer(myCharacter)
		local myRoot = myCharacter:FindFirstChild("HumanoidRootPart")
		if not myRoot then return nil end
	
		local closestPlayer = nil
		local shortestDistance = MAX_DISTANCE
	
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= player then
				local targetChar = p.Character
				local targetRoot = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
				local targetHum = targetChar and targetChar:FindFirstChildOfClass("Humanoid")
	
				if targetRoot and targetHum and targetHum.Health > 0 then
					local distance = (myRoot.Position - targetRoot.Position).Magnitude
	
					if distance < shortestDistance then
						shortestDistance = distance
						closestPlayer = p
					end
				end
			end
		end
	
		return closestPlayer
	end
	
	local function snapToTarget()
		if not buttonEnabled then return end
	
		local character = player.Character
		if not character then return end
	
		local knockedState = character:FindFirstChild("Knocked")
		if knockedState and knockedState.Value then return end
	
		local hasTool = character:FindFirstChild("Fight")
		if not hasTool then return end
	
		local myRoot = character:FindFirstChild("HumanoidRootPart")
		if not myRoot then return end
	
		local targetPlayer = getClosestPlayer(character)
		if not targetPlayer or not targetPlayer.Character then return end
	
		local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
		local targetHead = targetPlayer.Character:FindFirstChild("Head")
		local targetHum = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
	
		if not targetRoot or not targetHum or targetHum.Health <= 0 then return end
	
		-- Fallback to root position if the head piece isn't loaded
		local baseTargetPosition = targetHead and targetHead.Position or (targetRoot.Position + Vector3.new(0, 2, 0))
	
		-- Calculate predicted position based on velocity at the exact moment of the click
		local predictedPosition = baseTargetPosition + VERTICAL_OFFSET + (targetRoot.AssemblyLinearVelocity * PREDICTION_TIME)
	
		local lookDirection = (predictedPosition - camera.CFrame.Position).Unit
	
		-- Hard override camera rotation instantly once
		camera.CFrame = CFrame.lookAt(camera.CFrame.Position, camera.CFrame.Position + lookDirection)
	end
	
	local function monitorCharacter(character)
		if not character then return end
	
		character.ChildAdded:Connect(function(child)
			if child:IsA("Tool") and child.Name == "Fight" then
				if toolConnection then toolConnection:Disconnect() end
				toolConnection = child.Activated:Connect(snapToTarget)
			end
		end)
	
		character.ChildRemoved:Connect(function(child)
			if child:IsA("Tool") and child.Name == "Fight" then
				if toolConnection then
					toolConnection:Disconnect()
					toolConnection = nil
				end
			end
		end)
	end
	
	player.CharacterAdded:Connect(monitorCharacter)
	if player.Character then
		monitorCharacter(player.Character)
	end
	
	button.MouseButton1Click:Connect(function()
		buttonEnabled = not buttonEnabled
	
		if buttonEnabled then
			button.BackgroundColor3 = onColor
		else
			button.BackgroundColor3 = offColor
		end
	end)
end
