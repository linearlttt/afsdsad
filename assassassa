local function KEAL_fake_script() -- bSliderFrame_4.mainScript 
	local script = Instance.new('LocalScript', bSliderFrame_4)

	local Players = game:GetService("Players")
	local UIS = game:GetService("UserInputService")
	local RunService = game:GetService("RunService")
	
	local player = Players.LocalPlayer
	local character = player.Character or player.CharacterAdded:Wait()
	local humanoid = character:WaitForChild("Humanoid")
	local mouse = player:GetMouse()
	
	-- SLIDER
	local slider = script.Parent
	local slideFrame = slider:WaitForChild("slideFrame")
	local amountValue = slider:WaitForChild("amountValue")
	local parentRoot = slider.Parent.Parent
	local wipButton = parentRoot:FindFirstChild("WipButton")
	
	local MIN_DELAY = 0.2
	local MAX_DELAY = 1
	local attackDelay = 0.33
	local MAX_DISTANCE = 10000
	
	local attacking = false
	local currentHand = "RightHand"
	local wipEnabled = false
	local currentTarget = nil
	local dragging = false
	
	local hitPartsList = { "Head" }
	
	local stylesFolder = character:WaitForChild("Core"):WaitForChild("Animations"):WaitForChild("Styles")
	local animationClassMap = {}
	
	-- Helper to normalize AnimationId to a number
	local function getIdNumber(animation)
		local id = animation.AnimationId:match("%d+")
		return id and tonumber(id)
	end
	
	local function scanStyles(folder, className)
		for _, child in pairs(folder:GetChildren()) do
			if child:IsA("Animation") then
				local id = getIdNumber(child)
				if id then
					animationClassMap[id] = className
				end
			elseif child:IsA("Folder") then
				scanStyles(child, className)
			end
		end
	end
	
	for _, classFolder in pairs(stylesFolder:GetChildren()) do
		if classFolder:IsA("Folder") then
			scanStyles(classFolder, classFolder.Name)
		end
	end
	
	local lastClass = nil
	
	local function updateClassFromAnimation()
		local animator = humanoid:FindFirstChildOfClass("Animator")
		if not animator then return end
	
		for _, track in pairs(animator:GetPlayingAnimationTracks()) do
			local id = getIdNumber(track.Animation)
			local className = id and animationClassMap[id]
			if className and lastClass ~= className then
				lastClass = className
				break
			end
		end
	end
	
	RunService.Heartbeat:Connect(updateClassFromAnimation)
	
	local function isFightEquipped()
		local char = player.Character
		if not char then return false end
		local tool = char:FindFirstChildOfClass("Tool")
		return tool and tool.Name == "Fight"
	end
	
	local function getRemote()
		local char = player.Character or player.CharacterAdded:Wait()
		local core = char:WaitForChild("Core")
		local comm = core:WaitForChild("Communicate")
	
		for _, v in pairs(comm:GetChildren()) do
			if v:IsA("RemoteEvent") then
				return v
			end
		end
	end
	
	local function getClosest()
		local char = player.Character
		if not char then return end
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
	
		if currentTarget and currentTarget.Character then
			local humanoid = currentTarget.Character:FindFirstChildOfClass("Humanoid")
			local targetHRP = currentTarget.Character:FindFirstChild("HumanoidRootPart")
			if humanoid and humanoid.Health > 0 and targetHRP then
				return currentTarget
			end
		end
	
		local closest, dist = nil, math.huge
		for _, plr in pairs(Players:GetPlayers()) do
			if plr ~= player and plr.Character then
				local targetHRP = plr.Character:FindFirstChild("HumanoidRootPart")
				local humanoid = plr.Character:FindFirstChildOfClass("Humanoid")
				if targetHRP and humanoid and humanoid.Health > 0 then
					local d = (hrp.Position - targetHRP.Position).Magnitude
					if d < dist and d <= MAX_DISTANCE then
						dist = d
						closest = plr
					end
				end
			end
		end
	
		currentTarget = closest
		return currentTarget
	end
	
	-- =========================
	-- PREDICTION
	-- =========================
	local PREDICTION_FACTOR = 0.5 -- lower factor to reduce overshoot
	
	local function predictPosition(hrp)
		if not hrp then return end
		return hrp.Position + (hrp.Velocity * attackDelay * PREDICTION_FACTOR)
	end
	
	local function stabilizeCharacter(hrp)
		if not hrp then return end
		hrp.Velocity = Vector3.new(0, 0, 0)
		hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
		hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
		if hrp.Position.Y > 10 then
			hrp.CFrame = CFrame.new(hrp.Position.X, 10, hrp.Position.Z)
		end
	end
	
	local function attack()
		local remote = getRemote()
		if not remote then return end
	
		local target = getClosest()
		if not target or not target.Character then return end
		local tChar = target.Character
		local hrp = tChar:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
	
		local myClass = lastClass or "Amateur" -- fallback if no animation found
		local offHand = (currentHand == "RightHand") and "LeftHand" or "RightHand"
	
		for _, partName in pairs(hitPartsList) do
			local hitPart = tChar:FindFirstChild(partName) or hrp
	
			local args = {
				"Attack",
				{
					Point = predictPosition(hrp),
					Combo = 5,
					Class = myClass,
					IsKnockdown = false,
					Character = tChar,
					Hit = hitPart,
					Limb = currentHand,
					Classs = "",
					Result = nil
				},
				false
			}
	
			remote:FireServer(unpack(args))
			remote:FireServer("Swing", { Limb = currentHand })
			remote:FireServer("Swing", { Limb = offHand })
			currentHand = offHand
		end
	end
	
	local moveConnection
	
	local function startMovementLoop()
		if moveConnection then return end -- Already connected
	
		moveConnection = RunService.Heartbeat:Connect(function()
			if not attacking then return end
	
			local char = player.Character
			local myHRP = char and char:FindFirstChild("HumanoidRootPart")
			local target = getClosest()
	
			if isFightEquipped() and target and target.Character and myHRP then
				local tHRP = target.Character:FindFirstChild("HumanoidRootPart")
				if tHRP then
					stabilizeCharacter(myHRP)
					local predicted = predictPosition(tHRP)
					if predicted then
						myHRP.CFrame = CFrame.new(predicted + Vector3.new(0, 0, 2))
					end
				end
			end
		end)
	end
	
	local function stopMovementLoop()
		if moveConnection then
			moveConnection:Disconnect()
			moveConnection = nil
		end
	end
	
	-- =========================
	-- MAIN LOOP
	-- =========================
	local function startLoop()
		if attacking then return end
		attacking = true
	
		startMovementLoop()
	
		task.spawn(function()
			while attacking do
				local target = getClosest()
				if target and target.Character then
					local humanoid = target.Character:FindFirstChildOfClass("Humanoid")
					game:GetService("StarterGui"):SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, true)
	
					if humanoid and humanoid.Health > 0 then
						attack()
					end
				end
				task.wait(attackDelay)
			end
		end)
	end
	
	local function stopLoop()
		attacking = false
		currentTarget = nil
		stopMovementLoop()
	end
	
	-- =========================
	-- SLIDER
	-- =========================
	local function updateSlider(pos)
		slideFrame:TweenSize(
			UDim2.new(pos, 0, 1, 0),
			Enum.EasingDirection.Out,
			Enum.EasingStyle.Quad,
			0.1,
			true
		)
	
		local delay = MIN_DELAY + (pos * (MAX_DELAY - MIN_DELAY))
		delay = math.floor(delay * 100) / 100
	
		amountValue.Text = tostring(delay)
		attackDelay = delay
	end
	
	slider.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			local pos = math.clamp((mouse.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
			updateSlider(pos)
		end
	end)
	
	slider.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local pos = math.clamp((mouse.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
			updateSlider(pos)
		end
	end)
	
	-- =========================
	-- WIP BUTTON
	-- =========================
	if wipButton then
		wipButton.MouseButton1Down:Connect(function()
			wipEnabled = not wipEnabled
	
			if wipEnabled then
				wipButton.BackgroundColor3 = Color3.fromRGB(51, 255, 47)
				startLoop()
			else
				wipButton.BackgroundColor3 = Color3.fromRGB(255, 11, 0)
				stopLoop()
			end
		end)
	end
end
