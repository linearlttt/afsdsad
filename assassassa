				return
			end
	
			local tChar = currentTarget.Character
			local tHum = tChar:FindFirstChildOfClass("Humanoid")
			local tTorso = tChar:FindFirstChild("UpperTorso") or tChar:FindFirstChild("Torso")
	
			if not tHum or tHum.Health <= 0 or not tTorso then
				shutDownEverything()
				return
			end
	
			if myHRP then
				if not originalCFrame then
					originalCFrame = myHRP.CFrame
				end
	
				local rawVelocity = tTorso.AssemblyLinearVelocity
				local targetSpeed = rawVelocity.Magnitude
				local targetVelocity = rawVelocity
	
				if targetSpeed > 120 then
					targetVelocity = Vector3.new(0, 0, 0)
					targetSpeed = 0
				end
	
				-- Hidden positioning calculations
				local basePosition = tTorso.Position
				if targetSpeed > SPEED_THRESHOLD then
					basePosition = basePosition + (targetVelocity.Unit * FORWARD_OFFSET)
				end
	
				local enforcedUndergroundY = tTorso.Position.Y - 7
				local finalUnderPos = Vector3.new(basePosition.X, enforcedUndergroundY, basePosition.Z)
				local calculatedCFrame = CFrame.new(finalUnderPos) * CFrame.Angles(math.rad(90), 0, 0)
	
				myHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
				myHRP.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
				myHRP.CFrame = calculatedCFrame
				viewTarget(currentTarget)
			end
		end)
	
		-- Attack Loop
		task.spawn(function()
			while wipEnabled and attacking and currentTarget do
				attack(currentTarget)
				task.wait(attackDelay)
			end
		end)
	end
	
