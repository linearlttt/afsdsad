		return false
	end
	
	-- Check if your own character is knocked down
	local function isSelfKnocked()
		local char = LocalPlayer.Character
		if not char then return false end
	
		local knockedValue = char:FindFirstChild("Knocked")
		if knockedValue then
			if knockedValue:IsA("ValueBase") then
				if knockedValue:IsA("IntValue") or knockedValue:IsA("NumberValue") then
					return (knockedValue.Value > 0)
				else
					return (knockedValue.Value == true)
				end
			else
				return true
			end
		end
		return false
	end
	
	-- Get remote event from your character's Core folder
	local function getRemote()
		local char = LocalPlayer.Character
		local core = char and char:FindFirstChild("Core")
		local comm = core and core:FindFirstChild("Communicate")
	
		if not comm then return nil end
		for _, v in pairs(comm:GetChildren()) do
			if v:IsA("RemoteEvent") then
				return v
			end
		end
		return nil
	end
	
	-- Play animation with custom conditional speeds based on style
	local function playClassAnimation(animName)
		local char = LocalPlayer.Character
		local humanoid = char and char:FindFirstChildOfClass("Humanoid")
		local animator = humanoid and humanoid:FindFirstChildOfClass("Animator")
		if not animator then return end
	
		local styleFolder = findClassStorage(currentClass)
		if not styleFolder then return end
	
		local m1sFolder = styleFolder:FindFirstChild("M1s")
		local animObject = nil
	
		if m1sFolder then
			animObject = m1sFolder:FindFirstChild(animName)
		else
			animObject = styleFolder:FindFirstChild(animName, true)
		end
	
		if animObject and animObject:IsA("Animation") then
			local track = animator:LoadAnimation(animObject)
			track.Priority = Enum.AnimationPriority.Action4 
	
			-- Dynamically scale speeds (Philly = 1.7, Others = 1.54)
			local dynamicSpeed = 1.54
			if currentClass == "Philly" then
				dynamicSpeed = 1.7
			end
	
			track:Play(0.1, 1, dynamicSpeed)
			track:AdjustSpeed(dynamicSpeed)
		end
	end
	
	-- Fire server remote (Now randomly hits Head or UpperTorso)
	local function fireAttackRemote(target, step)
		local remote = getRemote()
		if not remote or not target or not target.Character then return end
	
		local tChar = target.Character
		local torsoPart = tChar:FindFirstChild("UpperTorso") 
	
		local args = {
			"Attack",
			{
				Point = torsoPart.Position,
				Combo = step,
				Class = currentClass,
				IsKnockdown = false,
				Character = tChar,
				Hit = torsoPart,
				Limb = "LeftHand",
				Result = nil
			},
			false
		}
		remote:FireServer(unpack(args))
		remote:FireServer("Swing", { Limb = "LeftHand" })
	end
	
	-- Find closest player inside the workspace.Live folder
	local function getClosestPlayerWithinRange(range)
		local closestPlayer = nil
		local closestDistance = math.huge
		local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
		if not myHRP then return nil end
	
		for _, player in pairs(Players:GetPlayers()) do
			if player.Character and player ~= LocalPlayer then
				local char = player.Character
				local hrp = char:FindFirstChild("HumanoidRootPart")
				local humanoid = char:FindFirstChildOfClass("Humanoid")
				local knockedValue = char:FindFirstChild("Knocked")
				local isKnocked = false
	
				if knockedValue then
					if knockedValue:IsA("ValueBase") then
						if knockedValue:IsA("IntValue") or knockedValue:IsA("NumberValue") then
							isKnocked = (knockedValue.Value > 0)
						else
							isKnocked = (knockedValue.Value == true)
						end
					else
						isKnocked = true
					end
				end
	
				if hrp and humanoid and humanoid.Health > 0 and not isKnocked then
					local distance = (hrp.Position - myHRP.Position).magnitude
					if distance <= range and distance < closestDistance then
						closestPlayer = player
						closestDistance = distance
					end
				end
			end
		end
		return closestPlayer
	end
	
	-- Action executed on right-click, controller, or mobile button press
	local function performSingleClickStrike()
		if not Toggle then return end 
		if not isFightToolEquipped() then return end 
		if isSelfKnocked() then return end 
		if isAttackCooldown then return end 
	
		local now = os.clock()
		if now - lastClickTime > COMBO_RESET_TIME then
			comboStep = 1
		end
		lastClickTime = now
	
		updateCurrentClass()
	
		-- This reads whatever value ATTACK_RANGE currently holds
		local targetPlayer = getClosestPlayerWithinRange(ATTACK_RANGE)
		if not targetPlayer then return end
	
		isAttackCooldown = true
	
		local targetAnimName = tostring(comboStep)
		playClassAnimation(targetAnimName)
		fireAttackRemote(targetPlayer, comboStep)
	
		comboStep = comboStep + 1
		if comboStep > 4 then
			comboStep = 1
		end
	
		task.wait(CLICK_COOLDOWN)
		isAttackCooldown = false
	end
	
	-- Hook mobile button click to execute action
	MobileStrikeButton.MouseButton1Click:Connect(function()
		performSingleClickStrike()
	end)
	
	-- Toggle Button click connection
	clickButton.MouseButton1Click:Connect(function()
		Toggle = not Toggle
		if Toggle then
			clickButton.BackgroundColor3 = onColor
			updateCurrentClass()
		else
			clickButton.BackgroundColor3 = offColor
			comboStep = 1
		end
	end)
	
	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then
			return
		end
	
		if input.UserInputType == Enum.UserInputType.MouseButton2
			or (input.KeyCode == Enum.KeyCode.ButtonY) then
			performSingleClickStrike()
		end
	end)
	
	-- Reset handling
	LocalPlayer.CharacterAdded:Connect(function()
		comboStep = 1
		isAttackCooldown = false
		if Toggle then
			updateCurrentClass()
		end
	end)
	
	updateCurrentClass()
end
