		myHRP.CFrame = CFrame.new(BasePart.Position + targetPredictionOffset) * Pos * Ang
	
		local vel = Vector3.new(1,1,1) * -VELOCITY_CAP
		myHRP.AssemblyLinearVelocity = vel
		myHRP.AssemblyAngularVelocity = Vector3.new(10000, 10000, 10000)
	
		RunService.RenderStepped:Wait()
	end
	
	local function runVelocityLoop()
		task.spawn(function()
			local Angle = 0
	
			-- Save your original position BEFORE the fling loop starts
			local myHRP = character and character:FindFirstChild("HumanoidRootPart")
			if myHRP then
				originalCFrame = myHRP.CFrame
			end
	
			while tracking and wipEnabled do
				RunService.Heartbeat:Wait()
				if not wipEnabled or not currentTarget or not currentTarget.Character then break end
	
				local tRoot = currentTarget.Character:FindFirstChild("HumanoidRootPart")
				local tHum = currentTarget.Character:FindFirstChildOfClass("Humanoid")
				if not tRoot or not tHum then break end
	
				Angle += 100
				local offset = tHum.MoveDirection * 2
				FPos(tRoot, CFrame.new(0, 0.1, 0), CFrame.Angles(math.rad(Angle), 0, 0), offset)
			end
	
			-- Clean up and return when the target is lost or button is turned off
			shutDownEverything()
		end)
	end
	
	local function attemptLockOn(hitPlayer)
		if hitPlayer and hitPlayer ~= player and hitPlayer.Character then
			-- If already tracking someone, reset first
			if tracking then shutDownEverything() end
	
			currentTarget = hitPlayer
			tracking = true
			runVelocityLoop()
		end
	end
	
	UIS.InputBegan:Connect(function(input, gpe)
		if gpe then return end
		if not wipEnabled then return end
	
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
