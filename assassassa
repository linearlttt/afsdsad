local function VKXGQAB_fake_script() -- TextLabel_30.mainScript 
	local script = Instance.new('LocalScript', TextLabel_30)

	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	
	local player = Players.LocalPlayer
	local button = script.Parent:WaitForChild("WipButton")
	
	local TARGET_NAMES = {["1"]=true, ["2"]=true, ["3"]=true, ["4"]=true}
	
	local Toggle = false
	local loopRunning = false
	local lastClick = 0
	local CLICK_DELAY = 0.1
	
	local onColor = Color3.fromRGB(51, 255, 47)
	local offColor = Color3.fromRGB(255, 0, 0)
	button.BackgroundColor3 = offColor
	
	-- =========================
	-- Get Closest Alive Player
	-- =========================
	local function getClosestAlive()
		local closestPlayer = nil
		local closestDist = math.huge
		for _, plr in pairs(Players:GetPlayers()) do
			if plr ~= player and plr.Character then
				local humanoid = plr.Character:FindFirstChildOfClass("Humanoid")
				local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
				if humanoid and humanoid.Health > 0 and hrp then
					local dist = (hrp.Position - Vector3.new(0,0,0)).Magnitude
					if dist < closestDist then
						closestDist = dist
						closestPlayer = plr
					end
				end
			end
		end
		return closestPlayer
	end
	
	-- =========================
	-- Loop Animations and Teleport
	-- =========================
	local function animationLoop()
		if loopRunning then return end
		loopRunning = true
	
		while Toggle do
			local char = player.Character
			if char then
				local humanoid = char:FindFirstChildOfClass("Humanoid")
				local animator = humanoid and humanoid:FindFirstChildOfClass("Animator")
	
				if animator then
					for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
						if track.Name and TARGET_NAMES[track.Name] then
							track:AdjustSpeed(2.3)
							track.Looped = true  -- keep anim looping
						end
					end
				end
	
				-- Teleport to closest alive player
				local target = getClosestAlive()
				if target and target.Character then
					local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
					local targetHum = target.Character:FindFirstChildOfClass("Humanoid")
					local myHRP = char:FindFirstChild("HumanoidRootPart")
					if targetHRP and myHRP and targetHum and targetHum.Health > 0 then
						-- Move 1 stud behind target (opposite to target lookVector)
						local behindPos = targetHRP.Position - targetHRP.CFrame.LookVector.Unit
						myHRP.CFrame = CFrame.new(behindPos + Vector3.new(0,0,0), targetHRP.Position)
					end
				end
			end
	
			task.wait()
		end
	
		loopRunning = false
	end
	
	-- =========================
	-- Button Toggle
	-- =========================
	button.MouseButton1Click:Connect(function()
		if tick() - lastClick < CLICK_DELAY then return end
		lastClick = tick()
	
		Toggle = not Toggle
		button.BackgroundColor3 = Toggle and onColor or offColor
	
		if Toggle then
			task.spawn(animationLoop)
		end
	end)
end
coroutine.wrap(VKXGQAB_fake_script)()
