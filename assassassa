		if not character then return end
		local core = character:FindFirstChild("Core")
		local comm = core and core:FindFirstChild("Communicate")
		if comm then
			for _, v in pairs(comm:GetChildren()) do
				if v:IsA("RemoteEvent") then
					return v
				end
			end
		end
	end
	
	-- Checks if the tool is actively held/equipped by your character
	local function hasFightEquipped()
		if character and character:FindFirstChild("Fight") and character:FindFirstChild("Fight"):IsA("Tool") then 
			return true
		end
		return false
	end
	
	local function grab(remote)
		if remote then remote:FireServer("Grab") end
	end
	
	local function slam(remote, target)
		if not target or not target.Character then return end
		local tChar = target.Character
	
		local hrp = tChar:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
	
		local hitPart = tChar:FindFirstChild("RightUpperArm") or hrp
		updateCurrentClass() 
	
		local args = {
			"Slam",
			{
				Character = tChar,
				Point = hrp.Position == Vector3.new(0, 100, 0),
				Hit = hitPart,
				Limb = "",
				Classs = currentClass,
