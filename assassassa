local function DMSOA_fake_script() -- bSliderFrame.mainScript 
	local script = Instance.new('LocalScript', bSliderFrame)

	local Players = game:GetService("Players")
	local UIS = game:GetService("UserInputService")
	
	local player = Players.LocalPlayer
	local mouse = player:GetMouse()
	
	local slider = script.Parent
	local slideFrame = slider:WaitForChild("slideFrame")
	local amountValue = slider:WaitForChild("amountValue")
	
	local character, humanoid
	local DEFAULT_SPEED = 9
	local currentSpeed = 9
	local enabled = false
	
	local parentRoot = slider.Parent.Parent
	local wipButton = parentRoot:FindFirstChild("WipButton")
	
	local function updateCharacter(char)
		character = char
		humanoid = char:WaitForChild("Humanoid")
		if not enabled then
			humanoid.WalkSpeed = DEFAULT_SPEED
		end
	end
	
	player.CharacterAdded:Connect(updateCharacter)
	if player.Character then
		updateCharacter(player.Character)
	end
	
	local dragging = false
	
	local function updateSlider(pos)
		-- Update slider UI
		slideFrame:TweenSize(
			UDim2.new(pos, 0, 1, 0),
			Enum.EasingDirection.Out,
			Enum.EasingStyle.Quad,
			0.1,
			true
		)
	
		-- Only change speed if toggle is enabled
		if enabled and humanoid then
			local walkSpeed = pos * 100 -- 0 to 100
			currentSpeed = walkSpeed
			humanoid.WalkSpeed = currentSpeed
			amountValue.Text = tostring(math.floor(currentSpeed))
		else
			-- Show current speed on slider even if toggle is off
			amountValue.Text = tostring(math.floor(currentSpeed))
		end
	end
	
	-- Initialize slider position to match default/current speed
	local initialPos = currentSpeed / 100
	updateSlider(initialPos)
	
	-- =========================
	-- SLIDER INPUT (PC + Mobile)
	-- =========================
	local function updateSliderFromInput(input)
		local inputPos
		if input.UserInputType == Enum.UserInputType.MouseMovement 
			or input.UserInputType == Enum.UserInputType.Touch 
			or input.UserInputType == Enum.UserInputType.MouseButton1 then
			inputPos = input.Position.X
		else
			return
		end
	
		local pos = math.clamp((inputPos - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
		updateSlider(pos)
	end
	
	-- Input began (mouse or touch)
	slider.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			updateSliderFromInput(input)
		end
	end)
	
	-- Input ended (release)
	slider.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	
	-- Input changed (drag)
	UIS.InputChanged:Connect(function(input)
		if dragging then
			updateSliderFromInput(input)
		end
	end)
	
	-- Loop to enforce speed while enabled
	local function startSpeedLoop()
		coroutine.wrap(function()
			while enabled do
				if humanoid then
					humanoid.WalkSpeed = currentSpeed
				end
				task.wait(0.05)
			end
		end)()
	end
	
	-- Toggle button logic
	if wipButton then
		wipButton.MouseButton1Click:Connect(function()
			enabled = not enabled
	
			if enabled then
				wipButton.BackgroundColor3 = Color3.fromRGB(51, 255, 47)
				startSpeedLoop()
			else
				wipButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
				if humanoid then
					humanoid.WalkSpeed = DEFAULT_SPEED
				end
			end
		end)
	end
	
	-- Initial display
	amountValue.Text = tostring(currentSpeed)
end
