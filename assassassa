		-- Connect Slider Input Events (Fully adjustable at any second)
		Janitor.Connections.SliderBegan = slider.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = true
				local pos = math.clamp((getInputPosition(input) - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
				updateSlider(pos)
			end
		end)
	
		Janitor.Connections.SliderEnded = slider.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = false
			end
		end)
	
		Janitor.Connections.SliderChanged = UIS.InputChanged:Connect(function(input)
			if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				local pos = math.clamp((getInputPosition(input) - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
				updateSlider(pos)
			end
		end)
	
		setupSpacebarWeave()
	end
	
	-- ==========================================
	-- INTERFACE INTERACTION SETUP
	-- ==========================================
	if wipButton then
		wipButton.MouseButton1Click:Connect(function()
			wipEnabled = not wipEnabled
			Config.WeaveEnabled = wipEnabled
	
			local targetColor = wipEnabled and Color3.fromRGB(51, 255, 47) or Color3.fromRGB(255, 11, 0)
			TweenService:Create(wipButton, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {BackgroundColor3 = targetColor}):Play()
	
			if wipEnabled then
				loadMechanics()
				local initialRatio = (Config.DelayDuration - MIN_VALUE) / (MAX_VALUE - MIN_VALUE)
				slideFrame.Size = UDim2.new(initialRatio, 0, 1, 0)
				amountValue.Text = string.format("%.2fs Delay", Config.DelayDuration)
			else
				unloadMechanics()
				dragging = false
				TweenService:Create(slideFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {Size = UDim2.new(0, 0, 1, 0)}):Play()
			end
		end)
	end
end
