	-- THE COMBO LOGIC
	-- =========================
	local function executeSelfSequence()
		if not cachedRemote then return end
	
		local char = LocalPlayer.Character
		if not char then return end
	
		local hrp = char:FindFirstChild("HumanoidRootPart")
		local hum = char:FindFirstChildWhichIsA("Humanoid")
		if not hrp or not hum or hum.Health <= 0 then return end
	
		bypassStates(char)
	
		-- 1. FIRE GRAB FIRST
		local grabArgs = {
			"Grab",
			{
				Character = char,
				Point = hrp.Position,
				Hit = hrp,
				Limb = currentHand, 
				Class = lastClass, 
				Result = nil
			}
		}
		cachedRemote:FireServer(unpack(grabArgs))
	
		-- 2. WAIT EXACTLY 0.05 SECONDS
		task.wait(0.05)
	
		-- Verify player didn't die during the 0.05s delay
		if not attacking or hum.Health <= 0 then return end
	
		-- 3. FIRE SLAM ON SELF
		local slamArgs = {
			"Slam",
			{
				Character = char,
				Point = hrp.Position,
				Hit = hrp,
				Limb = currentHand, 
				Class = lastClass, 
				Result = nil
			}
		}
		cachedRemote:FireServer(unpack(slamArgs))
	
		currentHand = (currentHand == "RightHand") and "LeftHand" or "RightHand"
	end
	
	-- =========================
	-- MASTER SEQUENCE LOOP
	-- =========================
	local function startComboLoop()
		if loopActive or not attacking then return end
		loopActive = true
	
		task.spawn(function()
			while attacking do
				local char = LocalPlayer.Character
				local hum = char and char:FindFirstChildWhichIsA("Humanoid")
	
				if char and hum and hum.Health > 0 then
					executeSelfSequence()
				end
	
				task.wait(ATTACK_DELAY)
			end
			loopActive = false
		end)
	end
	
	local function onCharacterAdded(char)
		character = char
		humanoid = character:WaitForChild("Humanoid")
	
		cachedRemote = nil 
	
		local core = character:WaitForChild("Core", 5)
		if core then
			stylesFolder = core:WaitForChild("Animations", 5):WaitForChild("Styles", 5)
	
			task.spawn(function()
				local communicate = core:WaitForChild("Communicate", 5)
				if communicate then
					cachedRemote = communicate:FindFirstChildWhichIsA("RemoteEvent")
				end
			end)
		end
	
		animationClassMap = {}
