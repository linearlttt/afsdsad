	local States = { DisableTouch = false }
	local Connections = {}
	
	-- Applies or removes the touch restriction on a player's character parts
	local function SetPlayerTouch(character, shouldDisable)
		if not character then return end
		for _, part in ipairs(character:GetChildren()) do
			if part:IsA("BasePart") then
				-- If true, sets CanTouch to false (blocking them)
				-- If false, returns CanTouch back to true
				part.CanTouch = not shouldDisable
			end
		end
	end
	
	-- Handles monitoring and disabling other players' touch capabilities
	local function DisableOtherPlayersTouch(args1)
		States.DisableTouch = args1
	
		-- Clean up old event listeners (stops checking old character updates)
		for _, connection in ipairs(Connections) do
			connection:Disconnect()
		end
		table.clear(Connections)
	
		-- If the toggle is turned OFF, restore everyone's touch instantly
		if not args1 then
