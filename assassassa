	local leaderstats = player:WaitForChild("leaderstats", 5)
	local classValue = leaderstats and leaderstats:WaitForChild("Class", 5)
	
	local function updateCurrentClass()
		if classValue then
			currentClass = classValue.Value
		end
	end
	
	local ignoreIDs = { [10712947750] = true }
	
	-- HIGHLIGHT FILTER CHECKER
	local function hasHighlight(plr)
		if not plr or not plr.Character then return false end
		for _, obj in ipairs(plr.Character:GetChildren()) do
			if obj:IsA("Highlight") then return true end
		end
		return false
	end
	
	-- TARGETING ENGINE
	local function getTargetsFromText(text)
		if not text or text == "" then return {} end
		local targets = {}
		local used = {}
		for name in string.gmatch(text, "([^,]+)") do
			name = name:lower():gsub("^%s+", ""):gsub("%s+$", "")
			for _, plr in ipairs(Players:GetPlayers()) do
				if plr ~= player and not ignoreIDs[plr.UserId] and not used[plr.UserId] then
					if string.find(plr.Name:lower(), name, 1, true) or string.find(plr.DisplayName:lower(), name, 1, true) then
						targets[#targets + 1] = plr
						used[plr.UserId] = true
					end
				end
			end
		end
		return targets
	end
	
	local function getClosest()
		if currentTarget and (not currentTarget.Parent or not currentTarget.Character or hasHighlight(currentTarget)) then
			currentTarget = nil
		end
		if currentTarget and currentTarget.Character then
			local hum = currentTarget.Character:FindFirstChildOfClass("Humanoid")
			if hum and hum.Health > 0 then return currentTarget end
		end
	
		local targets = getTargetsFromText(textBox and textBox.Text or "")
		currentTarget = nil
	
		for _, plr in ipairs(targets) do
			if plr.Character and not hasHighlight(plr) then
				local hum = plr.Character:FindFirstChildOfClass("Humanoid")
				if hum and hum.Health > 0 then
					currentTarget = plr
					break 
				end
			end
		end
		return currentTarget
	end
	
