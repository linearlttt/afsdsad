			Enum.EasingDirection.Out,
			Enum.EasingStyle.Quad,
			0.1,
			true
		)
		local healthThreshold = math.floor(minHealth + pos * (maxHealth - minHealth))
		amountValue.Text = tostring(healthThreshold)
		attackHealthThreshold = healthThreshold
	end
	
