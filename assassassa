		character.ChildRemoved:Connect(function(child)
			if child:IsA("Tool") and child.Name == "Fight" then
				if toolConnection then
					toolConnection:Disconnect()
					toolConnection = nil
				end
			end
		end)
	end
	
	-- Run setup for new characters when they spawn
	player.CharacterAdded:Connect(setupToolListener)
	
	-- Run setup for the current character if they already exist
	if player.Character then
		setupToolListener(player.Character)
	end
