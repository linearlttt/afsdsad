	local friendCache = {}
	local function updateFriendCache()
		for _, p in pairs(playersService:GetPlayers()) do
			if p ~= localPlayer and friendCache[p.UserId] == nil then
				task.spawn(function()
					local success, isFriend = pcall(function()
						return localPlayer:IsFriendsWith(p.UserId)
					end)
					if success then
						friendCache[p.UserId] = isFriend
					end
				end)
			end
		end
	end
	
	playersService.PlayerAdded:Connect(function(p)
		task.wait() 
		pcall(function()
			friendCache[p.UserId] = localPlayer:IsFriendsWith(p.UserId)
		end)
	end)
	
	local function hasWeapon()
		local character = localPlayer.Character
		if not character then return false end
		local equippedTool = character:FindFirstChildOfClass("Tool")
		return equippedTool and equippedTool.Name == "Fight"
	end
	
	local function fetchRemote()
		local character = localPlayer.Character
		local coreFolder = character and character:FindFirstChild("Core")
		local commsFolder = coreFolder and coreFolder:FindFirstChild("Communicate")
	
		if commsFolder then
			for _, child in pairs(commsFolder:GetChildren()) do
				if child:IsA("RemoteEvent") then
					return child
				end
			end
		end
		return nil
	end
	
	local function zeroVelocity(rootPart)
		if not rootPart then return end
		rootPart.AssemblyLinearVelocity = Vector3.zero
		rootPart.AssemblyAngularVelocity = Vector3.zero
	end
	
