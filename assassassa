	local currentTarget = nil
	local moveConnection = nil
	local originalCFrame = nil -- This will store your position
	
	-- UI Setup
	local parentRoot = script.Parent
	local wipButton = parentRoot:FindFirstChild("WipButton") 
	
	local function updateButtonVisuals()
		if wipButton then
			wipButton.BackgroundColor3 = wipEnabled and Color3.fromRGB(51, 255, 47) or Color3.fromRGB(255, 11, 0)
		end
	end
	
	local function resetCamera()
		camera.CameraSubject = character:FindFirstChildOfClass("Humanoid") or character
	end
	
	local function shutDownEverything()
		tracking = false
		currentTarget = nil
	
		-- Stop any active loops
		if moveConnection then 
			moveConnection:Disconnect() 
			moveConnection = nil 
		end
	
		-- Bring your character back to safety if a position was saved
		local myHRP = character and character:FindFirstChild("HumanoidRootPart")
		if myHRP and originalCFrame then
			myHRP.CFrame = originalCFrame
			myHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
			myHRP.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
		end
	
		originalCFrame = nil
		resetCamera()
	end
	
	local function toggleMasterState()
		wipEnabled = not wipEnabled
		updateButtonVisuals()
		if not wipEnabled then shutDownEverything() end
	end
	
