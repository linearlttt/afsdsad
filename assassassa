		remote:FireServer(unpack(args))
		remote:FireServer("Swing", { Limb = "LeftHand" })
	end
	
	-- TELEPORT RESET MECHANIC
	local function returnToOriginalPosition()
		resetCamera() 
		local myHRP = character and character:FindFirstChild("HumanoidRootPart")
		if myHRP and originalCFrame then
			myHRP.CFrame = originalCFrame
			myHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
			myHRP.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
			if humanoid then humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end
		end
		originalCFrame = nil 
	end
	
	-- ANIMATION OVERRIDES
	local function stopAllAnimations()
		local animator = humanoid and humanoid:FindFirstChildOfClass("Animator")
		if animator then
			for _, track in ipairs(animator:GetPlayingAnimationTracks()) do track:Stop(0) end
		end
	end
	
	local function startAnimationSuppressor()
		if animConnection then return end
		stopAllAnimations() 
		local animator = humanoid:WaitForChild("Animator", 3)
		if animator then
			animConnection = animator.AnimationPlayed:Connect(function(track)
				if attacking then track:Stop(0) end
			end)
		end
	end
	
	local function stopAnimationSuppressor()
		if animConnection then
			animConnection:Disconnect()
			animConnection = nil
		end
	end
	
	-- UI VISUALS
	local function updateButtonVisuals()
		if wipButton then
			wipButton.BackgroundColor3 = wipEnabled and Color3.fromRGB(51, 255, 47) or Color3.fromRGB(255, 11, 0)
		end
	end
	
	local function shutDownEverything()
		attacking = false
		currentTarget = nil
		if moveConnection then
			moveConnection:Disconnect()
			moveConnection = nil
		end
		stopAnimationSuppressor()
		returnToOriginalPosition()
		resetCamera() 
	end
	
	local function startLoop()
		if not wipEnabled or not currentTarget then return end
		attacking = true
		startAnimationSuppressor()
	
		-- Movement Loop
		moveConnection = RunService.Heartbeat:Connect(function()
			local myHRP = character and character:FindFirstChild("HumanoidRootPart")
	
			-- Target/Master Switch Validation Check
			if not wipEnabled or not currentTarget or not currentTarget.Parent or not currentTarget.Character then
				shutDownEverything()
				return
			end
	
			local tChar = currentTarget.Character
			local tHum = tChar:FindFirstChildOfClass("Humanoid")
			local tTorso = tChar:FindFirstChild("UpperTorso") or tChar:FindFirstChild("Torso")
	
			if not tHum or tHum.Health <= 0 or not tTorso then
				shutDownEverything()
				return
			end
	
			if myHRP then
				if not originalCFrame then
					originalCFrame = myHRP.CFrame
				end
	
				local rawVelocity = tTorso.AssemblyLinearVelocity
				local targetSpeed = rawVelocity.Magnitude
				local targetVelocity = rawVelocity
	
				if targetSpeed > 120 then
					targetVelocity = Vector3.new(0, 0, 0)
					targetSpeed = 0
				end
	
				-- Hidden positioning calculations
				local basePosition = tTorso.Position
				if targetSpeed > SPEED_THRESHOLD then
					basePosition = basePosition + (targetVelocity.Unit * FORWARD_OFFSET)
				end
	
				local enforcedUndergroundY = tTorso.Position.Y - 7
				local finalUnderPos = Vector3.new(basePosition.X, enforcedUndergroundY, basePosition.Z)
				local calculatedCFrame = CFrame.new(finalUnderPos) * CFrame.Angles(math.rad(90), 0, 0)
	
				myHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
				myHRP.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
				myHRP.CFrame = calculatedCFrame
				viewTarget(currentTarget)
			end
		end)
	
