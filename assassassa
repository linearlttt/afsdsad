	local maxVelocity = 400 -- max velocity allowed on any axis
	
	local function colorsAreClose(c1, c2, tolerance)
		tolerance = tolerance or 0.01
		local dr = math.abs(c1.R - c2.R)
		local dg = math.abs(c1.G - c2.G)
		local db = math.abs(c1.B - c2.B)
		return dr <= tolerance and dg <= tolerance and db <= tolerance
	end
	
