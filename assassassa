		local comm = core and core:FindFirstChild("Communicate")
		if comm then
			for _, v in pairs(comm:GetChildren()) do if v:IsA("RemoteEvent") then return v end end
		end
		return nil
	end
	
	local function safeFireClick(detector)
		local clickFunc = _G.fireclickdetector or _G.fire_click_detector or _G.click_detector or fireclickdetector
		if clickFunc then pcall(function() clickFunc(detector, 0) end) end
	end
	
	local function stopThrowing()
