	local player = Players.LocalPlayer
	local gui = script.Parent
	
	local padPositions = {
		Pad1 = Vector3.new(-189, 5, -172),
		Pad2 = Vector3.new(-184, 5, -167),
	}
	
	local buttons = {
		Pad1 = gui:WaitForChild("Pad1"),
		Pad2 = gui:WaitForChild("Pad2"),
		AutoReset = gui:WaitForChild("AutoReset")
	}
	
	-- Button setup
	for _, button in pairs(buttons) do
		if button:GetAttribute("Active") == nil then
			button:SetAttribute("Active", false)
		end
	
		button.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
	
		button.MouseButton1Click:Connect(function()
			local active = not button:GetAttribute("Active")
			button:SetAttribute("Active", active)
	
			button.BackgroundColor3 = active
				and Color3.fromRGB(51, 255, 47)
				or Color3.fromRGB(255, 0, 0)
		end)
	end
	
	local function getActivePadPosition()
		for padName, pos in pairs(padPositions) do
			local button = buttons[padName]
			if button and button:GetAttribute("Active") then
				return pos
			end
		end
	end
	
	-- Keeps player on pad if moved
	local function startPositionLock(char)
		local hrp = char:WaitForChild("HumanoidRootPart")
		local humanoid = char:WaitForChild("Humanoid")
	
		task.spawn(function()
			while char.Parent and humanoid.Health > 0 do
				local targetPos = getActivePadPosition()
	
				if targetPos then
					local distance = (hrp.Position - targetPos).Magnitude
	
					if distance > 5 then
						hrp.CFrame = CFrame.new(targetPos)
					end
				end
	
				task.wait(0.1)
			end
		end)
	end
	
	-- AutoReset ONLY once per spawn (no loops)
	local function autoResetOnce(char)
		local humanoid = char:WaitForChild("Humanoid")
		local hrp = char:WaitForChild("HumanoidRootPart")
	
		local playerFolder = workspace:WaitForChild("Live"):WaitForChild(player.Name)
		local pvpValue = playerFolder:WaitForChild("PVP")
	
		if not buttons.AutoReset:GetAttribute("Active") then return end
		if not pvpValue.Value then return end
	
		local targetPos = getActivePadPosition()
		if not targetPos then return end
	
		local startTime = tick()
	
		while char.Parent do
			local distance = (hrp.Position - targetPos).Magnitude
	
			-- ONLY reset when actually on pad
			if distance <= 5 then
				humanoid.Health = 0
				return
			end
	
			-- safety timeout
			if tick() - startTime > 10 then
				return
			end
	
			task.wait(0.1)
		end
	end
	
	local function onCharacter(char)
		local hrp = char:WaitForChild("HumanoidRootPart")
	
		-- spawn teleport burst (fixes late spawn desync)
		task.spawn(function()
			for i = 1, 10 do
				local targetPos = getActivePadPosition()
				if targetPos and hrp.Parent then
					hrp.CFrame = CFrame.new(targetPos)
				end
				task.wait(0.2)
			end
		end)
	
		-- lock position
		startPositionLock(char)
	
		-- auto reset once per spawn
		task.spawn(function()
			autoResetOnce(char)
		end)
	end
	
	player.CharacterAdded:Connect(onCharacter)
	
	if player.Character then
		onCharacter(player.Character)
	end
end
