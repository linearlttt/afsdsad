				return true
			end
		end
		return false
	end
	
	-- Finds the matching replacement animation object inside the OMNI folder
	local function getOmniReplacement(animName, isIdle)
		local omniFolder = getOmniFolder()
		if not omniFolder then return nil end
	
		if isIdle then
			-- Grabs "Idle" directly inside the OMNI folder
			return omniFolder:FindFirstChild(animName) or omniFolder:FindFirstChild("Idle")
		else
			-- Looks inside the M1s folder for the matching attack name
			local m1sFolder = omniFolder:FindFirstChild("M1s")
			if m1sFolder then
				return m1sFolder:FindFirstChild(animName)
			else
				return omniFolder:FindFirstChild(animName, true)
			end
		end
	end
	
