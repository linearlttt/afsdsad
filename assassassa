		Pad2 = gui:WaitForChild("Pad2"),
		AutoReset = gui:WaitForChild("AutoReset")
	}
	
	for name, btn in pairs(buttons) do
		if btn:GetAttribute("Active") == nil then
			btn:SetAttribute("Active", false)
		end
	
		btn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
	
		btn.MouseButton1Click:Connect(function()
			local active = not btn:GetAttribute("Active")
			btn:SetAttribute("Active", active)
			btn.BackgroundColor3 = active and Color3.fromRGB(51, 255, 47) or Color3.fromRGB(255, 0, 0)
		end)
	end
	
	local function getActivePad()
		for name, pos in pairs(pads) do
			local btn = buttons[name]
			if btn and btn:GetAttribute("Active") then
				return pos
			end
		end
		return nil
	end
	
	local conns = {}
	local token = 0
	
	local function clean()
		for _, c in ipairs(conns) do
			if c then c:Disconnect() end
		end
		table.clear(conns)
		token = token + 1
	end
	
	local function onChar(char)
		clean()
		local myToken = token
	
		local hrp = char:WaitForChild("HumanoidRootPart", 5)
		local hum = char:WaitForChild("Humanoid", 5)
		if not hrp or not hum then return end
	
		local live = workspace:WaitForChild("Live", 5)
		local pvp = live and live:WaitForChild(LP.Name, 5):WaitForChild("PVP", 5)
	
		local moveLoop = RunService.Heartbeat:Connect(function()
			if not char.Parent or not hrp.Parent then return end
	
			if not char:FindFirstChild("NO_GAMEPASS") then
				local target = getActivePad()
				if target then
					hrp.CFrame = CFrame.new(target)
				end
			end
		end)
		table.insert(conns, moveLoop)
	
		local deadConn = hum.Died:Connect(function()
			clean()
		end)
		table.insert(conns, deadConn)
	
		task.spawn(function()
			while hum.Health > 0 and char.Parent and token == myToken do
				if buttons.AutoReset:GetAttribute("Active") and pvp and pvp.Value then
					if char:FindFirstChild("NO_GAMEPASS") then
						hum.Health = 0
						clean()
						break 
					end
				end
				task.wait(0.5)
			end
		end)
	end
	
	LP.CharacterAdded:Connect(onChar)
	if LP.Character then
		task.spawn(onChar, LP.Character)
	end
