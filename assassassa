	-- ==========================================
	
	local function trackPlayerAnimations(enemyPlayer: Player)
		if not enemyPlayer or Janitor.TrackingPlayers[enemyPlayer] then return end
	
		local playerJanitor = {}
		Janitor.TrackingPlayers[enemyPlayer] = playerJanitor
		local enemyName = enemyPlayer.Name 
	
		local function onCharacterAdded(char: Model)
