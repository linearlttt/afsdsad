	local script = Instance.new('LocalScript', OutlastHubNormalPremium_2.TeleportToAll)

	local plrs = game:GetService("Players")
	local plr = plrs.LocalPlayer
	local run_service = game:GetService("RunService")
	
	local target: string
	local teleportEnabled = false
	local toggleButton = script.Parent
	local delayTextBox = toggleButton:FindFirstChild("TextBox")
	
	local FLUNG_VELOCITY_THRESHOLD = 1000
	local PREDICTION_TIME = 0
	
	local onColor = Color3.fromRGB(51, 255, 47)
	local offColor = Color3.fromRGB(255, 0, 0)
	
	-- Initialized with a default, will update via TextBox
	local teleportDelay = 1 
	local lastTeleportTimestamp = 0
	local ignoreFriendsEnabled = true 
	
	toggleButton.BackgroundColor3 = offColor
	if delayTextBox then
		delayTextBox.Text = tostring(teleportDelay)
	
		-- Added: Updates the delay variable whenever you type in the box
		delayTextBox:GetPropertyChangedSignal("Text"):Connect(function()
			local parsed = tonumber(delayTextBox.Text)
			if parsed then
				teleportDelay = math.max(0, parsed)
			end
		end)
	end
	
	local function find_target(name: string)
		if not name or #name < 1 then return end
		name = string.lower(name)
	
		local liveFolder = workspace:FindFirstChild("Live")
		if not liveFolder then return nil end
	
		for _, char in liveFolder:GetChildren() do
			local player_candidate = plrs:GetPlayerFromCharacter(char)
			if player_candidate and player_candidate ~= plr then
				local lower_name = string.lower(player_candidate.Name)
				local lower_display = string.lower(player_candidate.DisplayName)
	
				if string.sub(lower_name, 1, #name) == name or string.sub(lower_display, 1, #name) == name then
					if ignoreFriendsEnabled and plr:IsFriendsWith(player_candidate.UserId) then
						return nil
					end
					return player_candidate
				end
			end
		end
		return nil
	end
	
	local function generate_rand()
		local all_plrs = {}
		local liveFolder = workspace:FindFirstChild("Live")
	
		if not liveFolder then return nil end
	
		for _, char in liveFolder:GetChildren() do
			local v = plrs:GetPlayerFromCharacter(char)
			if v and v ~= plr then
				if not (ignoreFriendsEnabled and plr:IsFriendsWith(v.UserId)) then
					local humanoid = char:FindFirstChildWhichIsA("Humanoid")
					local hrp = char:FindFirstChild("HumanoidRootPart")
	
					if humanoid and humanoid.Health ~= 0 and not char:FindFirstChild("KO") and hrp and not hrp.Anchored then
						if hrp.AssemblyLinearVelocity.Y < FLUNG_VELOCITY_THRESHOLD then
							table.insert(all_plrs, v)
						end
					end
				end
			end
		end
	
		if #all_plrs < 1 then return nil end
		return all_plrs[math.random(1, #all_plrs)]
	end
	
	toggleButton.MouseButton1Click:Connect(function()
		teleportEnabled = not teleportEnabled
		toggleButton.BackgroundColor3 = teleportEnabled and onColor or offColor
	end)
	
	run_service.Stepped:Connect(function()
		if not teleportEnabled or not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then return end
	
		local myHRP = plr.Character.HumanoidRootPart
		local myHumanoid = plr.Character:FindFirstChildWhichIsA("Humanoid")
	
		if myHumanoid and myHumanoid.Health ~= 0 then
			local found_tar = find_target(target)
			if found_tar and found_tar.Character then
				local targetHRP = found_tar.Character:FindFirstChild("HumanoidRootPart")
				local targetHumanoid = found_tar.Character:FindFirstChildWhichIsA("Humanoid")
	
				if targetHumanoid and targetHumanoid.Health ~= 0 and targetHRP and not targetHRP.Anchored then
					if targetHRP.AssemblyLinearVelocity.Y < FLUNG_VELOCITY_THRESHOLD then
						local currentTime = os.clock()
						-- Now correctly uses the updated teleportDelay variable
						if currentTime - lastTeleportTimestamp >= teleportDelay then
							myHRP.CFrame = targetHRP.CFrame * CFrame.new(targetHRP.AssemblyLinearVelocity * PREDICTION_TIME)
							lastTeleportTimestamp = currentTime
						end
					end
				end
			end
		end
	end)
	
	task.spawn(function()
		while true do
			if teleportEnabled then
				local possible_rand = generate_rand()
				if possible_rand then
					target = possible_rand.Name
				end
			end
			task.wait()
		end
	end)
