	local function updateTargetUserIds()
		local text = (textBox and textBox.Text) or ""
		if text == "" then return end
	
		for chunk in string.gmatch(text, "[^,]+") do
			local cleanName = chunk:lower():gsub("^%s+", ""):gsub("%s+$", "")
			if cleanName ~= "" then
				for _, plr in ipairs(Players:GetPlayers()) do
					if string.find(plr.Name:lower(), cleanName, 1, true) or string.find(plr.DisplayName:lower(), cleanName, 1, true) then
						-- Check if the player is in the ignore list before saving them
						if not isIgnored(plr) and not table.find(savedTargetUserIds, plr.UserId) then
							table.insert(savedTargetUserIds, plr.UserId)
						end
					end
				end
			end
		end
	end
	
