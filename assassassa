local function WEBODT_fake_script() -- OutlastHubNormalPremium_2.bSliderFrame_10.mainScript 
	local script = Instance.new('LocalScript', OutlastHubNormalPremium_2.bSliderFrame_10)

	local Players = game:GetService("Players")
	local LocalPlayer = Players.LocalPlayer
	local UIS = game:GetService("UserInputService")
	
	-- =========================
	-- Slider Setup
	-- =========================
	local slider = script.Parent
	local slideFrame = slider:WaitForChild("slideFrame")
	local amountValue = slider:WaitForChild("amountValue")
	
	local MIN_VALUE = 0
	local MAX_VALUE = 1
	local currentValue = MIN_VALUE
	local dragging = false
	local wipEnabled = false 
	
	_G.WeaveEnabled = false
	_G.WeaveInterval = currentValue
	_G.MicroInterval = 0
	
	local function updateSlider(pos)
		slideFrame:TweenSize(
			UDim2.new(pos, 0, 1, 0),
			Enum.EasingDirection.Out,
			Enum.EasingStyle.Quad,
			0.1,
			true
		)
	
		-- Calculate raw value
		local rawValue = MIN_VALUE + (pos * (MAX_VALUE - MIN_VALUE))
	
		-- Clean formatting: Caps it at exactly 4 decimal places (e.g., 0.3124)
		currentValue = tonumber(string.format("%.4f", rawValue))
	
		amountValue.Text = string.format("%.4f", currentValue)
		_G.WeaveInterval = currentValue
	end
	
	local function getInputPosition(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement 
			or input.UserInputType == Enum.UserInputType.MouseButton1 
			or input.UserInputType == Enum.UserInputType.Touch then
			return input.Position.X
		end
	end
	
	-- =========================
	-- Mass Remote Trigger
	-- =========================
	local function triggerWeaveOnEveryone()
		-- Loop through every single player in the server instantly
		for _, player in pairs(Players:GetPlayers()) do
			if player ~= LocalPlayer and player.Character then
				local core = player.Character:FindFirstChild("Core")
				local comm = core and core:FindFirstChild("Communicate")
				local remote = comm and comm:FindFirstChildOfClass("RemoteEvent")
	
				if remote then
					-- Fires for everyone simultaneously using fast threads
					task.spawn(function()
						pcall(function()
							remote:FireServer("Weave", nil, true)
						end)
					end)
				end
			end
		end
	end
	
	-- =========================
	-- Precision Loop
	-- =========================
	task.spawn(function()
		while true do
			if wipEnabled and _G.WeaveEnabled then
				triggerWeaveOnEveryone()
				task.wait(math.max(currentValue, 0.001))
			else
				task.wait()
			end
		end
	end)
	
	-- =========================
	-- Persistent Slider Connections
	-- =========================
	slider.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			local pos = math.clamp((getInputPosition(input) - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
			updateSlider(pos)
		end
	end)
	
	slider.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local pos = math.clamp((getInputPosition(input) - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
			updateSlider(pos)
		end
	end)
	
	-- =========================
	-- Main Toggle Button
	-- =========================
	local parentRoot = slider.Parent.Parent
	local wipButton = parentRoot:FindFirstChild("WipButton")
	
	if wipButton then
		wipButton.MouseButton1Click:Connect(function()
			wipEnabled = not wipEnabled
			if wipEnabled then
				_G.WeaveEnabled = true
				wipButton.BackgroundColor3 = Color3.fromRGB(51, 255, 47)
			else
				_G.WeaveEnabled = false
				wipButton.BackgroundColor3 = Color3.fromRGB(255, 11, 0)
			end
		end)
	end
end
