local function CQFUNU_fake_script() -- OutlastHubNormalPremium_2.bSliderFrame_4.mainScript 
	local script = Instance.new('LocalScript', OutlastHubNormalPremium_2.bSliderFrame_4)

	local Players = game:GetService("Players")
	local LocalPlayer = Players.LocalPlayer
	local UIS = game:GetService("UserInputService")
	
	-- Cache native Luau methods for maximum execution speed inside hooks
	local IsA = game.IsA
	local FindFirstChildWhichIsA = game.FindFirstChildWhichIsA
	
	-- =========================
	-- Slider Setup
	-- =========================
	local slider = script.Parent
	local slideFrame = slider:WaitForChild("slideFrame")
	local amountValue = slider:WaitForChild("amountValue")
	
	local MIN_VALUE, MAX_VALUE = 0, 1
	local currentValue = MIN_VALUE
	local dragging = false
	local wipEnabled = false
	
	local function updateSlider(pos)
		if not wipEnabled then return end
		slideFrame:TweenSize(
			UDim2.new(pos,0,1,0),
			Enum.EasingDirection.Out,
			Enum.EasingStyle.Quad,
			0.1,
			true
		)
		currentValue = math.floor((MIN_VALUE + pos*(MAX_VALUE-MIN_VALUE))*100)/100
		amountValue.Text = tostring(currentValue)
		_G.WeaveInterval = currentValue
	end
	
	local function getInputPosition(input)
		return input.Position.X
	end
	
	slider.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			local pos = math.clamp((getInputPosition(input) - slider.AbsolutePosition.X)/slider.AbsoluteSize.X,0,1)
			updateSlider(pos)
		end
	end)
	
	slider.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local pos = math.clamp((getInputPosition(input) - slider.AbsolutePosition.X)/slider.AbsoluteSize.X,0,1)
			updateSlider(pos)
		end
	end)
	
	-- =========================
	-- Global State & UI Toggle
	-- =========================
	_G.WeaveEnabled = false
	_G.WeaveInterval = 9e9 -- Starts at 9e9 since it defaults to off
	_G.MicroInterval = 0
	_G._t = 0
	
	local parentRoot = slider.Parent.Parent
	local wipButton = parentRoot:FindFirstChild("WipButton")
	
	if wipButton then
		wipButton.MouseButton1Click:Connect(function()
			wipEnabled = not wipEnabled
			_G.WeaveEnabled = wipEnabled
	
			if wipEnabled then
				-- Enabled: Restore the actual slider value
				_G.WeaveInterval = currentValue
				wipButton.BackgroundColor3 = Color3.fromRGB(51,255,47)
			else
				-- Disabled: Set the weave time to 9e9 to freeze it
				_G.WeaveInterval = 9e9
				wipButton.BackgroundColor3 = Color3.fromRGB(255,11,0)
			end
		end)
	end
	
	-- =========================
	-- Optimized Remote Locator
	-- =========================
	local cachedCommunicate = nil
	
	local function getRemote()
		local char = LocalPlayer.Character
		if not char then cachedCommunicate = nil return end
	
		-- Cache verification to bypass constant FindFirstChild calls on the character
		if not cachedCommunicate or cachedCommunicate.Parent ~= char:FindFirstChild("Core") then
			local core = char:FindFirstChild("Core")
			cachedCommunicate = core and core:FindFirstChild("Communicate") or nil
		end
	
		if cachedCommunicate then
			return FindFirstChildWhichIsA(cachedCommunicate, "RemoteEvent")
		end
	end
	
	-- =========================
	-- Global Hook Interception Method
	-- =========================
	local hookedRemotes = {} -- Prevents double-hooking memory leaks
	
	local function hookRemoteEvent(remoteEvent)
		if hookedRemotes[remoteEvent] then return end
		hookedRemotes[remoteEvent] = true
	
		-- Listens globally for server-to-client traffic fired by players/server
		remoteEvent.OnClientEvent:Connect(function(...)
			if not _G.WeaveEnabled then return end
	
			local targetRemote = getRemote()
			-- Verify target exists and prevent the macro from looping into itself
			if targetRemote and targetRemote ~= remoteEvent then
				pcall(targetRemote.FireServer, targetRemote, "Weave", nil, true)
			end
		end)
	end
	
	local function startGlobalHooking()
		-- 1. Instantly scan the entire active data model for pre-existing RemoteEvents
		for _, instance in ipairs(game:GetDescendants()) do
			local success, isRemote = pcall(IsA, instance, "RemoteEvent")
			if success and isRemote then
				hookRemoteEvent(instance)
			end
		end
	
		-- 2. Dynamically capture any incoming remotes replicated later mid-game
		game.DescendantAdded:Connect(function(instance)
			local success, isRemote = pcall(IsA, instance, "RemoteEvent")
			if success and isRemote then
				hookRemoteEvent(instance)
			end
		end)
	end
	
	-- Run hooking routine asynchronously so it doesn't freeze UI setup
	task.spawn(startGlobalHooking)
end
