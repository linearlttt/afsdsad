local function EWOPEX_fake_script() -- OutlastHubNormalPremium_2.bSliderFrame_4.mainScript 
	local script = Instance.new('LocalScript', OutlastHubNormalPremium_2.bSliderFrame_4)

	local Players = game:GetService("Players")
	local LocalPlayer = Players.LocalPlayer
	local UIS = game:GetService("UserInputService")
	local TweenService = game:GetService("TweenService")
	
	-- ==========================================
	-- CONFIGURATION & STATE
	-- ==========================================
	type Settings = {
		WeaveEnabled: boolean,
		MaxDistance: number,
		DelayDuration: number
	}
	
	local Config: Settings = {
		WeaveEnabled = false,
		MaxDistance = 30,
		DelayDuration = 0.2 -- Default delay
	}
	
	local MIN_VALUE, MAX_VALUE = 0, 1 -- Slider min/max range in seconds
	local dragging = false
	local wipEnabled = false 
	local Janitor = { Connections = {} }
	
	-- ==========================================
	-- UI ELEMENTS
	-- ==========================================
	local slider = script.Parent
	local slideFrame = slider:WaitForChild("slideFrame") :: Frame
	local amountValue = slider:WaitForChild("amountValue") :: TextLabel
	local parentRoot = slider.Parent.Parent
	local wipButton = parentRoot:FindFirstChild("WipButton") :: TextButton
	
	-- ==========================================
	-- UTILITY FUNCTIONS
	-- ==========================================
	local function safeDisconnect(key: string)
		if Janitor.Connections[key] then
			Janitor.Connections[key]:Disconnect()
			Janitor.Connections[key] = nil
		end
	end
	
	local function getInputPosition(input: InputObject): number
		return input.Position.X
	end
	
	local function updateSlider(pos: number)
		if not wipEnabled then return end 
	
		-- Smoothly move the bar fill
		local tweenInfo = TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
		TweenService:Create(slideFrame, tweenInfo, {Size = UDim2.new(pos, 0, 1, 0)}):Play()
	
		-- Always purely manual adjustments
		local calculatedDelay = math.floor((MIN_VALUE + (pos * (MAX_VALUE - MIN_VALUE))) * 100) / 100 
		amountValue.Text = string.format("%.2fs Delay", calculatedDelay)
		Config.DelayDuration = calculatedDelay
	end
	
	-- FIX: Changed to look inside YOUR character, since clients can't pull remotes from other players' characters this way
	local function getLocalRemote(): RemoteEvent?
		local myChar = LocalPlayer.Character
		local core = myChar and myChar:FindFirstChild("Core")
		local comm = core and core:FindFirstChild("Communicate")
		return comm and comm:FindFirstChildOfClass("RemoteEvent") :: RemoteEvent?
	end
	
	-- Find the nearest player character within MaxDistance
	local function getClosestEnemy(myRoot: BasePart): Model?
		local closestEnemyChar: Model? = nil
		local closestDist = Config.MaxDistance
	
		for _, enemy in ipairs(Players:GetPlayers()) do
			if enemy ~= LocalPlayer and enemy.Character then
				local enemyRoot = enemy.Character:FindFirstChild("HumanoidRootPart") :: BasePart?
				if enemyRoot then
					local dist = (myRoot.Position - enemyRoot.Position).Magnitude
					if dist < closestDist then
						closestDist = dist
						closestEnemyChar = enemy.Character
					end
				end
			end
		end
		return closestEnemyChar
	end
	
	-- ==========================================
	-- CORE MANUAL WEAVE LOGIC
	-- ==========================================
	local function setupSpacebarWeave()
		Janitor.Connections.SpacebarBind = UIS.InputBegan:Connect(function(input, gameProcessed)
			-- Ignore inputs if typing in chat or if the toggle is disabled
			if gameProcessed or not wipEnabled then return end
	
			if input.KeyCode == Enum.KeyCode.Space then
				local myChar = LocalPlayer.Character
				-- Strict check: Must have "Fight" tool equipped
				if not myChar or not myChar:FindFirstChild("Fight") then return end
	
				local myRoot = myChar:FindFirstChild("HumanoidRootPart") :: BasePart?
				if not myRoot then return end
	
				local targetEnemy = getClosestEnemy(myRoot)
				if not targetEnemy then return end
	
				-- Capture the current delay slider setting right when space is pressed
				local activeDelay = Config.DelayDuration
	
				-- Execute on background thread for the delay
				task.spawn(function()
					if activeDelay > 0 then
						task.wait(activeDelay)
					end
	
					-- Check conditions are still valid after wait
					if not wipEnabled or not myChar:FindFirstChild("Fight") or not targetEnemy:IsDescendantOf(workspace) then 
						return 
					end
	
					-- FIX: Uses local character remote
					local remote = getLocalRemote()
					if remote then
						-- Fires exactly ONE time passing the action
						remote:FireServer("Weave", nil, true)
					end
				end)
			end
		end)
	end
	
	-- ==========================================
	-- LIFECYCLE MANAGEMENT
	-- ==========================================
	local function unloadMechanics()
		for key, _ in pairs(Janitor.Connections) do
			safeDisconnect(key)
		end
	end
	
	local function loadMechanics()
		unloadMechanics() 
	
		-- Connect Slider Input Events (Fully adjustable at any second)
		Janitor.Connections.SliderBegan = slider.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = true
				local pos = math.clamp((getInputPosition(input) - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
				updateSlider(pos)
			end
		end)
	
		Janitor.Connections.SliderEnded = slider.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = false
			end
		end)
	
		Janitor.Connections.SliderChanged = UIS.InputChanged:Connect(function(input)
			if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				local pos = math.clamp((getInputPosition(input) - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
				updateSlider(pos)
			end
		end)
	
		setupSpacebarWeave()
	end
	
	-- ==========================================
	-- INTERFACE INTERACTION SETUP
	-- ==========================================
	if wipButton then
		wipButton.MouseButton1Click:Connect(function()
			wipEnabled = not wipEnabled
			Config.WeaveEnabled = wipEnabled
	
			local targetColor = wipEnabled and Color3.fromRGB(51, 255, 47) or Color3.fromRGB(255, 11, 0)
			TweenService:Create(wipButton, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {BackgroundColor3 = targetColor}):Play()
	
			if wipEnabled then
				loadMechanics()
				local initialRatio = (Config.DelayDuration - MIN_VALUE) / (MAX_VALUE - MIN_VALUE)
				slideFrame.Size = UDim2.new(initialRatio, 0, 1, 0)
				amountValue.Text = string.format("%.2fs Delay", Config.DelayDuration)
			else
				unloadMechanics()
				dragging = false
				TweenService:Create(slideFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {Size = UDim2.new(0, 0, 1, 0)}):Play()
			end
		end)
	end
end
