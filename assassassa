				if (myRoot.Position - enemyRoot.Position).Magnitude > Config.MaxDistance then return end
	
				local animId = track.Animation and track.Animation.AnimationId
				if not animId then return end
	
				-- Instantly increment to invalidate and kill any previous loop running from an old animation
				currentWeaveId += 1
				local weaveId = currentWeaveId
	
				Config.WeaveInterval = track.Speed
				isAutoTracking = true
				dragging = false
				amountValue.Text = string.format("%.2f (Locked: %s)", track.Speed, enemyName)
	
