	local slider = script.Parent
	local slideFrame = slider:WaitForChild("slideFrame")
	local amountValue = slider:WaitForChild("amountValue")
	
	local MIN_VALUE = 0
	local MAX_VALUE = 1
	local currentValue = 0.1
	local dragging = false
	local wipEnabled = false
	
	local function updateSlider(pos)
		if not wipEnabled then return end
	
		slideFrame:TweenSize(
			UDim2.new(pos, 0, 1, 0),
			Enum.EasingDirection.Out,
			Enum.EasingStyle.Quad,
			0.1,
			true
		)
	
		currentValue = MIN_VALUE + (pos * (MAX_VALUE - MIN_VALUE))
		currentValue = math.floor(currentValue * 100) / 100
	
		amountValue.Text = tostring(currentValue)
		_G.WeaveInterval = currentValue
	end
	
	local function getInputPosition(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement
			or input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			return input.Position.X
		end
	end
	
	slider.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
	
			dragging = true
			local pos = math.clamp(
				(getInputPosition(input) - slider.AbsolutePosition.X) / slider.AbsoluteSize.X,
				0,
				1
			)
	
			updateSlider(pos)
		end
	end)
	
	slider.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
			or input.UserInputType == Enum.UserInputType.Touch) then
	
			local pos = math.clamp(
				(getInputPosition(input) - slider.AbsolutePosition.X) / slider.AbsoluteSize.X,
				0,
				1
			)
	
			updateSlider(pos)
		end
	end)
	
	-- =========================
	-- Toggle Button
	-- =========================
	_G.WeaveEnabled = false
	_G.WeaveInterval = currentValue
	
	local parentRoot = slider.Parent.Parent
	local wipButton = parentRoot:FindFirstChild("WipButton")
	
	if wipButton then
		wipButton.MouseButton1Click:Connect(function()
			wipEnabled = not wipEnabled
			_G.WeaveEnabled = wipEnabled
	
			wipButton.BackgroundColor3 = wipEnabled
				and Color3.fromRGB(51, 255, 47)
				or Color3.fromRGB(255, 11, 0)
		end)
	end
	
	-- =========================
	-- Remote
	-- =========================
	local function getRemote()
		local char = LocalPlayer.Character
		if not char then return end
	
		local core = char:FindFirstChild("Core")
		if not core then return end
	
		local comm = core:FindFirstChild("Communicate")
		if not comm then return end
	
		for _, v in ipairs(comm:GetChildren()) do
			if v:IsA("RemoteEvent") then
				return v
			end
		end
	end
	
	-- =========================
	-- Weave Logic (SAFE SINGLE TRIGGER)
	-- =========================
	local Players = game:GetService("Players")
	local LocalPlayer = Players.LocalPlayer
	
	local RANGE = 9
	local lastTrigger = {}
	local COOLDOWN = 0.33
	
	local function getHRP(char)
		return char and char:FindFirstChild("HumanoidRootPart")
	end
	
	local function isCloseEnough(otherPlayer)
		local myChar = LocalPlayer.Character
		local otherChar = otherPlayer.Character
	
		local myHRP = getHRP(myChar)
		local otherHRP = getHRP(otherChar)
	
		if not myHRP or not otherHRP then return false end
	
		return (myHRP.Position - otherHRP.Position).Magnitude <= RANGE
	end
	
	local function onAnimationPlayed(player)
		if player == LocalPlayer then return end
		if not _G.WeaveEnabled then return end
	
		if not isCloseEnough(player) then return end
	
		local now = os.clock()
		if lastTrigger[player] and (now - lastTrigger[player] < COOLDOWN) then
			return
		end
		lastTrigger[player] = now
	
		local remote = getRemote()
		if remote then
			remote:FireServer("Weave", nil, true)
		end
	end
	
	local function monitorPlayer(player)
		if player == LocalPlayer then return end
	
		local function hookCharacter(char)
			task.wait(0.1)
	
			local humanoid = char:FindFirstChildWhichIsA("Humanoid")
			if not humanoid then return end
	
			local animator = humanoid:FindFirstChildOfClass("Animator")
			if not animator then
				animator = Instance.new("Animator")
				animator.Parent = humanoid
			end
	
			animator.AnimationPlayed:Connect(function()
				onAnimationPlayed(player)
			end)
		end
	
		player.CharacterAdded:Connect(hookCharacter)
	
		if player.Character then
			hookCharacter(player.Character)
		end
	end
	
	for _, player in ipairs(Players:GetPlayers()) do
		monitorPlayer(player)
	end
	
	Players.PlayerAdded:Connect(monitorPlayer)
end
