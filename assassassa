		local loadedValue = targetPlr:FindFirstChild("Loaded")
		if loadedValue and (loadedValue:IsA("BoolValue") or loadedValue:IsA("StringValue")) then
			return loadedValue.Value == true or tostring(loadedValue.Value):lower() == "true"
		end
	
		local loadedAttribute = targetPlr:GetAttribute("Loaded")
		if loadedAttribute ~= nil then
			return loadedAttribute == true or tostring(loadedAttribute):lower() == "true"
		end
	
		return false
	end
	
