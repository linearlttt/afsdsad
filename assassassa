	local leaderstats = player:WaitForChild("leaderstats", 5)
	local classValue = leaderstats and leaderstats:WaitForChild("Class", 5)
	
	local function updateCurrentClass()
		if classValue then
			currentClass = classValue.Value
		end
	end
	
	local ignoreIDs = { [10712947750] = true }
	
	-- HIGHLIGHT FILTER CHECKER
	local function hasHighlight(plr)
		if not plr or not plr.Character then
			return false
		end
		-- Using GetChildren is faster and lightweight for performance
		for _, obj in ipairs(plr.Character:GetChildren()) do
			if obj:IsA("Highlight") then
				return true
			end
		end
		return false
	end
	
	-- CAMERA HANDLERS
	local function resetCamera()
		camera.CameraSubject = player.Character:FindFirstChildOfClass("Humanoid") or player.Character
