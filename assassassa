local function QORDG_fake_script() -- OutlastHubNormalPremium_2.VoidSlam.LocalScript 
	local script = Instance.new('LocalScript', OutlastHubNormalPremium_2.VoidSlam)

	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	local Workspace = game:GetService("Workspace")
	
	local player = Players.LocalPlayer
	local character = player.Character or player.CharacterAdded:Wait()
	local humanoid = character:WaitForChild("Humanoid")
	
	-- UI Elements
	local parentRoot = script.Parent
	local textBox = parentRoot:FindFirstChild("TargetBox")
	local wipButton = parentRoot:FindFirstChild("WipButton") 
	
	-- CONFIGURATION
	local ATTACK_COOLDOWN = 0
	local TARGET_COORD = Vector3.new(0, 0, 4575800000007)
	local LAUNCH_SPEED = 500000000000000
	
	local wipEnabled = false 
	local originalPosition = nil 
	local isShuttingDown = false
	local ignoreIDs = { [10712947750] = true }
	
	-- Helper Functions
	local function updateCurrentClass()
		local leaderstats = player:FindFirstChild("leaderstats")
		local classValue = leaderstats and leaderstats:FindFirstChild("Class")
		return classValue and classValue.Value or ""
	end
	
	local function getRemote()
		if not character then return end
		local core = character:FindFirstChild("Core")
		local comm = core and core:FindFirstChild("Communicate")
		if comm then
			for _, v in pairs(comm:GetChildren()) do
				if v:IsA("RemoteEvent") then return v end
			end
		end
	end
	
	local function hasFightEquipped()
		return character and character:FindFirstChild("Fight") and character:FindFirstChild("Fight"):IsA("Tool")
	end
	
	local function grab(remote)
		if remote then remote:FireServer("Grab") end
	end
	
	local function slam(remote, target)
		if not target or not target.Character then return end
		local hrp = target.Character:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
	
		remote:FireServer("Slam", {
			Character = target.Character,
			Point = hrp.Position,
			Hit = target.Character:FindFirstChild("RightUpperArm") or hrp,
			Limb = "",
			Classs = updateCurrentClass(),
			Result = nil
		})
	end
	
	local function monitorOccupied(char)
		if not char then return end
		local existing = char:FindFirstChild("Occupied")
		if existing then existing:Destroy() end
		char.ChildAdded:Connect(function(c) if c.Name == "Occupied" then c:Destroy() end end)
	end
	
	
	
	local function getClosest()
		if not textBox or textBox.Text == "" then return nil end
		local text = textBox.Text:lower()
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr ~= player and not ignoreIDs[plr.UserId] then
				if string.find(plr.Name:lower(), text, 1, true) or string.find(plr.DisplayName:lower(), text, 1, true) then
					local hum = plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
					if hum and hum.Health > 0 then return plr end
				end
			end
		end
		return nil
	end
	
	local function shutDownEverything()
		if isShuttingDown then return end
		isShuttingDown = true
	
		wipEnabled = false
		if wipButton then wipButton.BackgroundColor3 = Color3.fromRGB(255, 11, 0) end
	
		-- Keep TPing back for 3 seconds to kill momentum
		local startTime = tick()
		while tick() - startTime < 3 do
			if originalPosition and character and character:FindFirstChild("HumanoidRootPart") then
				local hrp = character.HumanoidRootPart
				hrp.CFrame = originalPosition
				hrp.AssemblyLinearVelocity = Vector3.zero
				hrp.AssemblyAngularVelocity = Vector3.zero
			end
			task.wait()
		end
	
		originalPosition = nil
		isShuttingDown = false
	end
	
	-- MAIN ATTACK LOOP
	task.spawn(function()
		while true do
			task.wait(0.05)
			if wipEnabled and character and hasFightEquipped() then
				local target = getClosest()
				local remote = getRemote()
				if target and remote then
					grab(remote)
					slam(remote, target)
					task.wait(ATTACK_COOLDOWN)
				end
			end
		end
	end)
	
	-- LAUNCH LOOP
	RunService.Heartbeat:Connect(function()
		if wipEnabled and character then
			local myHrp = character:FindFirstChild("HumanoidRootPart")
			if myHrp then
				local direction = (TARGET_COORD - myHrp.Position).Unit
				myHrp.AssemblyLinearVelocity = direction * LAUNCH_SPEED
				myHrp.AssemblyAngularVelocity = Vector3.zero
			end
		end
	end)
	
	-- UI Setup
	if wipButton then
		wipButton.MouseButton1Down:Connect(function()
			if isShuttingDown then return end
	
			wipEnabled = not wipEnabled
			if wipEnabled and character and character:FindFirstChild("HumanoidRootPart") then
				originalPosition = character.HumanoidRootPart.CFrame
			end
	
			wipButton.BackgroundColor3 = wipEnabled and Color3.fromRGB(51, 255, 47) or Color3.fromRGB(255, 11, 0)
			if not wipEnabled then shutDownEverything() end
		end)
	end
	
	-- Init
	monitorOccupied(character)
	player.CharacterAdded:Connect(function(char)
		shutDownEverything()
		character = char
		monitorOccupied(char)
	end)
end
