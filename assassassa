	updateSlider(initialPos)
	
	slider.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			updateSliderFromInput(input)
		end
	end)
	
	slider.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if dragging then
			updateSliderFromInput(input)
		end
	end)
	
	
	if wipButton then
		wipButton.MouseButton1Down:Connect(function()
			hitboxActive = not hitboxActive
			if hitboxActive then
				wipButton.BackgroundColor3 = Color3.fromRGB(51, 255, 47)
			else
				wipButton.BackgroundColor3 = Color3.fromRGB(255, 11, 0)
			end
			updateHitboxes()
		end)
	end
	
	
	local function setupPlayer(player)
		player.CharacterAdded:Connect(function(char)
			-- Apply size immediately
			applyHitboxToCharacter(char)
	
			-- Listen for death to optionally reset
			local humanoid = char:WaitForChild("Humanoid")
			humanoid.Died:Connect(function()
				local rootPart = char:FindFirstChild("HumanoidRootPart")
				if rootPart then
					rootPart.Size = Vector3.new(2, 2, 1) 
				end
			end)
		end)
	
		if player.Character then
			applyHitboxToCharacter(player.Character)
		end
	end
	
	Players.PlayerAdded:Connect(setupPlayer)
	for _, player in pairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then
			setupPlayer(player)
		end
	end
	
	LocalPlayer.CharacterAdded:Connect(function()
		applyHitboxToAllPlayers()
	end)
	
	RunService.RenderStepped:Connect(function()
		for _, player in pairs(Players:GetPlayers()) do
			if player ~= LocalPlayer and player.Character then
				local humanoid = player.Character:FindFirstChild("Humanoid")
				local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
				if humanoid and humanoid.Health > 0 and rootPart then
					rootPart.CanCollide = false
					if hitboxActive then
						rootPart.Size = Vector3.new(currentSize, currentSize, currentSize)
					end
				end
			end
		end
	end)
end
