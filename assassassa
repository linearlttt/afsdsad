	local currentHand = "RightHand"
	
	-- Class tracking variables
	local humanoid
	local character
	local stylesFolder
	local cachedRemote = nil
	local animationClassMap = {}
	local lastClass = nil
	
	-- =========================
	-- REMOTE & CLASS DETECT
	-- =========================
	local function getIdNumber(animation)
		if not animation or not animation.AnimationId then return nil end
		local id = animation.AnimationId:match("%d+")
		return id and tonumber(id)
	end
	
	local function scanStyles(folder, className)
		for _, child in pairs(folder:GetChildren()) do
			if child:IsA("Animation") then
				local id = getIdNumber(child)
				if id then
					animationClassMap[id] = className
				end
			elseif child:IsA("Folder") then
				scanStyles(child, className)
			end
		end
	end
	
	local function trackTrackClass(track)
		local id = getIdNumber(track.Animation)
		local className = id and animationClassMap[id]
		if className then
			lastClass = className
		end
	end
	
	-- =========================
	-- FORCE STATE VALUES FALSE
	-- =========================
	local function bypassStates(char)
		if not char then return end
		if char:GetAttribute("Knocked") ~= nil then char:SetAttribute("Knocked", false) end
		if char:GetAttribute("Occupied") ~= nil then char:SetAttribute("Occupied", false) end
	
		local knockedVal = char:FindFirstChild("Knocked")
		if knockedVal and knockedVal:IsA("ValueBase") then knockedVal.Value = false end
	
		local occupiedVal = char:FindFirstChild("Occupied")
		if occupiedVal and occupiedVal:IsA("ValueBase") then occupiedVal.Value = false end
	end
	
