	-- ==========================================
	local function safeDisconnect(key: string)
		if Janitor.Connections[key] then
			Janitor.Connections[key]:Disconnect()
			Janitor.Connections[key] = nil
		end
	end
	
	local function getInputPosition(input: InputObject): number
		return input.Position.X
	end
	
	local function updateSlider(pos: number)
		if not wipEnabled then return end 
	
		-- Smoothly move the bar fill
		local tweenInfo = TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
		TweenService:Create(slideFrame, tweenInfo, {Size = UDim2.new(pos, 0, 1, 0)}):Play()
	
		-- Always purely manual adjustments
		local calculatedDelay = math.floor((MIN_VALUE + (pos * (MAX_VALUE - MIN_VALUE))) * 100) / 100 
		amountValue.Text = string.format("%.2fs Delay", calculatedDelay)
		Config.DelayDuration = calculatedDelay
	end
	
	-- FIX: Changed to look inside YOUR character, since clients can't pull remotes from other players' characters this way
	local function getLocalRemote(): RemoteEvent?
		local myChar = LocalPlayer.Character
		local core = myChar and myChar:FindFirstChild("Core")
		local comm = core and core:FindFirstChild("Communicate")
		return comm and comm:FindFirstChildOfClass("RemoteEvent") :: RemoteEvent?
	end
	
	-- Find the nearest player character within MaxDistance
	local function getClosestEnemy(myRoot: BasePart): Model?
		local closestEnemyChar: Model? = nil
		local closestDist = Config.MaxDistance
	
		for _, enemy in ipairs(Players:GetPlayers()) do
			if enemy ~= LocalPlayer and enemy.Character then
				local enemyRoot = enemy.Character:FindFirstChild("HumanoidRootPart") :: BasePart?
				if enemyRoot then
					local dist = (myRoot.Position - enemyRoot.Position).Magnitude
					if dist < closestDist then
						closestDist = dist
						closestEnemyChar = enemy.Character
					end
				end
			end
		end
		return closestEnemyChar
	end
	
