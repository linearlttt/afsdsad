			local packet = {
				"Attack",
				{
					Point = targetRoot.Position,
					Combo = 5,
					Class = classStat.Value,
					IsKnockdown = false,
					Character = targetChar,
					Hit = hitPart,
					Limb = currentHand,
					Classs = "",
					Result = nil
				},
				false
			}
	
			attackRemote:FireServer(unpack(packet))
			attackRemote:FireServer("Swing", { Limb = currentHand })
			currentHand = nextHand
		end
	end
	
	local mainConnection = nil
	
	local function startMainLoop()
		if mainConnection then return end 
		isRunning = true
		updateFriendCache() 
	
		mainConnection = runService.Heartbeat:Connect(function()
			local character = localPlayer.Character
			local myRoot = character and character:FindFirstChild("HumanoidRootPart")
			if not myRoot or not hasWeapon() then return end
	
			local targetPlayer = nil
	
			if lockedTargetPlayer and lockedTargetPlayer.Character then
				local enemyRoot = lockedTargetPlayer.Character:FindFirstChild("HumanoidRootPart")
				local enemyHum = lockedTargetPlayer.Character:FindFirstChildOfClass("Humanoid")
	
				if enemyRoot and enemyHum and enemyHum.Health > 0 then
					targetPlayer = lockedTargetPlayer
				else
					lockedTargetPlayer = nil 
				end
			end
	
			if not targetPlayer then
				for _, p in pairs(playersService:GetPlayers()) do
					if p ~= localPlayer and p.Character then
						local enemyRoot = p.Character:FindFirstChild("HumanoidRootPart")
						local enemyHum = p.Character:FindFirstChildOfClass("Humanoid")
	
						if enemyRoot and enemyHum and enemyHum.Health > 0 and friendCache[p.UserId] then
							local dist = (myRoot.Position - enemyRoot.Position).Magnitude
							if dist <= maxDistance then
								targetPlayer = p
								lockedTargetPlayer = p 
								break 
							end
						end
					end
				end
			end
	
			if targetPlayer and targetPlayer.Character then
				local enemyRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
				if enemyRoot then
					zeroVelocity(myRoot)
					myRoot.CFrame = CFrame.new(enemyRoot.Position.X, myRoot.Position.Y, enemyRoot.Position.Z)
	
					local currentTime = os.clock()
					if currentTime - lastAttackTime >= loopSpeed then
						lastAttackTime = currentTime
						fireAttackRemote(targetPlayer.Character, enemyRoot)
					end
				end
			end
		end)
	end
	
	local function stopMainLoop()
		isRunning = false
		lockedTargetPlayer = nil
		if mainConnection then
			mainConnection:Disconnect()
			mainConnection = nil
		end
	end
	
	if toggleBtn then
		toggleBtn.MouseButton1Click:Connect(function()
			toggleState = not toggleState
			if toggleState then
				toggleBtn.BackgroundColor3 = Color3.fromRGB(51, 255, 47)
				startMainLoop()
			else
				toggleBtn.BackgroundColor3 = Color3.fromRGB(255, 11, 0)
				stopMainLoop()
			end
		end)
	end
