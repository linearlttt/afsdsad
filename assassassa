			},
			false
		}
		remote:FireServer(unpack(args))
		remote:FireServer("Swing", { Limb = "LeftHand" })
	end
	
	-- SLAM ATTACK LOGIC
	local function slamTarget(target)
		updateCurrentClass()
		local remote = getRemote()
		-- STRICT MODE ENFORCEMENT: Added explicit check for "Blatant" mode
		if not remote or not target or not target.Character or currentMode ~= "Blatant" then return end
	
		local tChar = target.Character
		local torsoPart = tChar:FindFirstChild("UpperTorso") or tChar:FindFirstChild("Torso")
