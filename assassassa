	-- Services
	local Players = game:GetService("Players")
	local UIS = game:GetService("UserInputService")
	local RunService = game:GetService("RunService")
	
	local player = Players.LocalPlayer
	
	-- UI Elements
	local slider = script.Parent
	local slideFrame = slider:WaitForChild("slideFrame")
	local amountValue = slider:WaitForChild("amountValue")
	local parentRoot = slider.Parent.Parent
	local wipButton = parentRoot:FindFirstChild("WipButton")
	
	-- Settings
	local maxDistance = 10000
	local attacking = false
	local currentHand = "RightHand"
	local wipEnabled = false
	local currentTarget = nil
	local dragging = false
	local hitPartsList = { "Head" }
	local minHealth = 1
	local maxHealth = 100
	local attackHealthThreshold = maxHealth
	local attackInterval = 0.17
	local lastAttackTime = 0
	local PREDICTION_FACTOR = 1
	
	-- Character / Class
	local humanoid
	local character
	local lastClass = nil
	
	-- =========================
	-- Leaderstats Class Checker
	-- =========================
	local classValue = player:WaitForChild("leaderstats"):WaitForChild("Class")
	local function updateClass()
		lastClass = classValue.Value
	end
	
	-- =========================
	-- Utility Functions
	-- =========================
	local function isFightEquipped()
		local tool = character and character:FindFirstChildOfClass("Tool")
		return tool and tool.Name == "Fight"
	end
	
	local function getRemote()
		if not character then return end
		local core = character:WaitForChild("Core")
		local comm = core:WaitForChild("Communicate")
		for _, v in pairs(comm:GetChildren()) do
			if v:IsA("RemoteEvent") then
				return v
			end
		end
	end
	
	local function predictPosition(hrp)
		return hrp.Position + (hrp.Velocity * attackInterval * PREDICTION_FACTOR)
	end
	
	local function getClosest()
		if not character then return end
		local hrp = character:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
	
		local closest, dist = nil, math.huge
		for _, plr in pairs(Players:GetPlayers()) do
			if plr ~= player and plr.Character then
				local targetHRP = plr.Character:FindFirstChild("HumanoidRootPart")
				local humanoid = plr.Character:FindFirstChildOfClass("Humanoid")
				if targetHRP and humanoid and humanoid.Health > 0 and humanoid.Health <= attackHealthThreshold then
					local d = (hrp.Position - targetHRP.Position).Magnitude
					if d < dist and d <= maxDistance then
						dist = d
						closest = plr
					end
				end
			end
		end
		currentTarget = closest
		return currentTarget
	end
	
	local function stabilizeCharacter(hrp)
		if not hrp then return end
		hrp.Velocity = Vector3.new(0,0,0)
		hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
		hrp.AssemblyAngularVelocity = Vector3.new(0,0,0)
	end
	
	local function performAttack()
		if not character then return end
		updateClass() -- always get class from leaderstats
		if not lastClass then return end
	
		local remote = getRemote()
		if not remote then return end
	
		local target = getClosest()
		if not target or not target.Character then return end
	
		local tChar = target.Character
		local hrp = tChar:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
	
		local offHand = (currentHand == "RightHand") and "LeftHand" or "RightHand"
	
		for _, partName in pairs(hitPartsList) do
			local hitPart = tChar:FindFirstChild(partName) or hrp
			local args = {
				"Attack",
				{
					Point = predictPosition(hrp),
					Combo = 5,
					Class = lastClass, 
					IsKnockdown = false,
					Character = tChar,
					Hit = hitPart,
					Limb = currentHand,
					Result = nil
				},
				false
			}
	
			remote:FireServer(unpack(args))
			remote:FireServer("Swing", { Limb = currentHand })
			currentHand = offHand
		end
	end
	
	-- =========================
	-- Movement Loop
	-- =========================
	local moveConnection
	local function startMovementLoop()
		if moveConnection then return end
		moveConnection = RunService.Heartbeat:Connect(function()
			pcall(function()
				if not attacking or not character then return end
				if not isFightEquipped() then return end
	
				local hrp = character:FindFirstChild("HumanoidRootPart")
				local target = getClosest()
				if hrp then
					if target and target.Character then
						local tHRP = target.Character:FindFirstChild("HumanoidRootPart")
						if tHRP then
							stabilizeCharacter(hrp)
							hrp.CFrame = CFrame.new(predictPosition(tHRP) + Vector3.new(0, -1, 2))
						end
					else
						local spawn = player.RespawnLocation or workspace:FindFirstChild("SpawnLocation")
						if spawn then
							hrp.CFrame = spawn.CFrame + Vector3.new(0, 3, 0)
						end
					end
				end
			end)
		end)
	end
	
	local function stopMovementLoop()
		if moveConnection then
			moveConnection:Disconnect()
			moveConnection = nil
		end
	end
	
	-- =========================
	-- Attack Loop
	-- =========================
	local function startLoop()
		if attacking then return end
		attacking = true
		startMovementLoop()
		lastAttackTime = tick() - attackInterval
	
		task.spawn(function()
			while attacking do
				local now = tick()
				if now - lastAttackTime >= attackInterval then
					local target = getClosest()
					if target and target.Character then
						local humanoid = target.Character:FindFirstChildOfClass("Humanoid")
						if humanoid and humanoid.Health > 0 then
							performAttack()
						end
					end
					lastAttackTime = now
				end
				task.wait(0.01)
			end
		end)
	end
	
	local function stopLoop()
		attacking = false
		currentTarget = nil
		stopMovementLoop()
		if character then
			local hrp = character:FindFirstChild("HumanoidRootPart")
			if hrp then
				local spawn = player.RespawnLocation or workspace:FindFirstChild("SpawnLocation")
				if spawn then
					hrp.CFrame = spawn.CFrame + Vector3.new(0, 3, 0)
				end
			end
		end
	end
	
	-- =========================
	-- Slider
	-- =========================
	local function updateSlider(pos)
		slideFrame:TweenSize(
			UDim2.new(pos, 0, 1, 0),
			Enum.EasingDirection.Out,
			Enum.EasingStyle.Quad,
			0.1,
			true
		)
		local healthThreshold = math.floor(minHealth + pos * (maxHealth - minHealth))
		amountValue.Text = tostring(healthThreshold)
		attackHealthThreshold = healthThreshold
	end
	
	local function updateSliderFromMouse()
		local pos = math.clamp((UIS:GetMouseLocation().X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
		updateSlider(pos)
	end
	
	slider.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			updateSliderFromMouse()
		end
	end)
	
	slider.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			updateSliderFromMouse()
		end
	end)
	
	-- =========================
	-- WIP Button
	-- =========================
	if wipButton then
		wipButton.MouseButton1Down:Connect(function()
			wipEnabled = not wipEnabled
			if wipEnabled then
				wipButton.BackgroundColor3 = Color3.fromRGB(51, 255, 47)
				startLoop()
			else
				wipButton.BackgroundColor3 = Color3.fromRGB(255, 11, 0)
				stopLoop()
			end
		end)
	end
	
	-- =========================
	-- Character Handling
	-- =========================
	local function onCharacterAdded(char)
		character = char
		humanoid = character:WaitForChild("Humanoid")
	end
	
	onCharacterAdded(player.Character or player.CharacterAdded:Wait())
	player.CharacterAdded:Connect(onCharacterAdded)
end
