		task.defer(updateClassFromAnimation)
	end
	
	onCharacterAdded(LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait())
	LocalPlayer.CharacterAdded:Connect(onCharacterAdded)
	
	local function getRemote()
		if not character then return end
		local core = character:WaitForChild("Core")
		local comm = core:WaitForChild("Communicate")
		for _, v in pairs(comm:GetChildren()) do
			if v:IsA("RemoteEvent") then
				return v
			end
		end
	end
	
	local function getClosestPlayer(maxDistance)
		local hrp = character:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
	
		local closest, dist = nil, math.huge
		for _, plr in pairs(Players:GetPlayers()) do
			if plr ~= LocalPlayer and plr.Character then
				local targetHRP = plr.Character:FindFirstChild("HumanoidRootPart")
				local humanoid = plr.Character:FindFirstChildOfClass("Humanoid")
				if targetHRP and humanoid and humanoid.Health > 0 then
					local d = (hrp.Position - targetHRP.Position).Magnitude
					if d < dist and d <= maxDistance then
						dist = d
						closest = plr
					end
				end
			end
		end
		return closest
	end
	
	-- =========================
	-- ATTACK FUNCTIONS
	-- =========================
	local function grab()
		local remote = getRemote()
		if not remote then return end
		local args = { "Grab" }
		remote:FireServer(unpack(args))
	end
	
	local function slam()
		local remote = getRemote()
		if not remote then return end
		local target = getClosestPlayer(15) -- Only within 15 studs
		if not target or not target.Character then return end
	
		local tChar = target.Character
		local hrp = tChar:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
	
		local hitPart = tChar:FindFirstChild("LeftUpperArm") or hrp
	
		local args = {
			"Slam",
			{
				Character = tChar,
				Point = hrp.Position,
				Hit = hitPart,
				Limb = "",
				Class = lastClass,
				Result = nil
			}
		}
	
		remote:FireServer(unpack(args))
	end
	
	-- =========================
	-- LOOP (Grab → Slam only if a player is within 15 studs)
	-- =========================
	local function startAttackLoop()
		if attacking then return end
		attacking = true
		task.spawn(function()
			while attacking do
				local target = getClosestPlayer(15)
				if target then
					grab()
					task.wait(attackDelay)
					slam()
					task.wait(attackDelay)
				else
					task.wait(0.1) -- small wait to prevent spamming when no players nearby
				end
			end
		end)
	end
	
	local function stopAttackLoop()
		attacking = false
	end
	
	-- =========================
	-- SLIDER
	-- =========================
	local function updateSlider(pos)
		local delay = MIN_DELAY + pos * (MAX_DELAY - MIN_DELAY)
		attackDelay = delay
		amountValue.Text = string.format("%.2f", delay)
		slideFrame:TweenSize(
			UDim2.new(pos, 0, 1, 0),
			Enum.EasingDirection.Out,
			Enum.EasingStyle.Quad,
			0.1,
			true
		)
	end
	
	local function updateSliderFromInput(input)
		local inputPos
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			inputPos = input.Position.X
		else
			return
		end
		local pos = math.clamp((inputPos - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
		updateSlider(pos)
	end
	
	local initialPos = (attackDelay - MIN_DELAY) / (MAX_DELAY - MIN_DELAY)
	updateSlider(initialPos)
	
	slider.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			updateSliderFromInput(input)
		end
	end)
	
	slider.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if dragging then
			updateSliderFromInput(input)
		end
	end)
	
	-- =========================
	-- WIP BUTTON
	-- =========================
	if wipButton then
		wipButton.MouseButton1Down:Connect(function()
			if attacking then
				stopAttackLoop()
				wipButton.BackgroundColor3 = Color3.fromRGB(255,11,0)
			else
				startAttackLoop()
				wipButton.BackgroundColor3 = Color3.fromRGB(51,255,47)
			end
		end)
	end
end
