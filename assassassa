			shutDownEverything()
		end
	end)
	
	player.CharacterAdded:Connect(function(char)
		if moveConnection then
			moveConnection:Disconnect()
			moveConnection = nil
		end
		tracking = false
		currentTarget = nil
		originalCFrame = nil
		isResetting = false
	
		updateButtonVisuals()
	
		character = char
		humanoid = char:WaitForChild("Humanoid")
		handleCharacterParenting(char)
	end)
