unction trackPlayerAnimations(enemyPlayer: Player)
		if not enemyPlayer or Janitor.TrackingPlayers[enemyPlayer] then return end
	
		local playerJanitor = {}
		Janitor.TrackingPlayers[enemyPlayer] = playerJanitor
		local enemyName = enemyPlayer.Name 
	
		local function onCharacterAdded(char: Model)
			if not char then return end
	
			local humanoid = char:WaitForChild("Humanoid", 5) :: Humanoid?
			local animator = humanoid and humanoid:WaitForChild("Animator", 5) :: Animator?
	
			if not animator then return end
	
			-- Keeps track of the current running thread token globally across animation changes
			local currentWeaveId = 0
	
			local function handleTrack(track: AnimationTrack)
				if not wipEnabled then return end
	
				if not LocalPlayer or not LocalPlayer.Character then return end
				local myChar = LocalPlayer.Character
	
				local myRoot = myChar:FindFirstChild("HumanoidRootPart") :: BasePart?
				local enemyRoot = char:FindFirstChild("HumanoidRootPart") :: BasePart?
				local hasWeapon = char:FindFirstChild("Fight")
	
				if not myRoot or not enemyRoot or not hasWeapon then return end
				if (myRoot.Position - enemyRoot.Position).Magnitude > Config.MaxDistance then return end
	
				local animId = track.Animation and track.Animation.AnimationId
				if not animId then return end
	
				-- Instantly increment to invalidate and kill any previous loop running from an old animation
				currentWeaveId += 1
				local weaveId = currentWeaveId
	
				Config.WeaveInterval = track.Speed
				isAutoTracking = true
				dragging = false
				amountValue.Text = string.format("%.2f (Locked: %s)", track.Speed, enemyName)
	
				local visualRatio = math.clamp((track.Speed - MIN_VALUE) / (MAX_VALUE - MIN_VALUE), 0, 1)
				TweenService:Create(
					slideFrame,
					TweenInfo.new(0.15, Enum.EasingStyle.Quad),
					{Size = UDim2.new(visualRatio, 0, 1, 0)}
				):Play()
	
				task.spawn(function()
					local remote = getEnemyRemote(char)
					if not remote then return end
	
					-- Front-load bursting: Ensures instantly active response before the loop scheduler catches up
					for _ = 1, 8 do
						triggerWeave(remote)
					end
	
					local startTime = os.clock()
	
					-- PERFORMANCE FIX: Replaced task.wait() with a frame-perfect loop logic 
					-- to guarantee instant execution when rapidly swapping animations
					while
						weaveId == currentWeaveId
						and wipEnabled
						and char:IsDescendantOf(workspace)
						and (os.clock() - startTime < Config.WeaveDuration)
					do
						triggerWeave(remote)
	
						-- Fallback to native engine scheduler rate limits rather than task.wait throttling
						RunService.Heartbeat:Wait() 
					end
	
					if weaveId == currentWeaveId then
						isAutoTracking = false
						if wipEnabled then
							amountValue.Text = string.format("%.2f (Ready)", Config.WeaveInterval)
						end
					end
				end)
			end
	
			playerJanitor.AnimationHook = animator.AnimationPlayed:Connect(handleTrack)
	
			for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
				task.spawn(handleTrack, track)
			end
		end
	
		if enemyPlayer.Character then 
			task.spawn(onCharacterAdded, enemyPlayer.Character) 
		end
	
		playerJanitor.CharAddedHook = enemyPlayer.CharacterAdded:Connect(onCharacterAdded)
	end
	
	local function untrackPlayer(enemyPlayer: Player)
		local pJanitor = Janitor.TrackingPlayers[enemyPlayer]
		if pJanitor then
			if pJanitor.AnimationHook then pJanitor.AnimationHook:Disconnect() end
			if pJanitor.CharAddedHook then pJanitor.CharAddedHook:Disconnect() end
			Janitor.TrackingPlayers[enemyPlayer] = nil
		end
	end
	
	-- ==========================================
	-- LIFECYCLE MANAGEMENT
	-- ==========================================
	local function unloadMechanics()
		for key, _ in pairs(Janitor.Connections) do
			safeDisconnect(key)
		end
		for player, _ in pairs(Janitor.TrackingPlayers) do
			untrackPlayer(player)
		end
	end
	
	local function loadMechanics()
		unloadMechanics() 
	
		Janitor.Connections.SliderBegan = slider.InputBegan:Connect(function(input)
			if isAutoTracking then return end 
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = true
				local pos = math.clamp((getInputPosition(input) - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
				updateSlider(pos)
			end
		end)
	
		Janitor.Connections.SliderEnded = slider.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = false
			end
		end)
	
		Janitor.Connections.SliderChanged = UIS.InputChanged:Connect(function(input)
			if isAutoTracking then dragging = false return end 
			if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				local pos = math.clamp((getInputPosition(input) - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
				updateSlider(pos)
			end
		end)
	
		for _, player in ipairs(Players:GetPlayers()) do
			if player ~= LocalPlayer then
				trackPlayerAnimations(player)
			end
		end
	
		Janitor.Connections.PlayerJoined = Players.PlayerAdded:Connect(function(player)
			if player ~= LocalPlayer then
				trackPlayerAnimations(player)
			end
		end)
	
		Janitor.Connections.PlayerLeaving = Players.PlayerRemoving:Connect(function(player)
			untrackPlayer(player)
		end)
	end
	
	-- ==========================================
	-- INTERFACE INTERACTION SETUP
	-- ==========================================
	if wipButton then
		wipButton.MouseButton1Click:Connect(function()
			wipEnabled = not wipEnabled
			Config.WeaveEnabled = wipEnabled
	
			local targetColor = wipEnabled and Color3.fromRGB(51, 255, 47) or Color3.fromRGB(255, 11, 0)
			TweenService:Create(wipButton, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {BackgroundColor3 = targetColor}):Play()
	
			if wipEnabled then
				loadMechanics()
				amountValue.Text = "Scanning..."
			else
				unloadMechanics()
				isAutoTracking = false
				dragging = false
				amountValue.Text = "0.00 (Off)"
				TweenService:Create(slideFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {Size = UDim2.new(0, 0, 1, 0)}):Play()
			end
		end)
	end
end
