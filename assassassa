					local throwableRemote = remotesFolder and remotesFolder:FindFirstChild("ThrowableRemote")
	
					if commRemote and throwableRemote then
						local item = ItemCycle[CurrentIndex]
	
						local clickDetector = sourceChar:FindFirstChildWhichIsA("ClickDetector", true)
						if clickDetector then safeFireClick(clickDetector) end
	
