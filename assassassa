local function ASBNCVQ_fake_script() -- OutlastHubNormalPremium_2.AutoHitAll.LocalScript 
	local script = Instance.new('LocalScript', OutlastHubNormalPremium_2.AutoHitAll)

	local Players = game:GetService("Players")
	
	local player = Players.LocalPlayer
	local button = script.Parent:WaitForChild("WipButton")
	
	local onColor = Color3.fromRGB(51, 255, 47)
	local offColor = Color3.fromRGB(255, 0, 0)
	button.BackgroundColor3 = offColor
	
	-- CONFIGURATION
	local ATTACK_DELAY = 0.19 -- Delay between firing sequences
	local currentHand = "RightHand"
	
	local classValue = player:WaitForChild("leaderstats"):WaitForChild("Class")
	
	local function getCurrentClass()
		return classValue.Value
	end
	
	-- Find the interaction remote inside a specific character
	local function getRemote(targetChar)
		if not targetChar then return nil end
		local core = targetChar:FindFirstChild("Core")
		local comm = core and core:FindFirstChild("Communicate")
		if not comm then return nil end
	
		for _, v in ipairs(comm:GetChildren()) do
			if v:IsA("RemoteEvent") then
				return v
			end
		end
		return nil
	end
	
	local function hasHighlight(plr)
		if not plr or not plr.Character then
			return false
		end
		for _, obj in ipairs(plr.Character:GetDescendants()) do
			if obj:IsA("Highlight") then
				return true
			end
		end
		return false
	end
	
	-- FRIEND PROTECTION CACHE
	local friendIds = {}
	local friendsLoaded = false
	
	task.spawn(function()
		local success, friends = pcall(function()
			return player:GetFriendsAsync()
		end)
		if success then
			for _, info in pairs(friends:GetCurrentPage()) do
				friendIds[info.Id] = true
			end
		end
		friendsLoaded = true
	end)
	
	local function isFriend(plr)
		if not plr then return true end
		if friendIds[plr.UserId] == true then return true end
	
		local success, result = pcall(function()
			return player:IsFriendsWith(plr.UserId)
		end)
		if success and result then
			friendIds[plr.UserId] = true
			return true
		end
	
		return false
	end
	
	local eligiblePlayers = {}
	
	local function updateEligiblePlayer(plr)
		if plr == player or isFriend(plr) then
			eligiblePlayers[plr] = nil
			return
		end
	
		if plr.Character then
			local upperTorso = plr.Character:FindFirstChild("UpperTorso") or plr.Character:FindFirstChild("Torso")
	
			if upperTorso then
				if hasHighlight(plr) then
					eligiblePlayers[plr] = nil
					return
				end
				eligiblePlayers[plr] = true
			else
				eligiblePlayers[plr] = nil
			end
		else
			eligiblePlayers[plr] = nil
		end
	end
	
	-- TRACKERS
	Players.PlayerAdded:Connect(function(plr)
		plr.CharacterAdded:Connect(function()
			task.wait(0.5)
			updateEligiblePlayer(plr)
		end)
	end)
	
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player then
			if plr.Character then updateEligiblePlayer(plr) end
			plr.CharacterAdded:Connect(function()
				task.wait(0.5)
				updateEligiblePlayer(plr)
			end)
		end
	end
	
	local function performAttack(target, myClass, offHand)
		local tChar = target.Character
		local targetPart = tChar:FindFirstChild("Head")
		if not targetPart then return end
	
		-- Grab the victim's own remote channel
		local remote = getRemote(tChar)
		if not remote then return end
	
		-- The arguments configure the target as BOTH the attacker and the victim
		local args = {
			"Attack",
			{
				Point = targetPart.Position, 
				Combo = math.random(1, 4),
				Class = myClass,
				IsKnockdown = true,
				Character = tChar, 
				Hit = targetPart,
				Limb = currentHand,
				Result = nil
			},
			false
		}
	
		remote:FireServer(unpack(args))
		remote:FireServer("Swing", { Limb = offHand })
	end
	
	local Toggle = false
	local loopRunning = false
	
	button.MouseButton1Click:Connect(function()
		Toggle = not Toggle
		button.BackgroundColor3 = Toggle and onColor or offColor
	
		if Toggle and not loopRunning then
			loopRunning = true
	
			task.spawn(function()
				local lastAttackTime = 0
	
				while Toggle do
					if not friendsLoaded then 
						task.wait()
						continue 
					end
	
					local now = tick()
					if now - lastAttackTime >= ATTACK_DELAY then
						local allPlayers = Players:GetPlayers()
						local myClass = getCurrentClass()
						local offHand = (currentHand == "RightHand") and "LeftHand" or "RightHand"
	
						-- Loop through every player in the server instantly
						for i = 1, #allPlayers do
							local target = allPlayers[i]
	
							-- Update status and check eligibility
							updateEligiblePlayer(target)
	
							if eligiblePlayers[target] and target.Character and not isFriend(target) then
								performAttack(target, myClass, offHand)
							end
						end
	
						currentHand = offHand
						lastAttackTime = now
					end
	
					task.wait()
				end
				loopRunning = false
			end)
		else
			Toggle = false
		end
	end)
end
