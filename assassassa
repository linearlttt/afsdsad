	local amountValue = slider:WaitForChild("amountValue")
	
	local MIN_VALUE = 0
	local MAX_VALUE = 1
	local currentValue = MIN_VALUE
	local dragging = false
	local wipEnabled = false -- will be toggled by button
	
	local function updateSlider(pos)
		if not wipEnabled then return end -- only update if WipButton is enabled
	
		-- Update slider UI
		slideFrame:TweenSize(
			UDim2.new(pos, 0, 1, 0),
			Enum.EasingDirection.Out,
			Enum.EasingStyle.Quad,
			0.1,
			true
		)
	
		-- Update current value
		currentValue = MIN_VALUE + (pos * (MAX_VALUE - MIN_VALUE))
		currentValue = math.floor(currentValue * 100) / 100 -- round to 2 decimals
		amountValue.Text = tostring(currentValue)
	
		-- Update the global interval to reflect slider value
		_G.WeaveInterval = currentValue
	end
	
	local function getInputPosition(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement 
			or input.UserInputType == Enum.UserInputType.MouseButton1 
			or input.UserInputType == Enum.UserInputType.Touch then
			return input.Position.X
		end
	end
	
	-- =========================
	-- Slider input handling
	-- =========================
	slider.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			-- tap-to-set
			local pos = math.clamp((getInputPosition(input) - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
			updateSlider(pos)
		end
	end)
	
	slider.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local pos = math.clamp((getInputPosition(input) - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
			updateSlider(pos)
		end
	end)
	
	_G.WeaveEnabled = false
	_G.WeaveInterval = currentValue
	_G.MicroInterval = 0
	_G._t = 0
	local parentRoot = slider.Parent.Parent
	local wipButton = parentRoot:FindFirstChild("WipButton")
	
	if wipButton then
		wipButton.MouseButton1Click:Connect(function()
			wipEnabled = not wipEnabled
			if wipEnabled then
				_G.WeaveEnabled = true
				wipButton.BackgroundColor3 = Color3.fromRGB(51, 255, 47)
			else
				_G.WeaveEnabled = false
				wipButton.BackgroundColor3 = Color3.fromRGB(255, 11, 0)
			end
		end)
	end
	
	
	
	local function getRemote()
		local char = LocalPlayer.Character
		if not char then return end
	
		local core = char:FindFirstChild("Core")
		if not core then return end
	
		local comm = core:FindFirstChild("Communicate")
		if not comm then return end
	
		for _, v in pairs(comm:GetChildren()) do
			if v:IsA("RemoteEvent") then
				return v
			end
		end
	end
	
	task.spawn(function()
		local last = os.clock()
	
		while true do
			task.wait()
	
			if not _G.WeaveEnabled then
				last = os.clock()
				_G._t = 0
				continue
			end
	
			local now = os.clock()
			local dt = now - last
			last = now
	
			_G._t += dt
	
			local interval = math.max(0, _G.WeaveInterval + _G.MicroInterval)
	
			if _G._t >= interval then
				_G._t -= interval
	
				local remote = getRemote()
				if remote then
					pcall(function()
						remote:FireServer("Weave", nil, true)
					end)
				end
			end
		end
	end)
