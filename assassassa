	local Players = game:GetService("Players")
	local TweenService = game:GetService("TweenService")
	local UserInputService = game:GetService("UserInputService")
	
	local player = Players.LocalPlayer
	
	local parentRoot = script.Parent
	local wipButton = parentRoot:FindFirstChild("WipButton")
	local dropdown = parentRoot:FindFirstChild("DropDownFrame")
	
	local attacking = false
	local characterAddedConnection = nil
	local selectedWeapon = nil
	
	local weaponMap = {
		Bat = "Bat",
		Gloves = "Boxing Gloves",
		Sneakers = "Sneakers"
	}
	
	local function buyWeapon(weaponName)
		if not weaponName then return end
	
		local args = {
			"BuyWeapon",
			weaponName
		}
	
		local communicate = player:WaitForChild("Communicate", 5)
		if not communicate then return end
		local interface = communicate:WaitForChild("Interface", 5)
		if not interface then return end
		local remote = interface:WaitForChild("RemoteEvent", 5)
	
		if remote then
			remote:FireServer(unpack(args))
		end
	end
	
	local function setDropdown(state)
		if not dropdown then return end
	
		if state then
			dropdown.Visible = true
			dropdown.BackgroundTransparency = 1
	
			dropdown.Position = UDim2.new(
				dropdown.Position.X.Scale,
				dropdown.Position.X.Offset,
				0.4, 0
			)
	
			TweenService:Create(dropdown, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
				Position = UDim2.new(
					dropdown.Position.X.Scale,
					dropdown.Position.X.Offset,
					0.5, 0
				),
				BackgroundTransparency = 0
			}):Play()
	
			for _, v in ipairs(dropdown:GetDescendants()) do
				if v:IsA("TextButton") or v:IsA("TextLabel") then
					v.TextTransparency = 1
					TweenService:Create(v, TweenInfo.new(0.2), {
						TextTransparency = 0
					}):Play()
				end
			end
		else
			local tween = TweenService:Create(dropdown, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
				Position = UDim2.new(
					dropdown.Position.X.Scale,
					dropdown.Position.X.Offset,
					0.4, 0
				),
				BackgroundTransparency = 1
			})
	
			tween:Play()
	
			for _, v in ipairs(dropdown:GetDescendants()) do
				if v:IsA("TextButton") or v:IsA("TextLabel") then
					TweenService:Create(v, TweenInfo.new(0.15), {
						TextTransparency = 1
					}):Play()
				end
			end
	
			tween.Completed:Connect(function()
				if not attacking or selectedWeapon then
					dropdown.Visible = false
				end
			end)
		end
	end
	
	if dropdown then
		dropdown.Visible = false
		dropdown.BackgroundTransparency = 1
	end
	
	local function hookDropdownButtons()
		if not dropdown then return end
	
		for _, button in ipairs(dropdown:GetChildren()) do
			if button:IsA("TextButton") then
				local weapon = weaponMap[button.Name]
	
				if weapon then
					button.MouseButton1Click:Connect(function()
						selectedWeapon = weapon
						buyWeapon(weapon)
						setDropdown(false)
					end)
				end
			end
		end
	end
	
	hookDropdownButtons()
	
	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then return end
		if not dropdown or not dropdown.Visible then return end
	
		if input.UserInputType ~= Enum.UserInputType.MouseButton1
			and input.UserInputType ~= Enum.UserInputType.Touch then
			return
		end
	
		local pos = UserInputService:GetMouseLocation()
		local guiObjects = UserInputService:GetGuiObjectsAtPosition(pos.X, pos.Y)
	
		for _, obj in ipairs(guiObjects) do
			if obj:IsDescendantOf(dropdown) or obj == wipButton then
				return
			end
		end
	
		setDropdown(false)
	end)
	
	local function setupCharacterAutofire()
		if characterAddedConnection then
			characterAddedConnection:Disconnect()
		end
	
		characterAddedConnection = player.CharacterAdded:Connect(function()
			task.wait(0.5) 
	
			if attacking and selectedWeapon then
				buyWeapon(selectedWeapon)
			end
		end)
	end
	
	wipButton.MouseButton1Click:Connect(function()
		attacking = not attacking
	
		if attacking then
			wipButton.BackgroundColor3 = Color3.fromRGB(51, 255, 47)
			setDropdown(true)
			setupCharacterAutofire()
	
			if selectedWeapon then
				buyWeapon(selectedWeapon)
			end
		else
			wipButton.BackgroundColor3 = Color3.fromRGB(255, 11, 0)
			setDropdown(false)
			selectedWeapon = nil
	
			if characterAddedConnection then
				characterAddedConnection:Disconnect()
				characterAddedConnection = nil
			end
		end
	end)
end
