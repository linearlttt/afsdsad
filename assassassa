		)
	
		-- Update current value
		currentValue = MIN_VALUE + (pos * (MAX_VALUE - MIN_VALUE))
		currentValue = math.floor(currentValue * 100) / 100 -- round to 2 decimals
		amountValue.Text = tostring(currentValue)
	
		-- Update the global interval to reflect slider value
		_G.WeaveInterval = currentValue
	end
	
	local function getInputPosition(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement 
			or input.UserInputType == Enum.UserInputType.MouseButton1 
			or input.UserInputType == Enum.UserInputType.Touch then
			return input.Position.X
		end
