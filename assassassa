	local ANIMATION_ID = "rbxassetid://72183601488494"
	
	-- 2. Create the Animation object
	local animation = Instance.new("Animation")
	animation.AnimationId = ANIMATION_ID
	
	-- Variable to store the currently playing animation track
	local currentTrack = nil
	local toolConnection = nil -- Stores the click listener for the tool
	
	-- Function to stop the animation if it's currently running
	local function stopAnimation()
		if currentTrack then
			currentTrack:Stop()
			currentTrack = nil
		end
	end
	
	-- Hook up the main button to PLAY the animation
	button.MouseButton1Click:Connect(function()
		local character = player.Character or player.CharacterAdded:Wait()
		local humanoid = character:FindFirstChildOfClass("Humanoid")
	
		if humanoid then
			-- Find or create the Animator object
			local animator = humanoid:FindFirstChildOfClass("Animator")
			if not animator then
				animator = Instance.new("Animator", humanoid)
			end
	
			-- STOP the previous animation if it is already playing
			stopAnimation()
	
			-- 3. Load and play the new animation
			currentTrack = animator:LoadAnimation(animation)
			currentTrack:Play()
		end
	end)
	
	-- Loop through all OTHER "idk" buttons and make them STOP the animation
	for _, otherButton in ipairs(parentFolder:GetChildren()) do
		-- Make sure it's named "idk" AND it is not the main button running this script
