						throwableRemote:FireServer("Impact", {Object = sourceChar, Type = item, Speed = IMPACT_SPEED, Part = sourceChar, HitPosition = sourceRoot.Position, GUID = HttpService:GenerateGUID(false)})
	
						performedAttack = true
					end
				end
			end
	
			if performedAttack then
				lastThrowTime = currentTime 
				CurrentIndex = (CurrentIndex % #ItemCycle) + 1
			end
		end)
	end
	
	-- UI Handling
	wipButton.MouseButton1Down:Connect(function()
		wipEnabled = not wipEnabled
		wipButton.BackgroundColor3 = wipEnabled and Color3.fromRGB(51, 255, 47) or Color3.fromRGB(255, 0, 0)
		if wipEnabled then 
			updateTargetUserIds()
			startThrowingLoop() 
		else 
			stopThrowing() 
		end
	end)
	
	textBox.FocusLost:Connect(function() 
		updateTargetUserIds()
		if wipEnabled then 
			startThrowingLoop()
		end 
