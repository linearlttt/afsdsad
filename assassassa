local function YICT_fake_script() -- OutlastHubNormalPremium_2.Frame_2.LocalScript 
	local script = Instance.new('LocalScript', OutlastHubNormalPremium_2.Frame_2)

	local dragger = {}
	local resizer = {}
	local frame = script.Parent
	
	local Players = game:GetService("Players")
	local UIS = game:GetService("UserInputService")
	local RunService = game:GetService("RunService")
	
	local player = Players.LocalPlayer
	
	-- =========================
	-- DRAGGER (Mouse & Touch Supported)
	-- =========================
	function dragger.new(frame)
		local dragging = false
		local startPos
		local startFramePos
		local heartbeatConnection
		local inputChangedConnection
		frame.Active = true
	
		frame.InputBegan:Connect(function(input)
			-- Listen for Mouse Click OR Mobile Touch
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = true
				startPos = input.Position
				startFramePos = frame.Position
	
				if heartbeatConnection then heartbeatConnection:Disconnect() end
				if inputChangedConnection then inputChangedConnection:Disconnect() end
	
				-- Track global input changes (supports both MouseMovement and Touch movement)
				local currentInput = input
				inputChangedConnection = UIS.InputChanged:Connect(function(changedInput)
					if changedInput.UserInputType == Enum.UserInputType.MouseMovement or changedInput.UserInputType == Enum.UserInputType.Touch then
						currentInput = changedInput
					end
				end)
	
				-- The main movement loop
				heartbeatConnection = RunService.Heartbeat:Connect(function()
					if dragging and currentInput then
						local delta = currentInput.Position - startPos
						frame.Position = UDim2.new(
							startFramePos.X.Scale,
							startFramePos.X.Offset + delta.X,
							startFramePos.Y.Scale,
							startFramePos.Y.Offset + delta.Y
						)
					else
						-- Clean up connections when done
						if heartbeatConnection then heartbeatConnection:Disconnect() heartbeatConnection = nil end
						if inputChangedConnection then inputChangedConnection:Disconnect() inputChangedConnection = nil end
					end
				end)
			end
		end)
	
		-- Global check for when the user releases the mouse or lifts their finger anywhere on screen
		UIS.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = false
			end
		end)
	end
	
	-- =========================
	-- RESIZER
	-- =========================
	function resizer.new(parent, frame)
		parent:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
			frame.Size = UDim2.new(
				frame.Size.X.Scale,
				frame.Size.X.Offset,
				frame.Size.Y.Scale,
				parent.AbsoluteSize.Y
			)
		end)
	end
	
	
	dragger.new(frame)
	frame.Draggable = false 
	
	UIS.InputBegan:Connect(function(input)
		if input.KeyCode == Enum.KeyCode.End then
			frame.Visible = not frame.Visible
		end
	end)
end
