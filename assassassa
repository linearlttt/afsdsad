	-- CONFIGURATION
	local LOOP_DELAY = 0.01 -- Quick delay for the shove loop execution
	local currentHand = "RightHand"
	
	local classValue = player:WaitForChild("leaderstats"):WaitForChild("Class")
	
	local function getCurrentClass()
		return classValue.Value
	end
	
	-- Find the interaction remote inside a specific character
	local function getRemote(targetChar)
		if not targetChar then return nil end
		local core = targetChar:FindFirstChild("Core")
		local comm = core and core:FindFirstChild("Communicate")
		if not comm then return nil end
	
		for _, v in ipairs(comm:GetChildren()) do
			if v:IsA("RemoteEvent") then
				return v
			end
		end
		return nil
	end
	
	-- FRIEND PROTECTION CACHE
	local friendIds = {}
	local friendsLoaded = false
	
	task.spawn(function()
		local success, friends = pcall(function()
			return player:GetFriendsAsync()
		end)
		if success then
			for _, info in pairs(friends:GetCurrentPage()) do
				friendIds[info.Id] = true
			end
		end
		friendsLoaded = true
	end)
	
	local function isFriend(plr)
		if not plr then return true end
		if friendIds[plr.UserId] == true then return true end
	
		local success, result = pcall(function()
			return player:IsFriendsWith(plr.UserId)
		end)
		if success and result then
			friendIds[plr.UserId] = true
			return true
		end
	
		return false
	end
	
	-- MASS SELF SHOVE EXECUTOR
	local function massSelfShove(myClass)
		local liveFolder = Workspace:FindFirstChild("Live")
		if not liveFolder then return end
	
		-- Loop through everyone inside Workspace.Live
		for _, character in ipairs(liveFolder:GetChildren()) do
			local targetPlr = Players:GetPlayerFromCharacter(character)
	
			-- Safety rules: Won't affect you or your friends
			if targetPlr and targetPlr ~= player and not isFriend(targetPlr) then
				local hrp = character:FindFirstChild("HumanoidRootPart")
				local commRemote = getRemote(character)
	
				if commRemote and hrp then
					local shoveArgs = {
						"Shove",
						{
							Character = character, -- Targets their own character
							Point = hrp.Position,
							Hit = hrp,
							Limb = currentHand, 
							Classs = myClass,
							Result = nil
						}
					}
					commRemote:FireServer(unpack(shoveArgs))
				end
			end
		end
	end
	
	local Toggle = false
	local loopRunning = false
	
	button.MouseButton1Click:Connect(function()
		Toggle = not Toggle
		button.BackgroundColor3 = Toggle and onColor or offColor
	
		if Toggle and not loopRunning then
			loopRunning = true
	
			task.spawn(function()
				while Toggle do
					if not friendsLoaded then 
						task.wait()
						continue 
					end
	
					local myClass = getCurrentClass()
	
					-- Force everyone in Workspace.Live to shove themselves
					pcall(massSelfShove, myClass)
	
					-- Alternates hands on each cycle loop
					currentHand = (currentHand == "RightHand") and "LeftHand" or "RightHand"
					task.wait(LOOP_DELAY)
				end
				loopRunning = false
			end)
		else
			Toggle = false
		end
	end)
end
