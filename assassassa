	local script = Instance.new('LocalScript', OutlastHubNormalPremium_2.AutoFarm)

	local Players = game:GetService("Players")
	
	local LP = Players.LocalPlayer
	local gui = script.Parent
	
	local pads = {
		Pad1 = Vector3.new(472, 39, 199),
		Pad2 = Vector3.new(471, 39, 208),
	}
	
	local stopPositions = {
		Vector3.new(497, 39, 215),
		Vector3.new(496, 39, 193)
	}
	
	local buttons = {
		Pad1 = gui:WaitForChild("Pad1"),
		Pad2 = gui:WaitForChild("Pad2"),
		AutoReset = gui:WaitForChild("AutoReset")
	}
	
	local lst = 0
	local lt = 0
	local td = 0
	local currentCharacter
	local running = false
	
	local function StartLoop()
		if running then return end
		running = true
	
		task.spawn(function()
			while running do
				task.wait()
	
				local char = LP.Character
				if not char then
					continue
				end
	
				-- FIX: When you get a completely new character (respawn), 
				-- we reset both the spawn time AND the teleport cooldown timer.
				if char ~= currentCharacter then
					currentCharacter = char
					lst = os.clock()
					lt = os.clock() -- Resets the teleport delay so it doesn't instantly TP you on spawn
				end
	
				local hrp = char:FindFirstChild("HumanoidRootPart")
				local hum = char:FindFirstChild("Humanoid")
				if not hrp or not hum or hum.Health <= 0 then
					continue
				end
	
				local now = os.clock()
				local position = hrp.Position
	
				local nearStopPos = false
	
				for _, pos in ipairs(stopPositions) do
					local diff = position - pos
					local distSq = diff:Dot(diff)
	
					if distSq <= 25 then -- 5 studs
						nearStopPos = true
					end
	
					if buttons.AutoReset:GetAttribute("Active")
						and now - lst >= 0.2
						and distSq <= 169 then -- 13 studs
						hum.Health = 0
						break
					end
				end
	
				if not nearStopPos and now - lt >= td then
					for name, pos in pairs(pads) do
						if buttons[name]:GetAttribute("Active") then
							hrp.CFrame = CFrame.new(pos)
							lt = now
							break
						end
					end
				end
	
				if not buttons.Pad1:GetAttribute("Active")
					and not buttons.Pad2:GetAttribute("Active")
					and not buttons.AutoReset:GetAttribute("Active") then
					running = false
				end
			end
		end)
	end
	
	for _, btn in pairs(buttons) do
		if btn:GetAttribute("Active") == nil then
			btn:SetAttribute("Active", false)
		end
	
		btn.BackgroundColor3 = btn:GetAttribute("Active")
			and Color3.fromRGB(51, 255, 47)
			or Color3.fromRGB(255, 0, 0)
	
		btn.MouseButton1Click:Connect(function()
			local active = not btn:GetAttribute("Active")
			btn:SetAttribute("Active", active)
	
			btn.BackgroundColor3 = active
				and Color3.fromRGB(51, 255, 47)
				or Color3.fromRGB(255, 0, 0)
	
			if active then
				StartLoop()
			end
		end)
	end
end
