local function AGTUM_fake_script() -- TargetHit.LocalScript 
	local script = Instance.new('LocalScript', TargetHit)

	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	local UIS = game:GetService("UserInputService")
	local Workspace = game:GetService("Workspace")
	
	local player = Players.LocalPlayer
	local character = player.Character or player.CharacterAdded:Wait()
	local humanoid = character:WaitForChild("Humanoid")
	local camera = Workspace.CurrentCamera 
	
	-- UI
	local parentRoot = script.Parent
	local textBox = parentRoot:FindFirstChild("TargetBox")
	local wipButton = parentRoot:FindFirstChild("WipButton")
	
	-- Config
	local attackDelay = 0.15
	local MAX_DISTANCE = 10000
	local PREDICTION_FACTOR = 1
	local MAX_PREDICT_SPEED = 60 -- Lowered to normal maximum character run speeds
	
	-- State
	local attacking = false
	local wipEnabled = false
	local currentTarget = nil
	local currentClass = nil
	local moveConnection = nil
	local animConnection = nil 
	local originalCFrame = nil 
	
	-- Class
	local leaderstats = player:WaitForChild("leaderstats", 5)
	local classValue = leaderstats and leaderstats:WaitForChild("Class", 5)
	
	local function updateCurrentClass()
		if classValue then
			currentClass = classValue.Value
		end
	end
	
	-- Ignore list
	local ignoreIDs = {
		[10712947750] = true,
	}
	
	-- CAMERA CONTROLLER
	local function resetCamera()
		camera.CameraSubject = player.Character:FindFirstChildOfClass("Humanoid") or player.Character
		camera.CameraType = Enum.CameraType.Custom
	end
	
	local function viewTarget(target)
		if target and target.Character then
			local tHum = target.Character:FindFirstChildOfClass("Humanoid")
			if tHum then
				camera.CameraSubject = tHum
			end
		else
			resetCamera()
		end
	end
	
	-- LIVE FOLDER & WORKSPACE HANDLER
	local function handleCharacterParenting(char)
		if not char then return end
		task.wait()
	
		local liveFolder = Workspace:FindFirstChild("Live")
		if liveFolder and char:IsDescendantOf(liveFolder) then
			char.Parent = Workspace
		end
	
		if char.Parent ~= Workspace then
			char.Parent = Workspace
		end
	end
	
	Workspace.DescendantAdded:Connect(function(descendant)
		if descendant == character then
			handleCharacterParenting(character)
		end
	end)
	
	handleCharacterParenting(character)
	
	local function getTargetsFromText(text)
		if not text or text == "" then return {} end
	
		local targets = {}
		local used = {}
	
		for name in string.gmatch(text, "([^,]+)") do
			name = name:lower():gsub("^%s+", ""):gsub("%s+$", "")
	
			for _, plr in ipairs(Players:GetPlayers()) do
				if plr ~= player and not ignoreIDs[plr.UserId] and not used[plr.UserId] then
					local uname = plr.Name:lower()
					local dname = plr.DisplayName:lower()
	
					if string.find(uname, name, 1, true) or string.find(dname, name, 1, true) then
						targets[#targets + 1] = plr
						used[plr.UserId] = true
					end
				end
			end
		end
	
		return targets
	end
	
	local function getClosest()
		if currentTarget and (not currentTarget.Parent or not currentTarget.Character) then
			currentTarget = nil
			resetCamera()
		end
	
		if currentTarget and currentTarget.Character then
			local hum = currentTarget.Character:FindFirstChildOfClass("Humanoid")
			if hum and hum.Health > 0 then
				return currentTarget
			end
		end
	
		local targets = getTargetsFromText(textBox and textBox.Text or "")
		currentTarget = nil
	
		for _, plr in ipairs(targets) do
			if plr.Character then
				local hum = plr.Character:FindFirstChildOfClass("Humanoid")
	
				if hum and hum.Health > 0 then
					currentTarget = plr
					viewTarget(plr) 
					break
				end
			end
		end
	
		if not currentTarget then
			resetCamera()
		end
	
		return currentTarget
	end
	
	-- Remote Finder
	local function getRemote()
		local core = character and character:FindFirstChild("Core")
		local comm = core and core:FindFirstChild("Communicate")
		if not comm then return nil end
	
		for _, v in pairs(comm:GetChildren()) do
			if v:IsA("RemoteEvent") then
				return v
			end
		end
	end
	
	-- Fixed Prediction: Stays perfectly underneath them even during flings
	local function predictPosition(tChar)
		if not tChar then return Vector3.new() end
	
		local trackingPart = tChar:FindFirstChild("UpperTorso") 
			or tChar:FindFirstChild("Torso") 
		if not trackingPart then return Vector3.new() end
	
		local vel = trackingPart.AssemblyLinearVelocity
		local speed = vel.Magnitude
	
		-- FLING DETECTOR: If speed is higher than a normal player running sprint, 
		-- it means they are trying to fling. Drop prediction entirely to stay glued directly under them.
		if speed > MAX_PREDICT_SPEED then
			return trackingPart.Position
		elseif speed < 0.1 then
			return trackingPart.Position
		end
	
		return trackingPart.Position + (vel * attackDelay * PREDICTION_FACTOR)
	end
	
	-- Return home
	local function returnToOriginalPosition()
		resetCamera() 
	
		local myHRP = character and character:FindFirstChild("HumanoidRootPart")
		if myHRP and originalCFrame then
			myHRP.CFrame = originalCFrame
			myHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
			myHRP.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
	
			if humanoid then
				humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
			end
	
			originalCFrame = nil 
		end
	end
	
	-- Animations
	local function stopAllAnimations()
		local animator = humanoid and humanoid:FindFirstChildOfClass("Animator")
		if animator then
			for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
				track:Stop(0) 
			end
		end
	end
	
	local function startAnimationSuppressor()
		if animConnection then return end
	
		stopAllAnimations() 
	
		local animator = humanoid:WaitForChild("Animator", 3)
		if animator then
			animConnection = animator.AnimationPlayed:Connect(function(track)
				if attacking and currentTarget then 
					track:Stop(0)
				end
			end)
		end
	end
	
	local function stopAnimationSuppressor()
		if animConnection then
			animConnection:Disconnect()
			animConnection = nil
		end
	end
	
	-- Attack Executor
	local function attack()
		updateCurrentClass()
	
		local remote = getRemote()
		if not remote then return end
	
		local target = getClosest()
		if not target or not target.Character then return end
	
		local tChar = target.Character
		local hrp = tChar:FindFirstChild("UpperTorso") 
			or tChar:FindFirstChild("Torso") 
			or tChar:FindFirstChild("HumanoidRootPart")
	
		if not hrp then return end
	
		local hitPart = tChar:FindFirstChild("Head") or hrp
		local offHand = "LeftHand"
	
		local args = {
			"Heavy",
			{
				Point = hrp.Position,
				Combo = math.random(1, 5),
				Class = currentClass,
				IsKnockdown = false,
				Character = tChar,
				Hit = hitPart,
				Limb = offHand,
				Result = nil
			},
			false
		}
	
		remote:FireServer(unpack(args))
		remote:FireServer("Swing", { Limb = offHand })
	end
	
	-- Movement loop
	local function startMovementLoop()
		if moveConnection then return end
	
		moveConnection = RunService.Heartbeat:Connect(function()
			if not attacking or not wipEnabled then return end
	
			local myHRP = character and character:FindFirstChild("HumanoidRootPart")
			local target = getClosest()
	
			if myHRP and target and target.Character then
				local tChar = target.Character
	
				if tChar then
					if not originalCFrame then
						originalCFrame = myHRP.CFrame
					end
	
					local predictedPos = predictPosition(tChar)
					local underPos = Vector3.new(
						predictedPos.X,
						predictedPos.Y - 7, -- Stays strictly 7 studs below their torso position
						predictedPos.Z
					)
	
					-- Keep local velocities perfectly blanked out to deny physical momentum transfer
					myHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
					myHRP.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
					myHRP.CFrame = CFrame.new(underPos) * CFrame.Angles(math.rad(90), 0, 0)
	
					viewTarget(target)
				else
					if originalCFrame then
						returnToOriginalPosition()
					end
				end
			else
				if originalCFrame then
					returnToOriginalPosition()
				end
			end
		end)
	end
	
	local function stopMovementLoop()
		if moveConnection then
			moveConnection:Disconnect()
			moveConnection = nil
		end
	end
	
	local function shutDownEverything()
		attacking = false
		wipEnabled = false
		currentTarget = nil
		stopMovementLoop()
		stopAnimationSuppressor()
		returnToOriginalPosition()
		resetCamera() 
	end
	
	local function startLoop()
		if attacking then return end
	
		attacking = true
		startMovementLoop()
		startAnimationSuppressor()
	
		task.spawn(function()
			while wipEnabled and attacking do
				local target = getClosest()
	
				if target and target.Character then
					attack()
				else
					currentTarget = nil
					returnToOriginalPosition()
				end
	
				task.wait(attackDelay)
			end
		end)
	end
	
	-- Button Toggle
	if wipButton and wipButton:IsA("GuiButton") then
		wipButton.MouseButton1Down:Connect(function()
			wipEnabled = not wipEnabled
	
			if wipEnabled then
				wipButton.BackgroundColor3 = Color3.fromRGB(51, 255, 47)
	
				local myHRP = character and character:FindFirstChild("HumanoidRootPart")
				if myHRP then originalCFrame = myHRP.CFrame end
	
				startLoop()
			else
				wipButton.BackgroundColor3 = Color3.fromRGB(255, 11, 0)
				shutDownEverything()
			end
		end)
	end
	
	-- Auto-reset camera
	Players.PlayerRemoving:Connect(function(leavingPlayer)
		if currentTarget and leavingPlayer == currentTarget then
			currentTarget = nil
			if originalCFrame then
				returnToOriginalPosition()
			else
				resetCamera()
			end
		end
	end)
	
	player.CharacterAdded:Connect(function(char)
		attacking = false
		stopMovementLoop()
		stopAnimationSuppressor()
	
		character = char
		humanoid = char:WaitForChild("Humanoid")
		local hrp = char:WaitForChild("HumanoidRootPart", 5)
	
		originalCFrame = nil 
		currentTarget = nil
		resetCamera()
	
		handleCharacterParenting(char)
	
		if wipEnabled and hrp then
			task.wait(0.5) 
			if wipEnabled then 
				originalCFrame = hrp.CFrame
				startLoop()
			end
		end
	end)
end
