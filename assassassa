			button.BackgroundColor3 = Color3.fromRGB(51, 255, 47) 
			DisableOtherPlayersTouch(true)
		else
			-- Turn red (OFF) -> Allows other players to touch you normally again
			button.BackgroundColor3 = Color3.fromRGB(255, 0, 0) 
			DisableOtherPlayersTouch(false)
		end
	end
	
	button.MouseButton1Click:Connect(h)
