			moveConnection:Disconnect()
			moveConnection = nil
		end
	end
	
	-- =========================
	-- LOOP
	-- =========================
	local function startLoop()
		if attacking then return end
		attacking = true
		startMovementLoop()
	
		task.spawn(function()
			while attacking do
				attack()
				task.wait(ATTACK_DELAY)
			end
		end)
