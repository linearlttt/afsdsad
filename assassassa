local function EIMOT_fake_script() -- OutlastHubNormalPremium_2.MakeEveryoneGlitchThemselves.LocalScript 
	local script = Instance.new('LocalScript', OutlastHubNormalPremium_2.MakeEveryoneGlitchThemselves)

	local Players = game:GetService("Players")
	local ReplicatedStorage = game:GetService("ReplicatedStorage")
	local Workspace = game:GetService("Workspace")
	
	local player = Players.LocalPlayer
	local click = script.Parent:FindFirstChild("WipButton")
	local ignoreFriendsButton = script.Parent:FindFirstChild("IgnoreFriends") 
	
	local Toggle = false
	local IgnoreFriendsToggle = false 
	
	-- Added the ignore array with UserIDs
	local ignore = { 11129834992, 11137378956 }
	
	local LOOP_DELAY = 0.05      
	local ItemCycle = {
		"VendingMachine", 
		"Sink", 
		"Football", 
		"Trash", 
		"Wet Floor Sign", 
		"FireExtinguisher", 
		"Classroom Chairs", 
		"Bench", 
		"Basketballs"
	}
	
	local CurrentIndex = 1
	local remotesFolder = ReplicatedStorage:FindFirstChild("Remotes")
	
	local friendCache = {}
	local currentHand = "RightHand" -- Track weapon hand state for shove sequence
	
	-- Quick helper function to check if a user is in the ignore list
	local function isIgnored(targetPlr)
		if not targetPlr then return false end
		return table.find(ignore, targetPlr.UserId) ~= nil
	end
	
	local function checkFriendship(targetPlr)
		if targetPlr == player then return end
	
		friendCache[targetPlr.UserId] = true 
	
		local success, isFriend = pcall(function()
			return player:IsFriendsWith(targetPlr.UserId)
		end)
	
		if success then
			friendCache[targetPlr.UserId] = isFriend
		else
			friendCache[targetPlr.UserId] = false
		end
	end
	
	-- Initialize cache
	for _, plr in ipairs(Players:GetPlayers()) do
		task.spawn(checkFriendship, plr)
	end
	
	Players.PlayerAdded:Connect(function(plr)
		checkFriendship(plr)
	end)
	
	Players.PlayerRemoving:Connect(function(plr)
		friendCache[plr.UserId] = nil
	end)
	
	local function isPlayerLoaded(targetPlr)
		if not targetPlr then return false end
	
		local loadedValue = targetPlr:FindFirstChild("Loaded")
		if loadedValue and (loadedValue:IsA("BoolValue") or loadedValue:IsA("StringValue")) then
			return loadedValue.Value == true or tostring(loadedValue.Value):lower() == "true"
		end
	
		local loadedAttribute = targetPlr:GetAttribute("Loaded")
		if loadedAttribute ~= nil then
			return loadedAttribute == true or tostring(loadedAttribute):lower() == "true"
		end
	
		return false
	end
	
	local function getCommRemote(character)
		local core = character:FindFirstChild("Core")
		local comm = core and core:FindFirstChild("Communicate")
		if comm then
			for _, v in pairs(comm:GetChildren()) do
				if v:IsA("RemoteEvent") then 
					return v 
				end
			end
		end
		return nil
	end
	
	local function getClassValue()
		local leaderstats = player:FindFirstChild("leaderstats")
		local classObj = leaderstats and leaderstats:FindFirstChild("Class")
		return classObj and classObj.Value or ""
	end
	
	-- Force characters inside Workspace.Live to shove themselves
	local function massSelfShove()
		local liveFolder = Workspace:FindFirstChild("Live")
		if not liveFolder then return end
	
		local currentClass = getClassValue()
	
		for _, character in ipairs(liveFolder:GetChildren()) do
			local targetPlr = Players:GetPlayerFromCharacter(character)
	
			if targetPlr and targetPlr ~= player and isPlayerLoaded(targetPlr) then
				local shouldSkipFriend = IgnoreFriendsToggle and friendCache[targetPlr.UserId]
				local shouldIgnore = isIgnored(targetPlr)
	
				if not shouldSkipFriend and not shouldIgnore then
					local hrp = character:FindFirstChild("HumanoidRootPart")
					local commRemote = getCommRemote(character)
	
					if commRemote and hrp then
						local args = {
							"Shove",
							{
								Character = character, -- Target character is set to themselves
								Point = hrp.Position,
								Hit = hrp,
								Limb = currentHand, 
								Classs = currentClass,
								Result = nil
							}
						}
						commRemote:FireServer(unpack(args))
					end
				end
			end
		end
	
		-- Alternating hands globally per iteration
		currentHand = (currentHand == "RightHand") and "LeftHand" or "RightHand"
	end
	
	-- UI Button Toggle Connection (Main Button)
	if click then
		click.MouseButton1Down:Connect(function()
			Toggle = not Toggle
			click.BackgroundColor3 = Toggle and Color3.fromRGB(51, 255, 47) or Color3.fromRGB(255, 0, 0)
		end)
	end
	
	-- UI Button Toggle Connection for IgnoreFriends
	if ignoreFriendsButton then
		ignoreFriendsButton.MouseButton1Down:Connect(function()
			IgnoreFriendsToggle = not IgnoreFriendsToggle
			ignoreFriendsButton.BackgroundColor3 = IgnoreFriendsToggle and Color3.fromRGB(51, 255, 47) or Color3.fromRGB(255, 0, 0)
		end)
	end
	
	-- Main Task Loop
	task.spawn(function()
		while true do
			if not Toggle then 
				task.wait(0.5) -- Sleep when toggled off to save CPU
				continue 
			end
	
			-- Runs the self-shoving routine for targets in Workspace.Live
			pcall(massSelfShove)
	
			local throwableRemote = remotesFolder and remotesFolder:FindFirstChild("ThrowableRemote")
			if throwableRemote then
				local activePlayers = Players:GetPlayers()
				local performedAttack = false
	
				for i = 1, #activePlayers do
					local attacker = activePlayers[i]
	
					local shouldSkipFriend = IgnoreFriendsToggle and friendCache[attacker.UserId]
					local shouldIgnore = isIgnored(attacker)
	
					if attacker ~= player and not shouldSkipFriend and not shouldIgnore and isPlayerLoaded(attacker) then
						local attackerChar = attacker.Character
						local attackerRoot = attackerChar and attackerChar:FindFirstChild("HumanoidRootPart")
	
						if attackerRoot and attackerChar:IsDescendantOf(Workspace) then
							local commRemote = getCommRemote(attackerChar)
	
							if commRemote then
								local currentItem = ItemCycle[CurrentIndex]
	
								commRemote:FireServer("Pickup", {Object = attackerChar, Type = currentItem}, false)
								commRemote:FireServer("Throw", {
									Type = currentItem, 
									Object = attackerChar, 
									HoldDuration = nil, 
									Held = nil, 
									Aim = attackerRoot.Position
								}, false)
	
								performedAttack = true
							end
						end
					end
				end
	
				if performedAttack then
					CurrentIndex = (CurrentIndex % #ItemCycle) + 1
				end
			end
	
			task.wait(LOOP_DELAY) -- Throttles the loop execution
		end
	end)
end
