local function GNAW_fake_script() -- OutlastHubNormalPremium_2.TextLabel_42.LocalScript 
	local script = Instance.new('LocalScript', OutlastHubNormalPremium_2.TextLabel_42)

	local Toggle = false
	local button = script.Parent:FindFirstChild("WipButton")
	
	-- State tracking and connection storage
	local States = { Interact = false }
	local Connections = {}
	
	-- The function that handles disabling/enabling throwables
	local function DisableThrowables(args1)
		States.Interact = args1
	
		local Interaction = workspace:FindFirstChild("Map")
			and workspace.Map:FindFirstChild("Interaction")
	
		if not Interaction then
			return
		end
	
		local function Taken(model, value)
			if model:IsA("Model") then
				model:SetAttribute("Taken", value)
			end
		end
	
		-- Clean up old event listeners
		for _, connection in ipairs(Connections) do
			connection:Disconnect()
		end
		table.clear(Connections)
	
		-- Loop through folders and apply the "Taken" attribute
		for _, folder in ipairs(Interaction:GetChildren()) do
			if folder:IsA("Folder") then
	
				for _, model in ipairs(folder:GetChildren()) do
					Taken(model, args1)
				end
	
				-- If toggled ON, listen for newly added items
				if args1 then
					table.insert(Connections,
						folder.ChildAdded:Connect(function(model)
							Taken(model, true)
						end)
					)
				end
			end
		end
	end
	
	-- The button toggle click event
	local function h()
		Toggle = not Toggle
	
		if Toggle then
			-- Turn green (ON) -> Disables Throwables
			button.BackgroundColor3 = Color3.fromRGB(51, 255, 47) 
			DisableThrowables(true)
		else
			-- Turn red (OFF) -> Enables Throwables back
			button.BackgroundColor3 = Color3.fromRGB(255, 0, 0) 
			DisableThrowables(false)
		end
	end
	
	button.MouseButton1Click:Connect(h)
end
coroutine.wrap(GNAW_fake_script)()
