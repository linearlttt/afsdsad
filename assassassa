		local hitPart = tChar:FindFirstChild("LeftUpperArm") or torsoPart
		local godZone = Vector3.new(9e9, 9e9, 9e9)
	
		remote:FireServer("Grab")
		task.wait(0.02)
		-- RE-VERIFY CONDITIONS: Make sure mode hasn't changed or stopped during task.wait
		if not attacking or currentMode ~= "Blatant" then return end
	
		local args = {
			"Slam",
			{
				Character = tChar,
				Point = godZone,
				Hit = hitPart,
				Limb = "",
				Class = currentClass, -- Fixed minor typo ('Classs' -> 'Class')
				Result = {
					Position = godZone,
