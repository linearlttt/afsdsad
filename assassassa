			wipButton.BackgroundColor3 = wipEnabled and Color3.fromRGB(51, 255, 47) or Color3.fromRGB(255, 11, 0)
		end
	end
	
	local function shutDownEverything()
		attacking = false
		currentTarget = nil
		updateButtonVisuals()
	end
	
	local function startLoop()
		if not wipEnabled then return end
		attacking = true
	
		-- Isolated Auto-Slam Loop
		task.spawn(function()
			while wipEnabled and attacking do
				local target = getClosest()
				if target and target.Character then
					slamTarget(target)
				end
				task.wait(slamDelay)
			end
		end)
	end
	
	-- MASTER TOGGLE CLICK
	if wipButton and wipButton:IsA("GuiButton") then
		wipButton.BackgroundColor3 = Color3.fromRGB(255, 11, 0)
		wipButton.MouseButton1Down:Connect(function()
			wipEnabled = not wipEnabled
			if wipEnabled then
				updateButtonVisuals()
				startLoop()
			else
				shutDownEverything()
			end
		end)
	end
	
	-- CLEANUP & RESET
	Players.PlayerRemoving:Connect(function(leavingPlayer)
		if currentTarget and leavingPlayer == currentTarget then
			currentTarget = nil
		end
	end)
	
	player.CharacterAdded:Connect(function(char)
		local backupWip = wipEnabled
		shutDownEverything()
	
		character = char
		humanoid = char:WaitForChild("Humanoid")
	
		if backupWip then
			task.wait(0.5)
			wipEnabled = true
			updateButtonVisuals()
			startLoop()
		end
	end)
end
